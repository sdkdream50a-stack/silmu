<%# 이월·전용 적법성 판단기 %>

<section class="section py-10">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- 뒤로가기 -->
    <div class="mb-6">
      <%= link_to tools_path, class: "inline-flex items-center text-slate-600 hover:text-amber-600 transition-colors font-medium" do %>
        <span class="material-symbols-outlined mr-1">arrow_back</span>
        도구 목록으로
      <% end %>
    </div>

    <!-- 헤더 -->
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-4">
        <div class="icon-container icon-container-lg gradient-amber shadow-lg">
          <span class="material-symbols-outlined text-3xl text-white">swap_horiz</span>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-900">이월·전용 적법성 판단기</h1>
          <p class="text-slate-500">예산 이월·전용 요건을 법령 기준으로 즉시 확인</p>
        </div>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5">
        <p class="text-amber-800 text-sm leading-relaxed">
          <strong>근거 법령:</strong> 지방재정법 제48조~제49조(이월), 지방재정법 제49조(전용), 국가재정법 제46조~제48조, 지방자치단체 예산편성 운영기준
        </p>
      </div>
    </div>

    <!-- 탭 선택 -->
    <div class="flex gap-3 mb-6">
      <button onclick="switchTab('carryover')" id="tab-carryover"
              class="flex-1 py-3 rounded-xl font-semibold text-sm transition-all bg-amber-500 text-white shadow">
        이월 (예산 다음 연도 이행)
      </button>
      <button onclick="switchTab('transfer')" id="tab-transfer"
              class="flex-1 py-3 rounded-xl font-semibold text-sm transition-all bg-slate-100 text-slate-600">
        전용 (같은 연도 다른 과목으로)
      </button>
    </div>

    <!-- 이월 판단 -->
    <div id="section-carryover">
      <div class="space-y-4 mb-6">
        <h2 class="text-lg font-bold text-slate-900">이월 유형 선택</h2>
        <div class="grid grid-cols-1 gap-4">
          <!-- 명시이월 -->
          <div class="card p-5 border-2 border-slate-200 cursor-pointer hover:border-amber-400 transition-colors" onclick="showCarryoverDetail('explicit')">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-amber-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-amber-600">event_available</span>
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">명시이월</h3>
                <p class="text-sm text-slate-600">세출예산 중 연도 내 지출을 끝내지 못할 것이 예측되는 경비를 <strong>예산을 편성할 때부터</strong> 미리 이월로 지정한 경우</p>
                <p class="text-xs text-slate-400 mt-1">지방재정법 제48조 / 국가재정법 제24조</p>
              </div>
            </div>
          </div>

          <!-- 사고이월 -->
          <div class="card p-5 border-2 border-slate-200 cursor-pointer hover:border-amber-400 transition-colors" onclick="showCarryoverDetail('accident')">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-orange-600">warning</span>
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">사고이월</h3>
                <p class="text-sm text-slate-600">연도 내 지출 원인 행위를 마쳤으나 <strong>불가피한 사유</strong>로 연도 내 지출하지 못한 경우</p>
                <p class="text-xs text-slate-400 mt-1">지방재정법 제48조 제2항 / 국가재정법 제48조 제2항</p>
              </div>
            </div>
          </div>

          <!-- 계속비이월 -->
          <div class="card p-5 border-2 border-slate-200 cursor-pointer hover:border-amber-400 transition-colors" onclick="showCarryoverDetail('continuing')">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-blue-600">timeline</span>
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">계속비이월</h3>
                <p class="text-sm text-slate-600">수 년도에 걸쳐 진행되는 사업의 해당 연도 미집행액을 <strong>계속비</strong>로 편성·승인 후 이월</p>
                <p class="text-xs text-slate-400 mt-1">지방재정법 제45조 / 국가재정법 제23조</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 이월 상세 판단 -->
      <div id="carryover-detail" class="hidden">
        <!-- JS로 생성 -->
      </div>
    </div>

    <!-- 전용 판단 -->
    <div id="section-transfer" class="hidden">
      <div class="card p-6 mb-6">
        <h2 class="text-lg font-bold text-slate-900 mb-5 flex items-center gap-2">
          <span class="material-symbols-outlined text-amber-600">swap_horiz</span>
          전용 요건 확인
        </h2>
        <div class="space-y-4 mb-5">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" class="transfer-chk mt-1 w-4 h-4 accent-amber-500" onchange="checkTransfer()">
            <div>
              <p class="text-sm font-semibold text-slate-800">전용 대상 과목이 같은 정책사업 내에 있다</p>
              <p class="text-xs text-slate-500">이 범위를 벗어나는 전용은 원칙적으로 불가 (의회 추경 필요). 지방예산은 회계-정책사업-단위사업-목 체계 적용 (장·관·항은 국가재정 과목체계)</p>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" class="transfer-chk mt-1 w-4 h-4 accent-amber-500" onchange="checkTransfer()">
            <div>
              <p class="text-sm font-semibold text-slate-800">인건비에서 다른 목으로 전용하는 것이 아니다</p>
              <p class="text-xs text-slate-500">인건비 전용은 원칙적으로 금지 (지방재정법 제49조)</p>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" class="transfer-chk mt-1 w-4 h-4 accent-amber-500" onchange="checkTransfer()">
            <div>
              <p class="text-sm font-semibold text-slate-800">전용 후 해당 목의 집행이 당초 편성 취지에 부합한다</p>
              <p class="text-xs text-slate-500">전용 목적이 원래 편성 취지를 벗어나지 않아야 함</p>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" class="transfer-chk mt-1 w-4 h-4 accent-amber-500" onchange="checkTransfer()">
            <div>
              <p class="text-sm font-semibold text-slate-800">단체장 전결 또는 의회 승인 절차를 거칠 수 있다</p>
              <p class="text-xs text-slate-500">전용 규모에 따라 의회 동의가 필요할 수 있음</p>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" class="transfer-chk mt-1 w-4 h-4 accent-amber-500" onchange="checkTransfer()">
            <div>
              <p class="text-sm font-semibold text-slate-800">법령에 의해 전용이 금지된 경비가 아니다</p>
              <p class="text-xs text-slate-500">예비비, 국고보조금, 계속비 등은 전용 제한 또는 금지</p>
            </div>
          </label>
        </div>

        <div id="transfer-result" class="hidden">
          <!-- JS로 생성 -->
        </div>
      </div>

      <div class="card p-5 bg-amber-50 border border-amber-200">
        <h3 class="text-sm font-bold text-amber-900 mb-3">전용 절차 요약</h3>
        <ol class="space-y-2 text-sm text-amber-800">
          <li class="flex gap-2"><span class="font-bold">①</span> 예산 전용 요구서 작성</li>
          <li class="flex gap-2"><span class="font-bold">②</span> 기획·예산 부서 검토</li>
          <li class="flex gap-2"><span class="font-bold">③</span> 단체장 전결 (또는 의회 심의·의결)</li>
          <li class="flex gap-2"><span class="font-bold">④</span> 재정정보시스템(e호조) 전산 처리</li>
          <li class="flex gap-2"><span class="font-bold">⑤</span> 세입세출결산서에 전용 내역 표시</li>
        </ol>
      </div>
    </div>
  </div>
</section>

<script>
  const CARRYOVER_DETAILS = {
    explicit: {
      title: "명시이월 요건 점검",
      color: "amber",
      requirements: [
        { text: "당초 예산 편성 시 세출예산 각목 명세서에 명시이월 예정 사항으로 기재하였다", critical: true },
        { text: "의회 예산 심의·의결 과정에서 해당 이월 사항이 포함된 예산이 가결되었다", critical: true },
        { text: "이월 대상 경비가 연도 내 완료가 불가능한 구체적 사유가 있다", critical: false },
        { text: "이월 금액과 사유를 결산 시 명시이월 명세서에 기재할 준비가 되었다", critical: false },
      ],
      procedure: ["예산 편성 단계에서 세출명세서에 이월 기재", "의회 예산 심의 통과", "다음 연도 예산으로 이월 처리", "결산 시 명시이월 명세서 작성"],
      caution: "명시이월은 예산을 편성할 때부터 계획된 이월입니다. 사업 도중에 명시이월로 변경하는 것은 불가합니다. 사업 도중 불가피한 사유로 이월이 필요하다면 사고이월을 검토하세요."
    },
    accident: {
      title: "사고이월 요건 점검",
      color: "orange",
      requirements: [
        { text: "해당 회계연도 내에 지출 원인 행위(계약 체결 또는 발주)가 완료되었다", critical: true },
        { text: "연도 내 지출이 불가능한 사유가 천재지변, 법령 개정, 예측불가한 사정으로 인한 것이다", critical: true },
        { text: "단순 행정 지연이나 담당자 과실로 인한 이월이 아니다 (단순 지연은 불가)", critical: true },
        { text: "이월 사유를 구체적으로 소명하는 사유서를 작성할 수 있다", critical: true },
        { text: "이월 금액이 당초 지출 원인 행위 금액 이내이다", critical: false },
      ],
      procedure: ["연도 말 지출 원인 행위 확인", "사고이월 사유서 작성", "기획·예산 부서 검토 및 단체장 결재", "다음 연도 예산으로 이월 처리", "결산 시 사고이월 명세서 작성"],
      caution: "감사에서 가장 자주 지적되는 이월 유형입니다. '불가피한 사유' 없이 처리하면 감사 지적 대상이 됩니다. 사유서에는 지출 원인 행위 날짜, 지출 미완성 이유, 향후 집행 계획을 구체적으로 명시하세요."
    },
    continuing: {
      title: "계속비이월 요건 점검",
      color: "blue",
      requirements: [
        { text: "해당 사업이 수 회계연도에 걸쳐 시행하는 공사·제조·연구개발 사업이다", critical: true },
        { text: "의회에서 계속비로 의결된 사업이다 (연도 총액 및 연부액 의결)", critical: true },
        { text: "이월 금액이 해당 연도 계속비 예산 중 미집행액이다", critical: true },
        { text: "계속비 사업의 완성 연도가 남아 있다", critical: false },
      ],
      procedure: ["계속비 의회 의결 확인", "해당 연도 미집행액 산정", "계속비이월 명세서 작성", "다음 연도로 이월 처리"],
      caution: "계속비는 처음 예산 편성 시 의회의 별도 의결이 필요합니다. 의회 의결 없이 계속비를 처리하는 것은 불법입니다."
    }
  };

  function showCarryoverDetail(type) {
    const data = CARRYOVER_DETAILS[type];
    const container = document.getElementById('carryover-detail');
    container.classList.remove('hidden');

    const colorMap = { amber: 'amber', orange: 'orange', blue: 'blue' };
    const c = colorMap[data.color];

    let html = `
      <div class="card p-6 border-2 border-${c}-200 bg-${c}-50">
        <h2 class="text-lg font-bold text-${c}-900 mb-5">${data.title}</h2>
        <div class="space-y-2 mb-5">`;

    data.requirements.forEach(req => {
      html += `
        <label class="flex items-start gap-3 cursor-pointer group p-2 rounded-lg hover:bg-white/60">
          <input type="checkbox" class="co-item mt-0.5 w-4 h-4 accent-${c}-500 flex-shrink-0" onchange="updateCarryoverProgress('${type}', ${data.requirements.length})">
          <div>
            <span class="text-sm text-slate-700">${req.text}</span>
            ${req.critical ? `<span class="ml-1 text-xs font-semibold text-red-500 bg-red-50 px-1.5 py-0.5 rounded">필수</span>` : ''}
          </div>
        </label>`;
    });

    html += `
        </div>

        <div class="p-4 bg-white rounded-xl border border-${c}-200 mb-4">
          <p class="text-xs font-bold text-${c}-700 mb-2">처리 절차</p>
          <ol class="space-y-1">
            ${data.procedure.map((p, i) => `<li class="text-sm text-slate-700 flex gap-2"><span class="font-bold text-${c}-600">0${i + 1}</span>${p}</li>`).join('')}
          </ol>
        </div>

        <div class="p-4 bg-white rounded-xl border border-orange-200">
          <p class="text-xs font-bold text-orange-700 mb-1">⚠️ 주의사항</p>
          <p class="text-sm text-orange-800">${data.caution}</p>
        </div>

        <div class="mt-4">
          <div class="flex justify-between text-xs font-semibold text-${c}-700 mb-1">
            <span>요건 충족 현황</span>
            <span id="co-progress-${type}">0 / ${data.requirements.length}</span>
          </div>
          <div class="bg-white/60 rounded-full h-2">
            <div id="co-bar-${type}" class="h-full rounded-full bg-${c}-500 transition-all" style="width:0%"></div>
          </div>
        </div>
      </div>`;

    container.innerHTML = html;
    container.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function updateCarryoverProgress(type, total) {
    const checked = document.querySelectorAll(`.co-item:checked`).length;
    const pct = total > 0 ? (checked / total * 100) : 0;
    const bar = document.getElementById(`co-bar-${type}`);
    const txt = document.getElementById(`co-progress-${type}`);
    if (bar) bar.style.width = pct + '%';
    if (txt) txt.textContent = `${checked} / ${total}`;
  }

  function checkTransfer() {
    const total = document.querySelectorAll('.transfer-chk').length;
    const checked = document.querySelectorAll('.transfer-chk:checked').length;
    const result = document.getElementById('transfer-result');

    result.classList.remove('hidden');

    if (checked === total) {
      result.innerHTML = `<div class="p-4 bg-green-50 rounded-xl border border-green-200">
        <p class="text-sm font-bold text-green-700 mb-1">✅ 전용 가능 요건 충족</p>
        <p class="text-sm text-green-600">모든 요건을 충족합니다. 위의 전용 절차에 따라 진행하세요. 처리 후 재정정보시스템에 반드시 반영하세요.</p>
      </div>`;
    } else if (checked >= 3) {
      result.innerHTML = `<div class="p-4 bg-amber-50 rounded-xl border border-amber-200">
        <p class="text-sm font-bold text-amber-700 mb-1">⚡ 추가 검토 필요</p>
        <p class="text-sm text-amber-600">일부 요건이 미충족 상태입니다. 미체크 항목을 다시 확인하거나 예산 부서와 협의하세요.</p>
      </div>`;
    } else {
      result.innerHTML = `<div class="p-4 bg-red-50 rounded-xl border border-red-200">
        <p class="text-sm font-bold text-red-700 mb-1">❌ 전용 불가 가능성 높음</p>
        <p class="text-sm text-red-600">요건 미충족 항목이 많습니다. 전용 대신 추가경정예산 편성을 검토하거나 예산 부서와 반드시 협의하세요.</p>
      </div>`;
    }
  }

  function switchTab(tab) {
    const isCarryover = tab === 'carryover';
    document.getElementById('section-carryover').classList.toggle('hidden', !isCarryover);
    document.getElementById('section-transfer').classList.toggle('hidden', isCarryover);
    document.getElementById('tab-carryover').className = `flex-1 py-3 rounded-xl font-semibold text-sm transition-all ${isCarryover ? 'bg-amber-500 text-white shadow' : 'bg-slate-100 text-slate-600'}`;
    document.getElementById('tab-transfer').className = `flex-1 py-3 rounded-xl font-semibold text-sm transition-all ${!isCarryover ? 'bg-amber-500 text-white shadow' : 'bg-slate-100 text-slate-600'}`;
  }
</script>
