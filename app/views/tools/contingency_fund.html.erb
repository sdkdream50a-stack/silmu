<%# 예비비 한도 계산기 %>

<section class="section py-10">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- 뒤로가기 -->
    <div class="mb-6">
      <%= link_to tools_path, class: "inline-flex items-center text-slate-600 hover:text-editorial-navy transition-colors font-medium" do %>
        <span class="material-symbols-outlined mr-1">arrow_back</span>
        도구 목록으로
      <% end %>
    </div>

    <!-- 페이지 헤더 -->
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-4">
        <div class="icon-container icon-container-lg gradient-indigo shadow-lg">
          <span class="material-symbols-outlined text-3xl text-white">savings</span>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-900">예비비 한도 계산기</h1>
          <p class="text-slate-500">예산 규모별 법정 예비비 한도와 적정 편성 금액을 계산합니다</p>
        </div>
      </div>

      <details class="bg-white rounded-2xl shadow-sm border border-editorial-navy-bg mt-6">
        <summary class="px-6 py-4 cursor-pointer hover:bg-slate-50 transition-colors flex items-center gap-2 [list-style:none] [&::-webkit-details-marker]:hidden">
          <span class="material-symbols-outlined text-editorial-navy text-[20px]">info</span>
          <span class="text-sm font-semibold text-slate-700">이 도구를 사용하는 이유</span>
          <span class="ml-auto text-xs text-slate-400">펼치기 ▾</span>
        </summary>
        <div class="px-6 pb-6 prose prose-slate prose-sm max-w-none">
          <p class="text-slate-700 leading-relaxed mb-3">
            예비비는 예측하기 어려운 지출에 대비하여 편성하는 예산으로, <strong>지방재정법 제43조</strong>에 따라 일반예비비는 일반회계 예산 총액의
            <strong>1% 이내</strong>로 편성하도록 규정되어 있습니다. 목적예비비(재난·재해 대응 등)는 별도 편성 가능합니다.
          </p>
          <p class="text-slate-700 leading-relaxed mb-3">
            예비비를 과다 편성하면 실질 사업예산이 줄어들고, 과소 편성하면 예측 못한 지출 발생 시 추가경정예산 편성 등 행정 부담이 증가합니다.
            이 도구는 예산 총액을 입력하면 <strong>법정 한도와 권장 편성 범위</strong>를 자동 계산합니다.
          </p>
          <div class="bg-blue-50 border-l-4 border-blue-500 p-3 rounded-r-lg mt-4">
            <p class="text-blue-900 text-xs leading-relaxed">
              <strong>📌 참고:</strong> 지방재정법 제43조 (예비비) — 「일반회계와 교육비특별회계」는 각 예산 총액의 100분의 1 이내 금액을 예비비로 예산에 <strong>계상하여야 하며(의무)</strong>, 「그 밖의 특별회계」는 100분의 1 이내 금액을 예비비로 예산에 <strong>계상할 수 있다(임의)</strong>.
            </p>
          </div>
        </div>
      </details>
    </div>

    <div class="lg:flex lg:gap-8">
      <!-- 입력 폼 -->
      <div class="lg:w-1/2 mb-8 lg:mb-0">
        <div class="card p-6">
          <h2 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-editorial-navy">edit</span>
            예산 정보 입력
          </h2>

          <!-- 자치단체 유형 -->
          <div class="mb-5">
            <label class="block text-sm font-semibold text-slate-700 mb-2">자치단체 유형</label>
            <select id="entity-type" class="form-input w-full" onchange="calculate()">
              <option value="general">시·군·구 (일반시군구)</option>
              <option value="metro">특별시·광역시·도</option>
              <option value="special">특별자치시·특별자치도</option>
            </select>
          </div>

          <!-- 회계 구분 -->
          <div class="mb-5">
            <label class="block text-sm font-semibold text-slate-700 mb-2">회계 구분</label>
            <select id="account-type" class="form-input w-full" onchange="calculate()">
              <option value="general">일반회계</option>
              <option value="special">특별회계</option>
            </select>
            <p class="text-xs text-slate-400 mt-1">예비비 한도는 회계 구분별로 적용됩니다</p>
          </div>

          <!-- 예산 총액 -->
          <div class="mb-5">
            <label class="block text-sm font-semibold text-slate-700 mb-2">
              예산 총액
              <span class="text-xs font-normal text-slate-400 ml-1">(세출예산 총계 기준)</span>
            </label>
            <div class="relative">
              <input type="number" id="total-budget" placeholder="예: 500,000,000" min="0" step="1000000"
                class="form-input w-full pr-10" oninput="calculate()">
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">원</span>
            </div>
            <p class="text-xs text-slate-400 mt-1">당초예산 + 추가경정예산 기준 (천원 단위 정확히 입력)</p>
          </div>

          <!-- 현재 편성 예비비 -->
          <div class="mb-6">
            <label class="block text-sm font-semibold text-slate-700 mb-2">
              현재 편성 예비비
              <span class="text-xs font-normal text-slate-400 ml-1">(없으면 0 입력)</span>
            </label>
            <div class="relative">
              <input type="number" id="current-reserve" placeholder="0" min="0" step="1000000"
                class="form-input w-full pr-10" oninput="calculate()">
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">원</span>
            </div>
          </div>

          <!-- 목적예비비 포함 여부 -->
          <div class="mb-6">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" id="include-purpose" class="w-4 h-4 rounded" onchange="calculate()">
              <div>
                <span class="text-sm font-semibold text-slate-700">목적예비비 별도 편성 예정</span>
                <p class="text-xs text-slate-400">재난·재해 대응 등 특정 목적 예비비는 한도 외 별도 편성 가능</p>
              </div>
            </label>
            <div id="purpose-input" class="mt-3 hidden">
              <div class="relative">
                <input type="number" id="purpose-amount" placeholder="목적예비비 금액" min="0" step="1000000"
                  class="form-input w-full pr-10" oninput="calculate()">
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">원</span>
              </div>
            </div>
          </div>

          <button type="button" onclick="calculate()" class="w-full btn btn-point btn-md">
            <span class="material-symbols-outlined">calculate</span>
            한도 계산
          </button>
        </div>
      </div>

      <!-- 결과 -->
      <div class="lg:w-1/2">
        <div class="card p-6 h-full">
          <h2 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-editorial-navy">analytics</span>
            예비비 한도 분석
          </h2>

          <!-- 초기 안내 -->
          <div id="empty-state" class="flex flex-col items-center justify-center h-48 text-slate-300">
            <span class="material-symbols-outlined text-5xl mb-3">savings</span>
            <p class="text-sm">예산 총액을 입력하면 한도가 계산됩니다</p>
          </div>

          <!-- 결과 영역 -->
          <div id="result-area" class="hidden">
            <!-- 한도 현황 -->
            <div id="limit-card" class="rounded-xl p-4 mb-5">
              <div class="text-sm font-medium mb-1" id="limit-label">법정 최대 한도</div>
              <div id="limit-amount" class="text-3xl font-bold mb-1">-</div>
              <div id="limit-desc" class="text-xs opacity-80">예산 총액의 1% 이내</div>
            </div>

            <!-- 수치 비교 -->
            <div class="grid grid-cols-2 gap-3 mb-5">
              <div class="bg-white border border-slate-100 rounded-xl p-3 text-center">
                <div class="text-xs text-slate-400 mb-1">법정 최대 한도</div>
                <div id="max-limit" class="text-base font-bold text-editorial-navy-dark">-</div>
              </div>
              <div class="bg-white border border-slate-100 rounded-xl p-3 text-center">
                <div class="text-xs text-slate-400 mb-1">현재 편성액</div>
                <div id="current-amount" class="text-base font-bold text-slate-700">-</div>
              </div>
              <div class="bg-white border border-slate-100 rounded-xl p-3 text-center">
                <div class="text-xs text-slate-400 mb-1">적정 편성 범위</div>
                <div id="recommended-range" class="text-sm font-bold text-green-600">-</div>
              </div>
              <div class="bg-white border border-slate-100 rounded-xl p-3 text-center">
                <div class="text-xs text-slate-400 mb-1">목적예비비</div>
                <div id="purpose-display" class="text-base font-bold text-purple-600">-</div>
              </div>
            </div>

            <!-- 상태 메시지 -->
            <div id="status-message" class="rounded-xl p-4 text-sm mb-4"></div>

            <!-- 사용 가능 예비비 잔액 -->
            <div class="bg-slate-50 rounded-xl p-4">
              <div class="text-xs font-semibold text-slate-500 mb-2">예비비 사용 시 잔액 시뮬레이션</div>
              <div class="mb-3">
                <label class="block text-xs text-slate-500 mb-1">사용 예정액 (원)</label>
                <input type="number" id="usage-amount" placeholder="0" min="0" step="100000"
                  class="form-input w-full text-sm" oninput="simulateUsage()">
              </div>
              <div id="usage-result" class="text-sm text-slate-500 text-center py-2">금액을 입력하면 잔액이 계산됩니다</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 예비비 법령 안내 -->
    <div class="mt-8 card p-6">
      <h3 class="text-base font-bold text-slate-900 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-amber-600">gavel</span>
        예비비 관련 법령 안내
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
        <div class="bg-blue-50 rounded-xl p-4">
          <div class="font-semibold text-blue-800 mb-2">📋 일반예비비 (제43조)</div>
          <ul class="text-blue-700 space-y-1 text-xs">
            <li>• 일반회계 예산 총액의 1% 이내</li>
            <li>• 예측 불가능한 지출 대비</li>
            <li>• 행정안전부장관 승인 불필요</li>
            <li>• 단체장 재량으로 배정</li>
          </ul>
        </div>
        <div class="bg-purple-50 rounded-xl p-4">
          <div class="font-semibold text-purple-800 mb-2">🎯 목적예비비</div>
          <ul class="text-purple-700 space-y-1 text-xs">
            <li>• 특정 용도 지정 예비비</li>
            <li>• 재난·재해 대응 등</li>
            <li>• 1% 한도 외 별도 편성</li>
            <li>• 지정 목적에만 사용 가능</li>
          </ul>
        </div>
        <div class="bg-amber-50 rounded-xl p-4">
          <div class="font-semibold text-amber-800 mb-2">⚠️ 예비비 사용 절차</div>
          <ul class="text-amber-700 space-y-1 text-xs">
            <li>• 긴급·불가피한 경우에만 사용</li>
            <li>• 단체장 결재 후 집행</li>
            <li>• 다음 연도 예산에 반영 보고</li>
            <li>• 의회 승인은 사후 정리결산 시</li>
          </ul>
        </div>
        <%= render 'shared/ad_slot', position: 'tool-result' %>
      </div>
    </div>
  </div>
</section>

<script>
  // 목적예비비 체크박스
  document.getElementById('include-purpose').addEventListener('change', function() {
    document.getElementById('purpose-input').classList.toggle('hidden', !this.checked);
    calculate();
  });

  let calculatedReserve = 0;

  function calculate() {
    const budget = parseFloat(document.getElementById('total-budget').value) || 0;
    const current = parseFloat(document.getElementById('current-reserve').value) || 0;
    const includePurpose = document.getElementById('include-purpose').checked;
    const purposeAmount = includePurpose ? (parseFloat(document.getElementById('purpose-amount')?.value) || 0) : 0;

    if (budget <= 0) {
      document.getElementById('empty-state').classList.remove('hidden');
      document.getElementById('result-area').classList.add('hidden');
      return;
    }

    document.getElementById('empty-state').classList.add('hidden');
    document.getElementById('result-area').classList.remove('hidden');

    const maxLimit = Math.floor(budget * 0.01);
    const recommended_min = Math.floor(budget * 0.005);
    const recommended_max = maxLimit;

    calculatedReserve = current;

    // 한도 카드
    const limitCard = document.getElementById('limit-card');
    limitCard.className = 'rounded-xl p-4 mb-5 bg-editorial-navy-bg';
    document.getElementById('limit-label').textContent = '법정 최대 한도 (예산 총액의 1%)';
    document.getElementById('limit-label').className = 'text-sm font-medium mb-1 text-editorial-navy';
    document.getElementById('limit-amount').textContent = formatKRW(maxLimit);
    document.getElementById('limit-amount').className = 'text-3xl font-bold mb-1 text-editorial-navy-dark';
    document.getElementById('limit-desc').textContent = `예산 총액 ${formatKRW(budget)} × 1%`;
    document.getElementById('limit-desc').className = 'text-xs text-editorial-navy';

    // 수치
    document.getElementById('max-limit').textContent = formatKRW(maxLimit);
    document.getElementById('current-amount').textContent = current > 0 ? formatKRW(current) : '미입력';
    document.getElementById('recommended-range').textContent = `${formatKRW(recommended_min)} ~ ${formatKRW(recommended_max)}`;
    document.getElementById('purpose-display').textContent = includePurpose && purposeAmount > 0 ? formatKRW(purposeAmount) : '없음';

    // 상태 메시지
    const statusEl = document.getElementById('status-message');
    if (current <= 0) {
      statusEl.className = 'rounded-xl p-4 text-sm mb-4 bg-slate-50 border border-slate-200 text-slate-600';
      statusEl.innerHTML = `<div class="font-semibold mb-1">📊 예비비 편성 가이드</div>
        <div class="text-xs">적정 편성액: <strong>${formatKRW(recommended_min)} ~ ${formatKRW(recommended_max)}</strong><br>
        일반적으로 예산 총액의 <strong>0.5~1.0%</strong> 범위에서 편성하는 것이 권장됩니다.</div>`;
    } else if (current > maxLimit) {
      statusEl.className = 'rounded-xl p-4 text-sm mb-4 bg-red-50 border border-red-200 text-red-800';
      const excess = current - maxLimit;
      statusEl.innerHTML = `<div class="font-semibold mb-1">❌ 법정 한도 초과</div>
        <div class="text-xs">현재 편성액이 법정 한도를 <strong>${formatKRW(excess)}</strong> 초과합니다.<br>
        예산을 <strong>${formatKRW(maxLimit)}</strong> 이하로 조정해야 합니다.</div>`;
    } else if (current >= recommended_min) {
      statusEl.className = 'rounded-xl p-4 text-sm mb-4 bg-green-50 border border-green-200 text-green-800';
      const remaining = maxLimit - current;
      statusEl.innerHTML = `<div class="font-semibold mb-1">✅ 적정 편성</div>
        <div class="text-xs">법정 한도(${formatKRW(maxLimit)}) 대비 <strong>${formatKRW(remaining)}</strong> 추가 편성 가능합니다.<br>
        현재 편성률: 예산 총액의 ${(current / budget * 100).toFixed(2)}%</div>`;
    } else {
      statusEl.className = 'rounded-xl p-4 text-sm mb-4 bg-amber-50 border border-amber-200 text-amber-800';
      statusEl.innerHTML = `<div class="font-semibold mb-1">⚡ 편성 부족 가능성</div>
        <div class="text-xs">현재 편성액이 권장 최소액(${formatKRW(recommended_min)})보다 적습니다.<br>
        예측 불가 지출 발생 시 추경 편성이 필요할 수 있습니다.</div>`;
    }

    document.getElementById('usage-result').textContent = '금액을 입력하면 잔액이 계산됩니다';
    document.getElementById('usage-amount').value = '';
  }

  function simulateUsage() {
    const usage = parseFloat(document.getElementById('usage-amount').value) || 0;
    const current = parseFloat(document.getElementById('current-reserve').value) || 0;
    const resultEl = document.getElementById('usage-result');

    if (usage <= 0 || current <= 0) {
      resultEl.textContent = '금액을 입력하면 잔액이 계산됩니다';
      return;
    }

    const balance = current - usage;
    if (balance < 0) {
      resultEl.innerHTML = `<span class="text-red-600 font-semibold">⚠️ 잔액 부족: ${formatKRW(Math.abs(balance))} 초과 사용</span>`;
    } else {
      resultEl.innerHTML = `사용 후 잔액: <strong class="text-green-600">${formatKRW(balance)}</strong> (예산 총액의 ${(balance / (parseFloat(document.getElementById('total-budget').value) || 1) * 100).toFixed(3)}%)`;
    }
  }

  function formatKRW(n) {
    if (n >= 100000000) {
      const eo = Math.floor(n / 100000000);
      const man = Math.floor((n % 100000000) / 10000);
      if (man > 0) return `${eo}억 ${man.toLocaleString('ko-KR')}만원`;
      return `${eo}억원`;
    } else if (n >= 10000) {
      return `${Math.floor(n / 10000).toLocaleString('ko-KR')}만원`;
    }
    return `${n.toLocaleString('ko-KR')}원`;
  }
</script>
