<%# 댓글 카드 partial %>
<div id="comment-<%= comment.id %>" class="border-b border-slate-100 last:border-0 py-4">
  <div class="flex items-start gap-3">
    <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0
                <%= comment.is_official? ? 'bg-indigo-600' : 'bg-slate-200' %>">
      <span class="material-symbols-outlined text-sm
                   <%= comment.is_official? ? 'text-white' : 'text-slate-500' %>">
        <%= comment.is_official? ? 'verified' : 'person' %>
      </span>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xs font-semibold text-slate-700">
          <%= comment.author_name %>
        </span>
        <% if comment.is_official? %>
          <span class="text-xs px-2 py-0.5 bg-indigo-100 text-indigo-700 rounded-full font-medium">공식 답변</span>
        <% end %>
        <span class="text-xs px-2 py-0.5 rounded-full
                     <%= comment.question? ? 'bg-amber-100 text-amber-700' : comment.answer? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %>">
          <%= { "question" => "질문", "answer" => "답변", "comment" => "댓글" }[comment.comment_type] %>
        </span>
        <span class="text-xs text-slate-400 ml-auto"><%= comment.created_at.strftime("%m.%d %H:%M") %></span>
      </div>
      <p class="text-sm text-slate-700 leading-relaxed"><%= simple_format(comment.body) %></p>
      <div class="flex items-center gap-3 mt-2">
        <button onclick="fetch('/topics/<%= comment.topic_slug %>/comments/<%= comment.id %>/like', {method:'POST', headers:{'X-CSRF-Token': document.querySelector('[name=csrf-token]').content}}).then(()=>{this.querySelector('.count').textContent = parseInt(this.querySelector('.count').textContent)+1})"
                class="flex items-center gap-1 text-xs text-slate-400 hover:text-indigo-600 transition-colors">
          <span class="material-symbols-outlined text-sm">thumb_up</span>
          <span class="count"><%= comment.likes_count %></span>
        </button>
      </div>

      <!-- 대댓글 -->
      <% if comment.replies.any? %>
        <div class="mt-3 pl-4 border-l-2 border-slate-100 space-y-3">
          <% comment.replies.visible.order(created_at: :asc).each do |reply| %>
            <%= render partial: "topic_comments/comment", locals: { comment: reply } %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
