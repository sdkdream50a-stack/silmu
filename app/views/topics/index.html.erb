<%# Created: 2026-03-02 %>
<%# 법령 가이드 허브 페이지 — 9개 카테고리 카드 %>

<!-- 페이지 헤더 -->
<section class="gradient-premium text-white py-12 lg:py-16 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/4"></div>
  <div class="container-wide relative z-10">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div class="flex items-start gap-5">
        <div class="w-16 h-16 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/20 shadow-lg">
          <span class="material-symbols-outlined text-4xl text-white">library_books</span>
        </div>
        <div>
          <h1 class="text-3xl lg:text-4xl font-bold tracking-tight mb-2">법령 가이드</h1>
          <p class="text-white/80 text-lg">주요 법령을 법률→시행령→규칙 체계로 쉽게 정리</p>
        </div>
      </div>
      <div class="flex gap-4 lg:gap-6">
        <div class="text-center px-4 py-2 bg-white/10 backdrop-blur-md rounded-xl border border-white/15">
          <div class="text-2xl font-bold"><%= @total_count %></div>
          <div class="text-xs text-white/70 mt-0.5">전체 법령</div>
        </div>
        <div class="text-center px-4 py-2 bg-white/10 backdrop-blur-md rounded-xl border border-white/15">
          <div class="text-2xl font-bold"><%= @hub_categories.size %></div>
          <div class="text-xs text-white/70 mt-0.5">분야</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 카테고리 카드 그리드 -->
<section class="py-10 bg-background-light min-h-screen">
  <div class="container-wide">
    <% cache ["topics_hub_v1", @total_count, @hub_categories.map { |c| c[:count] }.join("-")] do %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @hub_categories.each do |cat| %>
        <% key = cat[:key]; cfg = cat[:cfg]; color = cfg[:color] %>
        <%= link_to topics_category_path(key: key),
            class: "group flex flex-col rounded-2xl bg-white p-6 shadow-sm border border-slate-100 transition-all hover:shadow-lg hover:-translate-y-0.5 hover:border-#{color}-100 cursor-pointer" do %>
          <!-- 아이콘 + 카테고리명 + 뱃지 -->
          <div class="flex items-center gap-3 mb-3">
            <div class="shrink-0 w-11 h-11 rounded-xl bg-<%= color %>-50 flex items-center justify-center group-hover:bg-<%= color %>-600 transition-colors">
              <span class="material-symbols-outlined text-xl text-<%= color %>-600 group-hover:text-white transition-colors"><%= cfg[:icon] %></span>
            </div>
            <h2 class="text-lg font-bold text-slate-900 group-hover:text-<%= color %>-700 transition-colors"><%= cfg[:label] %></h2>
            <span class="ml-auto text-xs font-semibold text-<%= color %>-600 bg-<%= color %>-50 px-2.5 py-1 rounded-full"><%= cat[:count] %>개</span>
          </div>

          <!-- 설명 -->
          <p class="text-sm text-slate-500 leading-relaxed mb-4"><%= cfg[:desc] %></p>

          <!-- 대표 토픽 미리보기 태그 -->
          <div class="flex flex-wrap gap-1.5 mb-5">
            <% cat[:preview].each do |topic| %>
              <span class="px-2.5 py-1 bg-slate-50 border border-slate-100 rounded-lg text-xs text-slate-500 leading-none"><%= topic.name %></span>
            <% end %>
            <% if cat[:count] > 3 %>
              <span class="px-2.5 py-1 bg-slate-50 border border-slate-100 rounded-lg text-xs text-slate-400 leading-none">+<%= cat[:count] - 3 %>개 더</span>
            <% end %>
          </div>

          <!-- 보러가기 버튼 -->
          <div class="mt-auto flex items-center justify-between">
            <span class="text-sm font-medium text-<%= color %>-600 group-hover:text-<%= color %>-700 transition-colors">모두 보기</span>
            <span class="material-symbols-outlined text-lg text-<%= color %>-400 group-hover:text-<%= color %>-600 transition-colors group-hover:translate-x-0.5">arrow_forward</span>
          </div>
        <% end %>
      <% end %>
    </div>
    <% end %> <%# cache %>
  </div>
</section>
