  </div>
</div>

<div id="docPopup" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-lg max-w-4xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">
    <div class="sticky top-0 bg-gradient-to-r from-amber-500 to-orange-500 text-white p-6 rounded-t-lg">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-3xl">auto_awesome</span>
          <h3 class="text-2xl font-bold">예산 편성 관련 공문·양식 자동 생성</h3>
        </div>
        <button onclick="closeDocPopup()" class="text-white hover:text-gray-200 transition-colors">
          <span class="material-symbols-outlined text-3xl">close</span>
        </button>
      </div>
      <p class="mt-2 text-amber-50">필요한 양식을 선택하면 AI가 자동으로 작성해드립니다</p>
    </div>

    <div class="p-6">
      <div id="docCategories" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
    </div>
  </div>
</div>

<script>
const docPopupData = {
  "예산요구서": [
    {title: "예산요구서", desc: "사업별 예산 신청", icon: "description", prompt: "예산요구서를 작성해줘. 사무용품 구매 사업, 2027년 예산 3천만원, 사업 필요성 및 산출 근거 포함."},
    {title: "사업계획서", desc: "예산요구 근거 자료", icon: "assignment", prompt: "사업계획서를 작성해줘. 청사 환경개선 사업, 추진 배경, 목표, 기대효과, 예산 5천만원."}
  ],
  "검토서": [
    {title: "예산 심사 의견서", desc: "재정과 심사 결과", icon: "fact_check", prompt: "예산 심사 의견서를 작성해줘. 요구액 3천만원, 심사 결과 2,500만원 조정, 조정 사유 포함."}
  ]
};

function openDocPopup(event) {
  event.preventDefault();
  const popup = document.getElementById('docPopup');
  const categoriesContainer = document.getElementById('docCategories');
  categoriesContainer.innerHTML = '';
  Object.entries(docPopupData).forEach(([category, items]) => {
    const categoryDiv = document.createElement('div');
    categoryDiv.className = 'col-span-full';
    categoryDiv.innerHTML = `<h4 class="font-bold text-lg text-gray-900 mb-3 flex items-center gap-2"><span class="material-symbols-outlined text-amber-600">folder</span>${category}</h4>`;
    const itemsGrid = document.createElement('div');
    itemsGrid.className = 'grid grid-cols-1 md:grid-cols-2 gap-3 mb-6';
    items.forEach(item => {
      const itemCard = document.createElement('a');
      itemCard.href = `/tools/official-document?prompt=${encodeURIComponent(item.prompt)}`;
      itemCard.className = 'bg-gradient-to-br from-white to-amber-50 border-2 border-amber-200 hover:border-amber-400 rounded-lg p-4 transition-all hover:shadow-lg cursor-pointer';
      itemCard.setAttribute('data-turbo', 'false');
      itemCard.innerHTML = `<div class="flex items-start gap-3"><span class="material-symbols-outlined text-amber-600 text-2xl">${item.icon}</span><div><h5 class="font-bold text-gray-900 mb-1">${item.title}</h5><p class="text-sm text-gray-600">${item.desc}</p></div></div>`;
      itemsGrid.appendChild(itemCard);
    });
    categoryDiv.appendChild(itemsGrid);
    categoriesContainer.appendChild(categoryDiv);
  });
  popup.classList.remove('hidden');
}

function closeDocPopup() {
  document.getElementById('docPopup').classList.add('hidden');
}

document.addEventListener('keydown', function(event) {
  if (event.key === 'Escape') { closeDocPopup(); }
});

document.getElementById('docPopup')?.addEventListener('click', function(event) {
  if (event.target === this) { closeDocPopup(); }
});
</script>
