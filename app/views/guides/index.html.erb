<%# 실무 가이드 목록 페이지 - 프리미엄 디자인 시스템 %>

<!-- 페이지 헤더 -->
<section class="gradient-emerald text-white py-12 lg:py-16 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/4"></div>
  <div class="container-wide relative z-10">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div class="flex items-start gap-5">
        <div class="w-16 h-16 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/20 shadow-lg">
          <span class="material-symbols-outlined text-4xl text-white">menu_book</span>
        </div>
        <div>
          <h1 class="text-2xl font-bold tracking-tight mb-2">실무 가이드</h1>
          <p class="text-sm text-white/80">공무원 업무 처리에 필요한 단계별 가이드</p>
        </div>
      </div>
      <div class="flex gap-4 lg:gap-6">
        <div class="text-center px-4 py-2 bg-white/10 backdrop-blur-md rounded-xl border border-white/15">
          <div class="text-2xl font-bold"><%= @guides.size %></div>
          <div class="text-xs text-emerald-100 mt-0.5">전체 가이드</div>
        </div>
        <div class="text-center px-4 py-2 bg-white/10 backdrop-blur-md rounded-xl border border-white/15">
          <div class="text-2xl font-bold"><%= @category_count %></div>
          <div class="text-xs text-emerald-100 mt-0.5">업무 분야</div>
        </div>
        <div class="text-center px-4 py-2 bg-white/10 backdrop-blur-md rounded-xl border border-white/15">
          <div class="text-2xl font-bold">단계별</div>
          <div class="text-xs text-emerald-100 mt-0.5">절차 안내</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 검색 및 필터 -->
<section class="bg-white/80 backdrop-blur-xl border-b border-gray-100 sticky top-16 z-40 shadow-soft">
  <div class="container-wide py-4">
    <!-- 검색바 -->
    <div class="flex items-center bg-surface-100 rounded-xl overflow-hidden mb-4">
      <div class="flex items-center justify-center pl-4 text-slate-400">
        <span class="material-symbols-outlined">search</span>
      </div>
      <input type="text" id="search-input" aria-label="가이드 검색" placeholder="가이드 검색" class="w-full border-none focus:ring-0 bg-transparent py-3 px-3 text-slate-800 placeholder:text-slate-400">
    </div>

    <!-- 카테고리 필터 -->
    <div class="flex flex-wrap gap-2" id="category-tabs">
      <button data-category="전체" class="tab-btn active px-5 py-2.5 bg-emerald-600 text-white rounded-xl text-sm font-semibold shadow-md transition-all">전체</button>
      <% @guide_categories.each do |cat| %>
        <button data-category="<%= cat %>" class="tab-btn px-5 py-2.5 bg-surface-100 text-slate-600 hover:bg-surface-200 rounded-xl text-sm font-medium transition-all"><%= cat %></button>
      <% end %>
    </div>
  </div>
</section>

<section class="section py-10">
  <div class="container-wide">
    <div class="lg:flex lg:gap-10">
      <!-- 메인 콘텐츠 -->
      <div class="lg:w-[70%]">
        <!-- 전체 카운트 + 검색 결과 카운트 -->
        <div class="flex items-center justify-between mb-6">
          <p class="text-slate-600">총 <span class="font-bold text-slate-900" id="item-count"><%= @guides.size %></span>개의 가이드</p>
        </div>

        <!-- 카드 목록 (검색·필터용 숨김 가능한 flat list) -->
        <div class="space-y-3" id="items-list" style="display:none">
          <% @guides.each do |guide| %>
            <% guide_link = guide.has_full_content? ? guide_path(guide) : (guide.external_link.present? ? guide.external_link : guide_path(guide)) %>
            <%= link_to guide_link, class: "block card card-hover p-5 group item-card", data: { category: guide.category, title: guide.title } do %>
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class="badge badge-emerald text-xs"><%= guide.category %></span>
                    <% if guide.tag.present? %>
                      <span class="badge badge-emerald text-xs"><%= guide.tag %></span>
                    <% end %>
                  </div>
                  <h3 class="text-base font-semibold text-slate-900 group-hover:text-emerald-600 transition-colors"><%= guide.title %></h3>
                  <p class="text-sm text-gray-600 mt-1 leading-relaxed"><%= guide.summary %></p>
                </div>
                <span class="material-symbols-outlined text-slate-300 group-hover:text-emerald-500 shrink-0 transition-colors">arrow_forward</span>
              </div>
            <% end %>
          <% end %>
        </div>

        <!-- 분야별 섹션 (기본 화면) -->
        <div id="category-sections">

          <%# ── 완전정복 시리즈 섹션 ── %>
          <% if @series_groups.any? %>
            <div class="mb-10">
              <!-- 섹션 헤더 -->
              <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 bg-amber-100 rounded-xl flex items-center justify-center">
                  <span class="material-symbols-outlined text-amber-600" style="font-size:20px">auto_stories</span>
                </div>
                <div>
                  <h2 class="text-lg font-bold text-gray-800">완전정복 시리즈</h2>
                  <p class="text-xs text-slate-500">핵심 주제를 편별로 나눠 마인드맵·플래시카드와 함께 완전 마스터</p>
                </div>
                <span class="text-xs font-medium text-amber-600 bg-amber-50 px-2.5 py-1 rounded-lg ml-auto"><%= @series_groups.size %>개 시리즈</span>
              </div>

              <!-- 개별 시리즈 아코디언 -->
              <% @series_groups.each_with_index do |(series_name, episodes), sidx| %>
                <% sid = "series-#{sidx}" %>
                <div class="card mb-3 overflow-hidden border border-amber-100">
                  <!-- 시리즈 헤더 (클릭으로 편 목록 펼치기) -->
                  <button type="button"
                          class="w-full flex items-center gap-3 px-5 py-4 text-left hover:bg-amber-50 transition-colors"
                          aria-expanded="false"
                          onclick="seriesToggle('<%= sid %>')">
                    <!-- 시리즈 뱃지 -->
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-amber-100 text-amber-700 text-xs font-bold rounded-lg shrink-0">
                      <span class="material-symbols-outlined" style="font-size:14px">bookmark</span>시리즈
                    </span>
                    <!-- 시리즈명 -->
                    <h3 class="flex-1 text-base font-bold text-slate-900 leading-snug"><%= series_name.tr('_', ' ') %></h3>
                    <!-- 편수 뱃지 + 랜딩 링크 + 펼치기 힌트 -->
                    <div class="flex items-center gap-2 shrink-0">
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-amber-500 text-white text-xs font-bold rounded-lg">
                        <span class="material-symbols-outlined" style="font-size:13px">format_list_numbered</span>
                        <%= episodes.size %>편
                      </span>
                      <% if (s_slug = Guide.series_slug(series_name)) %>
                        <%= link_to series_path(s_slug),
                            class: "hidden sm:inline-flex items-center gap-1 px-2.5 py-1 bg-white border border-amber-300 text-amber-700 text-xs font-semibold rounded-lg hover:bg-amber-50 transition-colors",
                            onclick: "event.stopPropagation()" do %>
                          <span class="material-symbols-outlined" style="font-size:12px">open_in_new</span>시리즈 보기
                        <% end %>
                      <% end %>
                      <span class="text-xs text-amber-600 font-medium hidden lg:block" data-series-label="<%= sid %>">눌러서 펼치기</span>
                      <span class="material-symbols-outlined text-amber-400 transition-transform duration-200"
                            data-series-chevron="<%= sid %>">expand_more</span>
                    </div>
                  </button>

                  <!-- 편 목록 (기본 접힘) -->
                  <div id="<%= sid %>" class="hidden border-t border-amber-100 bg-amber-50/40 px-5 pb-4">
                    <div class="grid sm:grid-cols-2 gap-2 pt-3">
                      <% episodes.each do |ep| %>
                        <%= link_to guide_path(ep), class: "flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-white hover:bg-amber-50 group transition-colors border border-amber-100 hover:border-amber-300 shadow-sm" do %>
                          <span class="w-7 h-7 flex items-center justify-center rounded-full bg-amber-100 text-amber-700 text-xs font-bold shrink-0 group-hover:bg-amber-500 group-hover:text-white transition-colors"><%= ep.series_order %></span>
                          <span class="text-sm text-slate-700 group-hover:text-amber-700 font-medium leading-snug">
                            <%= ep.series_episode_title %>
                          </span>
                          <span class="material-symbols-outlined text-slate-300 group-hover:text-amber-400 text-base ml-auto shrink-0">chevron_right</span>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

          <%# ── 분야별 일반 가이드 ── %>
          <%
            category_config = {
              '계약' => { icon: 'gavel',          color: 'emerald', desc: '수의계약·입찰·검수·대금지급 등 계약 전 과정' },
              '예산' => { icon: 'account_balance', color: 'blue',    desc: '예산 이월·전용·보조금 집행·정산' },
              '인사' => { icon: 'badge',           color: 'violet',  desc: '임용·승진·휴직·복직 절차' },
              '복무' => { icon: 'today',           color: 'orange',  desc: '휴가·공가·겸직허가·복무 관리' },
              '민원' => { icon: 'support_agent',   color: 'rose',    desc: '민원 응대 및 처리 절차' },
            }
            non_series_guides = @guides.reject { |g| g.series.present? }
            grouped = non_series_guides.group_by(&:category)
          %>
          <% category_config.each_with_index do |(cat, cfg), idx| %>
            <% guides_in_cat = grouped[cat] || [] %>
            <% next if guides_in_cat.empty? %>
            <% acc_id = "guide-cat-#{cat}" %>
            <div class="mb-4 card overflow-hidden">
              <!-- 분야 헤더 (클릭으로 펼치기/접기) -->
              <button type="button"
                      class="w-full flex items-center justify-between p-5 text-left"
                      aria-expanded="false"
                      onclick="guideToggle('<%= acc_id %>')">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 bg-<%= cfg[:color] %>-100 rounded-xl flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-<%= cfg[:color] %>-600" style="font-size:20px"><%= cfg[:icon] %></span>
                  </div>
                  <div>
                    <h2 class="text-base font-bold text-gray-800"><%= cat %> 가이드</h2>
                    <p class="text-xs text-slate-500"><%= cfg[:desc] %></p>
                  </div>
                </div>
                <div class="flex items-center gap-2 shrink-0 ml-3">
                  <span class="text-xs text-slate-400"><%= guides_in_cat.size %>개</span>
                  <span class="material-symbols-outlined text-slate-400 transition-transform duration-200"
                        data-guide-chevron="<%= acc_id %>">expand_more</span>
                </div>
              </button>
              <!-- 카드 그리드 (기본 접힘) -->
              <div id="<%= acc_id %>" class="hidden border-t border-slate-100 px-5 pb-5">
                <div class="grid sm:grid-cols-2 gap-3 pt-4">
                  <% guides_in_cat.each do |guide| %>
                    <% guide_link = guide.has_full_content? ? guide_path(guide) : (guide.external_link.present? ? guide.external_link : guide_path(guide)) %>
                    <%= link_to guide_link, class: "card card-hover p-4 group flex items-start gap-3" do %>
                      <div class="w-8 h-8 bg-<%= cfg[:color] %>-50 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                        <span class="material-symbols-outlined text-<%= cfg[:color] %>-500" style="font-size:18px">menu_book</span>
                      </div>
                      <div class="flex-1 min-w-0">
                        <h3 class="text-sm font-semibold text-slate-900 group-hover:text-emerald-600 transition-colors leading-snug mb-1"><%= guide.title %></h3>
                        <p class="text-xs text-slate-500 leading-relaxed line-clamp-2"><%= guide.summary %></p>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- 페이지네이션 (검색/필터 시 사용) -->
        <div class="flex justify-center mt-8" id="pagination-container" style="display:none">
          <nav class="flex items-center gap-2" id="pagination-nav"></nav>
        </div>
      </div>

      <!-- 사이드바 -->
      <div class="lg:w-[30%] mt-10 lg:mt-0">
        <div class="sticky top-36 space-y-6">
          <!-- 사전 체크리스트 배너 -->
          <%= link_to pre_contract_checklist_path, class: "block card card-interactive overflow-hidden group" do %>
            <div class="gradient-emerald p-5 text-white">
              <div class="flex items-center gap-3 mb-2">
                <span class="material-symbols-outlined text-2xl">checklist_rtl</span>
                <span class="font-bold">사전 체크리스트</span>
              </div>
              <p class="text-white/80 text-sm">계약 전 필수 확인사항을 단계별로 점검</p>
              <div class="mt-3 text-xs text-white/60 flex items-center gap-1 group-hover:text-white transition-colors">
                바로가기
                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </div>
          <% end %>

          <!-- 계약 흐름도 배너 -->
          <%= link_to contract_flow_path, class: "block card card-interactive overflow-hidden group" do %>
            <div class="gradient-slate p-5 text-white">
              <div class="flex items-center gap-3 mb-2">
                <span class="material-symbols-outlined text-2xl">account_tree</span>
                <span class="font-bold">계약 흐름도</span>
              </div>
              <p class="text-white/80 text-sm">물품/용역/공사 계약 전체 프로세스를 한눈에</p>
              <div class="mt-3 text-xs text-white/60 flex items-center gap-1 group-hover:text-white transition-colors">
                자세히 보기
                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </div>
          <% end %>

          <!-- 자료실 배너 -->
          <%= link_to guide_resources_path, class: "block card card-interactive overflow-hidden group" do %>
            <div class="gradient-indigo p-5 text-white">
              <div class="flex items-center gap-3 mb-2">
                <span class="material-symbols-outlined text-2xl">library_books</span>
                <span class="font-bold">자료실 / FAQ</span>
              </div>
              <p class="text-white/80 text-sm">판례해설, 유권해석, 자주 묻는 질문</p>
              <div class="mt-3 text-xs text-white/60 flex items-center gap-1 group-hover:text-white transition-colors">
                자세히 보기
                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </div>
          <% end %>

          <!-- 감사사례 배너 -->
          <%= link_to audit_cases_path, class: "block card card-interactive overflow-hidden group" do %>
            <div class="bg-gradient-to-br from-red-700 to-red-900 p-5 text-white">
              <div class="flex items-center gap-3 mb-2">
                <span class="material-symbols-outlined text-2xl">gavel</span>
                <span class="font-bold">감사사례 <%= @audit_case_count %>건</span>
              </div>
              <p class="text-red-100 text-sm">감사 지적 사례와 실무 체크포인트 확인</p>
              <div class="mt-3 text-xs text-white/60 flex items-center gap-1 group-hover:text-white transition-colors">
                바로가기
                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </div>
          <% end %>

          <!-- 인기 가이드 -->
          <div class="card p-6">
            <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-amber-500">local_fire_department</span>
              인기 가이드 TOP 5
            </h3>
            <ol class="space-y-3">
              <% @popular_guides.each_with_index do |guide, i| %>
                <li class="flex items-center gap-3 group">
                  <span class="w-7 h-7 flex items-center justify-center rounded-full text-xs font-bold <%= i < 3 ? 'bg-emerald-100 text-emerald-600' : 'bg-slate-100 text-slate-500' %>"><%= i + 1 %></span>
                  <%= link_to guide.title, guide_path(guide), class: "text-sm text-slate-700 group-hover:text-emerald-600 transition-colors truncate" %>
                </li>
              <% end %>
            </ol>
          </div>

          <!-- 최근 본 가이드 -->
          <div class="card p-6">
            <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-slate-400">history</span>
              최근 본 가이드
            </h3>
            <% if @recent_guides.any? %>
              <ul class="space-y-3">
                <% @recent_guides.each do |guide| %>
                  <li>
                    <%= link_to guide.title, guide_path(guide), class: "text-sm text-slate-700 hover:text-emerald-600 transition-colors truncate block" %>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-sm text-slate-400">아직 본 가이드가 없습니다.<br>가이드를 클릭하면 여기에 표시됩니다.</p>
            <% end %>
          </div>


          <!-- AI 상담 CTA -->
          <div class="gradient-emerald rounded-2xl p-6 text-white shadow-strong">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 bg-white/10 backdrop-blur rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl">support_agent</span>
              </div>
              <div>
                <h3 class="font-bold text-base">가이드가 어려우신가요?</h3>
                <p class="text-emerald-100 text-sm">AI에게 물어보세요</p>
              </div>
            </div>
            <%= link_to silmu_search_path, class: "block w-full py-3 bg-white text-emerald-700 rounded-xl font-semibold text-center hover:bg-emerald-50 transition-colors shadow-soft" do %>
              실무 검색으로 찾기
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function seriesToggle(id) {
  var panel = document.getElementById(id);
  var chevron = document.querySelector('[data-series-chevron="' + id + '"]');
  var label = document.querySelector('[data-series-label="' + id + '"]');
  var btn = chevron ? chevron.closest('button') : null;
  if (!panel) return;
  var isOpen = !panel.classList.contains('hidden');
  if (isOpen) {
    panel.classList.add('hidden');
    chevron.style.transform = '';
    if (label) label.textContent = '눌러서 펼치기';
    if (btn) btn.setAttribute('aria-expanded', 'false');
  } else {
    panel.classList.remove('hidden');
    chevron.style.transform = 'rotate(180deg)';
    if (label) label.textContent = '접기';
    if (btn) btn.setAttribute('aria-expanded', 'true');
  }
}

function guideToggle(id) {
  var panel = document.getElementById(id);
  var chevron = document.querySelector('[data-guide-chevron="' + id + '"]');
  var btn = chevron ? chevron.closest('button') : null;
  if (!panel) return;
  var isOpen = !panel.classList.contains('hidden');
  if (isOpen) {
    panel.classList.add('hidden');
    chevron.style.transform = '';
    if (btn) btn.setAttribute('aria-expanded', 'false');
  } else {
    panel.classList.remove('hidden');
    chevron.style.transform = 'rotate(180deg)';
    if (btn) btn.setAttribute('aria-expanded', 'true');
  }
}

document.addEventListener('turbo:load', function() {
  const itemCount = document.getElementById('item-count');
  if (!itemCount) return;
  const tabs = document.querySelectorAll('#category-tabs .tab-btn');
  const items = document.querySelectorAll('.item-card');
  const searchInput = document.getElementById('search-input');
  const paginationNav = document.getElementById('pagination-nav');
  const itemsList = document.getElementById('items-list');
  const categorySections = document.getElementById('category-sections');
  const paginationContainer = document.getElementById('pagination-container');

  // 검색/필터 모드 전환
  function setSearchMode(active) {
    if (active) {
      itemsList.style.display = '';
      categorySections.style.display = 'none';
      paginationContainer.style.display = '';
    } else {
      itemsList.style.display = 'none';
      categorySections.style.display = '';
      paginationContainer.style.display = 'none';
      itemCount.textContent = items.length;
    }
  }

  // 페이지네이션 설정
  const ITEMS_PER_PAGE = 6;
  let currentPage = 1;
  let filteredItems = [];

  // URL 파라미터에서 카테고리 읽기
  const urlParams = new URLSearchParams(window.location.search);
  const initialCategory = urlParams.get('category');

  // 초기 카테고리가 있으면 해당 탭 활성화
  if (initialCategory) {
    tabs.forEach(tab => {
      if (tab.dataset.category === initialCategory) {
        tabs.forEach(t => {
          t.classList.remove('active', 'bg-emerald-600', 'text-white', 'shadow-md');
          t.classList.add('bg-surface-100', 'text-slate-600');
        });
        tab.classList.add('active', 'bg-emerald-600', 'text-white', 'shadow-md');
        tab.classList.remove('bg-surface-100', 'text-slate-600');
      }
    });
  }

  function getFilteredItems() {
    const activeTab = document.querySelector('#category-tabs .tab-btn.active');
    const category = activeTab ? activeTab.dataset.category : '전체';
    const searchTerm = searchInput.value.toLowerCase();

    return Array.from(items).filter(item => {
      const itemCategory = item.dataset.category;
      const itemTitle = item.dataset.title.toLowerCase();
      const matchesCategory = category === '전체' || itemCategory === category;
      const matchesSearch = itemTitle.includes(searchTerm);
      return matchesCategory && matchesSearch;
    });
  }

  function displayPage(page) {
    currentPage = page;
    const startIndex = (page - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    // 모든 아이템 숨기기
    items.forEach(item => item.style.display = 'none');

    // 현재 페이지 아이템만 표시
    filteredItems.slice(startIndex, endIndex).forEach(item => {
      item.style.display = '';
    });

    renderPagination();
  }

  function renderPagination() {
    const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE);

    if (totalPages <= 1) {
      paginationNav.innerHTML = '';
      return;
    }

    let html = '';

    // 이전 버튼
    html += `
      <button onclick="guideGoToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}
        class="w-10 h-10 flex items-center justify-center rounded-xl ${currentPage === 1 ? 'text-slate-300 cursor-not-allowed' : 'text-slate-500 hover:bg-surface-100'} transition-colors">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
    `;

    // 페이지 번호들
    const maxVisiblePages = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
    let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);

    // startPage 조정
    if (endPage - startPage + 1 < maxVisiblePages) {
      startPage = Math.max(1, endPage - maxVisiblePages + 1);
    }

    // 첫 페이지와 ... 표시
    if (startPage > 1) {
      html += `
        <button onclick="guideGoToPage(1)" class="w-10 h-10 flex items-center justify-center rounded-xl text-slate-600 hover:bg-surface-100 font-medium transition-colors">1</button>
      `;
      if (startPage > 2) {
        html += `<span class="w-10 h-10 flex items-center justify-center text-slate-400">...</span>`;
      }
    }

    // 페이지 번호 버튼
    for (let i = startPage; i <= endPage; i++) {
      if (i === currentPage) {
        html += `
          <button class="w-10 h-10 flex items-center justify-center rounded-xl bg-emerald-600 text-white font-semibold shadow-md cursor-default">${i}</button>
        `;
      } else {
        html += `
          <button onclick="guideGoToPage(${i})" class="w-10 h-10 flex items-center justify-center rounded-xl text-slate-600 hover:bg-surface-100 font-medium transition-colors">${i}</button>
        `;
      }
    }

    // 마지막 페이지와 ... 표시
    if (endPage < totalPages) {
      if (endPage < totalPages - 1) {
        html += `<span class="w-10 h-10 flex items-center justify-center text-slate-400">...</span>`;
      }
      html += `
        <button onclick="guideGoToPage(${totalPages})" class="w-10 h-10 flex items-center justify-center rounded-xl text-slate-600 hover:bg-surface-100 font-medium transition-colors">${totalPages}</button>
      `;
    }

    // 다음 버튼
    html += `
      <button onclick="guideGoToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}
        class="w-10 h-10 flex items-center justify-center rounded-xl ${currentPage === totalPages ? 'text-slate-300 cursor-not-allowed' : 'text-slate-500 hover:bg-surface-100'} transition-colors">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    `;

    paginationNav.innerHTML = html;
  }

  // 페이지 이동 (renderPagination 내부 onclick에서 호출)
  window.guideGoToPage = function(page) {
    const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE);
    if (page < 1 || page > totalPages) return;
    displayPage(page);
    // 스크롤 이동
    document.getElementById('items-list').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  function filterAndPaginate() {
    const activeTab = document.querySelector('#category-tabs .tab-btn.active');
    const category = activeTab ? activeTab.dataset.category : '전체';
    const searchTerm = searchInput.value.trim();

    // 전체 카테고리 + 검색어 없음 → 분야별 섹션 표시
    if (category === '전체' && !searchTerm) {
      setSearchMode(false);
      return;
    }

    // 검색/필터 모드
    setSearchMode(true);
    filteredItems = getFilteredItems();
    itemCount.textContent = filteredItems.length;
    currentPage = 1;
    displayPage(1);
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', function() {
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-emerald-600', 'text-white', 'shadow-md');
        t.classList.add('bg-surface-100', 'text-slate-600');
      });
      this.classList.add('active', 'bg-emerald-600', 'text-white', 'shadow-md');
      this.classList.remove('bg-surface-100', 'text-slate-600');
      filterAndPaginate();
    });
  });

  searchInput.addEventListener('input', filterAndPaginate);

  // 초기: 분야별 섹션 표시
  setSearchMode(false);
});

// C-2 fix: Turbo 캐시 복원 시 필터 상태 초기화 (뒤로가기 시 카드 사라짐 방지)
document.addEventListener('turbo:before-cache', function() {
  const itemsList = document.getElementById('items-list');
  if (!itemsList) return;

  // 분야별 섹션 복원
  itemsList.style.display = 'none';
  const categorySections = document.getElementById('category-sections');
  if (categorySections) categorySections.style.display = '';
  const paginationContainer = document.getElementById('pagination-container');
  if (paginationContainer) paginationContainer.style.display = 'none';

  // 모든 카드 표시
  document.querySelectorAll('.item-card').forEach(function(c) { c.style.display = ''; });

  // 탭 초기화 (전체 탭 활성)
  document.querySelectorAll('#category-tabs .tab-btn').forEach(function(btn) {
    if (btn.dataset.category === '전체') {
      btn.classList.add('active', 'bg-emerald-600', 'text-white', 'shadow-md');
      btn.classList.remove('bg-surface-100', 'text-slate-600');
    } else {
      btn.classList.remove('active', 'bg-emerald-600', 'text-white', 'shadow-md');
      btn.classList.add('bg-surface-100', 'text-slate-600');
    }
  });

  // 검색어 초기화
  const searchInput = document.getElementById('search-input');
  if (searchInput) searchInput.value = '';

  // W-1 fix: 전역 함수 정리
  delete window.guideGoToPage;
});
</script>
