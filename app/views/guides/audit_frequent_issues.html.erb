<%# 감사 빈출 지적 TOP 30 가이드 %>

<section class="section py-10">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- 뒤로가기 -->
    <div class="mb-6">
      <%= link_to guides_path, class: "inline-flex items-center text-slate-600 hover:text-red-600 transition-colors font-medium" do %>
        <span class="material-symbols-outlined mr-1">arrow_back</span>
        가이드 목록으로
      <% end %>
    </div>

    <!-- 헤더 -->
    <div class="mb-10">
      <div class="flex items-center gap-4 mb-4">
        <div class="icon-container icon-container-lg gradient-rose shadow-lg">
          <span class="material-symbols-outlined text-3xl text-white">gavel</span>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-900">감사 빈출 지적 TOP 30</h1>
          <p class="text-slate-500">계약·예산·인사·보조금 분야별 가장 자주 지적되는 항목과 예방법</p>
        </div>
      </div>
      <div class="bg-red-50 border border-red-200 rounded-2xl p-5">
        <p class="text-red-800 text-sm leading-relaxed">
          <strong>출처:</strong> 감사원 「공공계약 실무가이드」, 감사원 「계약업무 길라잡이」, 지자체 계약심사사례집, 행안부 감사결과 공개 자료를 종합 정리하였습니다.
          각 항목에는 <strong>지적 근거 법령</strong>과 <strong>예방 조치</strong>가 함께 제시됩니다.
        </p>
      </div>
    </div>

    <!-- 분야 선택 탭 -->
    <div class="flex gap-2 mb-8 overflow-x-auto pb-2">
      <button onclick="showSection('all')" class="tab-btn active px-4 py-2 rounded-xl text-sm font-semibold whitespace-nowrap" data-section="all">전체 30선</button>
      <button onclick="showSection('contract')" class="tab-btn px-4 py-2 rounded-xl text-sm font-semibold whitespace-nowrap" data-section="contract">계약 분야 (13건)</button>
      <button onclick="showSection('budget')" class="tab-btn px-4 py-2 rounded-xl text-sm font-semibold whitespace-nowrap" data-section="budget">예산 분야 (8건)</button>
      <button onclick="showSection('personnel')" class="tab-btn px-4 py-2 rounded-xl text-sm font-semibold whitespace-nowrap" data-section="personnel">인사 분야 (5건)</button>
      <button onclick="showSection('subsidy')" class="tab-btn px-4 py-2 rounded-xl text-sm font-semibold whitespace-nowrap" data-section="subsidy">보조금 분야 (4건)</button>
    </div>

    <!-- 계약 분야 -->
    <div class="audit-section" data-section="contract">
      <h2 class="text-xl font-bold text-slate-900 mb-5 flex items-center gap-2">
        <span class="w-8 h-8 bg-red-100 text-red-700 rounded-lg flex items-center justify-center text-sm font-bold">계</span>
        계약 분야 빈출 지적 (13건)
      </h2>
      <div class="space-y-4 mb-10">
        <%= render "guides/audit_item", number: 1, severity: "critical", title: "수의계약 요건 미충족 체결",
            law: "국가계약법 시행령 제26조, 지방계약법 시행령 제25조",
            issue: "법령에 규정된 수의계약 사유에 해당하지 않음에도 수의계약을 체결하거나, 사유서 없이 수의계약을 진행하는 경우",
            prevention: "수의계약 전 해당 근거 조문 명시, 사유서 작성 필수. 금액 기준(물품·용역 2,000만원, 종합공사 4억원·전문공사 2억원·기타공사 1억 6천만원) 확인",
            tool_label: "수의계약 사유서 생성기", tool_path: :contract_reason_path %>

        <%= render "guides/audit_item", number: 2, severity: "critical", title: "분할계약을 통한 경쟁입찰 회피",
            law: "지방계약법 시행령 제77조, 국가계약법 시행령 제93조",
            issue: "동일 목적의 계약을 여러 건으로 분할하여 각각 수의계약 한도 이하로 처리. 특히 동일 회계연도 내 동일 업체와 반복 계약 시 지적",
            prevention: "연간 구매 계획 수립 후 통합 발주. 분할 불가피 시 계약목적의 독립성 입증 문서 구비",
            tool_label: "분할계약 판단 체크리스트", tool_path: :split_contract_checker_path %>

        <%= render "guides/audit_item", number: 3, severity: "critical", title: "예정가격 산정 부적정",
            law: "국가계약법 시행령 제7조~제9조, 지방계약법 시행령 제7조",
            issue: "복수 기초금액 미작성, 기초금액 범위 오류(±2% 범위 이탈), 원가계산 항목 누락 또는 과다 계상",
            prevention: "기초금액 15개 이상 작성(추첨형), 복수예비가격 작성 기준 준수. 예정가격 산정조서 작성",
            tool_label: "예정가격 계산기", tool_path: :estimated_price_path %>

        <%= render "guides/audit_item", number: 4, severity: "high", title: "적격심사 채점 오류",
            law: "용역·물품 적격심사기준(기재부 예규), 시설공사 적격심사기준",
            issue: "이행실적·재무상태·신용도 등 항목별 배점 오류, 신용평가등급 잘못 적용, 기간 계산 오류",
            prevention: "적격심사 기준 최신본 확인(매년 개정). 평점 산식별 계산 검증. 개찰·낙찰 결과 이중 검토",
            tool_label: "적격심사 자동채점기", tool_path: :qualification_evaluation_path %>

        <%= render "guides/audit_item", number: 5, severity: "high", title: "계약보증금 면제·징수 부적정",
            law: "국가계약법 시행규칙 제52조, 지방계약법 시행규칙 제70조",
            issue: "계약보증금 면제 대상이 아님에도 면제, 보증금 비율 잘못 적용(계약금액의 10% 이상)",
            prevention: "계약 체결 시 보증금 면제 요건 해당 여부 확인. 이행보증보험증권 금액·유효기간 검증",
            tool_label: "계약보증금 계산기", tool_path: :contract_guarantee_path %>

        <%= render "guides/audit_item", number: 6, severity: "high", title: "지체상금 미부과·과소 부과",
            law: "국가계약법 시행령 제74조·시행규칙 제75조, 지방계약법 시행령 제90조·시행규칙 제75조",
            issue: "준공 기일 이후 지체일수 계산 오류, 천재지변·발주자 귀책 등 면제 사유 없이 감면, 지체상금 부과 누락",
            prevention: "준공일 지연 즉시 지체상금 산정. 지체일수 = 준공기한 다음날~실준공일. 상한(계약금액의 10%, 지방계약법 시행규칙 §75 단서) 확인",
            tool_label: "계약보증금·지체상금 계산기", tool_path: :contract_guarantee_path %>

        <%= render "guides/audit_item", number: 7, severity: "high", title: "설계변경 계약금액 조정 부적정",
            law: "국가계약법 시행령 제65조, 지방계약법 시행령 제74조",
            issue: "물량증감 없이 단가만 변경하는 방식으로 계약금액 증액, 간접비 재계산 누락, 설계변경 근거 부족",
            prevention: "설계변경 요인 발생 즉시 기록. 물량·단가 각각 산출 후 합산. 관련 근거자료 일체 구비",
            tool_label: "설계변경 계산기", tool_path: :design_change_path %>

        <%= render "guides/audit_item", number: 8, severity: "medium", title: "물가변동(ESC) 계약금액 조정 부적정",
            law: "국가계약법 시행령 제64조, 지방계약법 시행령 제73조",
            issue: "조정 기준일(계약체결일 또는 직전 조정 기준일)로부터 90일 이상 경과 요건 미충족, 조정률 계산 오류",
            prevention: "조정 기준일 체크(90일 이상, 등락률 ±3% 이상). 지수조정률/품목조정률 방식 선택 후 산식 준수",
            tool_label: "물가변동 조정 계산기", tool_path: :price_adjustment_calculator_path %>

        <%= render "guides/audit_item", number: 9, severity: "medium", title: "2인 이상 견적 징구 의무 위반",
            law: "지방계약법 시행령 제25조 제2항, 국가계약법 시행령 제26조 제2항",
            issue: "2,000만원 이하 수의계약에서 1인 견적만 징구하거나, 견적서 미징구 후 구두 수의",
            prevention: "반드시 2인 이상 견적 징구. 견적서 원본 보관. 정당한 이유 있는 경우만 1인 견적 가능(미상당, 독점 공급 등)",
            tool_label: nil, tool_path: nil %>

        <%= render "guides/audit_item", number: 10, severity: "medium", title: "낙찰자 결정 후 계약 체결 지연",
            law: "국가계약법 시행령 제47조, 지방계약법 시행령 제58조",
            issue: "낙찰 통보 후 10일 이내(수의계약 5일) 계약 체결 의무 미준수",
            prevention: "낙찰 통보 즉시 계약 체결 일정 수립. 지연 불가피 시 사유서 작성", tool_label: nil, tool_path: nil %>

        <%= render "guides/audit_item", number: 11, severity: "medium", title: "검수·검사 부실 또는 생략",
            law: "국가계약법 시행령 제55조~제57조, 지방계약법 시행령 제66조",
            issue: "납품 확인 없이 대금 지급, 검수조서 미작성, 검사·검수 담당자 지정 없이 처리",
            prevention: "납품 즉시 검수 실시 후 검수조서 작성. 담당자 사전 지정 및 전결 처리",
            tool_label: "기성검사 체크리스트", tool_path: :progress_inspection_path %>

        <%= render "guides/audit_item", number: 12, severity: "medium", title: "하도급 관련 의무 위반",
            law: "건설산업기본법 제29조, 하도급거래공정화법 제13조",
            issue: "하도급 미통보, 하도급 대금 직접지급 의무 위반, 하도급 비율 초과",
            prevention: "수급인이 하도급 계약 시 발주자에게 통보 의무 이행 확인. 직접지급 요건 발생 시 즉시 처리",
            tool_label: nil, tool_path: nil %>

        <%= render "guides/audit_item", number: 13, severity: "medium", title: "계약 관련 서류 미비치·미보존",
            law: "국가계약법 시행규칙 제82조, 지방계약법 시행규칙 제106조",
            issue: "입찰·계약 관련 서류 보존기간(5년) 미준수, 전자 문서 백업 미비, 서류 분실",
            prevention: "계약 완료 후 관련 서류 일체 편철. 전자조달 시스템 데이터 백업 확인",
            tool_label: nil, tool_path: nil %>
      </div>
    </div>

    <!-- 예산 분야 -->
    <div class="audit-section" data-section="budget">
      <h2 class="text-xl font-bold text-slate-900 mb-5 flex items-center gap-2">
        <span class="w-8 h-8 bg-amber-100 text-amber-700 rounded-lg flex items-center justify-center text-sm font-bold">예</span>
        예산 분야 빈출 지적 (8건)
      </h2>
      <div class="space-y-4 mb-10">
        <%= render "guides/audit_item", number: 14, severity: "critical", title: "예산 목적 외 사용",
            law: "지방재정법 제47조, 국가재정법 제45조",
            issue: "예산으로 정한 목적 이외의 경비 지출. 예산 과목 잘못 적용으로 실질적 목적 외 사용",
            prevention: "지출 전 예산 과목 적정성 검토. 목적 외 사용 의심 시 법무·예산 부서 유권해석 요청",
            tool_label: "예산 과목 분류 도우미", tool_path: :budget_category_finder_path %>

        <%= render "guides/audit_item", number: 15, severity: "critical", title: "예산 전용 부적정",
            law: "지방재정법 제49조, 국가재정법 제46조",
            issue: "의회 승인 없이 법정 한도 초과 전용, 인건비에서 물건비로 전용 등 금지된 전용",
            prevention: "전용 전 법령상 요건 확인. 인건비 전용 금지 원칙 준수. 의회 의결이 필요한 경우 사전 처리",
            tool_label: "이월·전용 적법성 판단기", tool_path: :budget_transfer_checker_path %>

        <%= render "guides/audit_item", number: 16, severity: "high", title: "사고이월 요건 미충족 이월",
            law: "지방재정법 제48조, 국가재정법 제48조",
            issue: "사고이월 요건(공사 착수 후 불가피한 사유, 법령 규정 지출 의무 부담 등) 미충족에도 이월 처리",
            prevention: "이월 전 적법 요건 충족 여부 검토. 사고이월 사유서 구체적으로 작성. 의회 승인 필요 여부 확인",
            tool_label: "이월·전용 적법성 판단기", tool_path: :budget_transfer_checker_path %>

        <%= render "guides/audit_item", number: 17, severity: "high", title: "예비비 사용 부적정",
            law: "지방재정법 제43조, 국가재정법 제22조",
            issue: "예비비 사용 요건(예측불가한 예산 부족) 미충족, 법정 편성 한도(1%) 초과",
            prevention: "예비비 사용 전 행정안전부 지침 확인. 사용 사유의 예측불가성 소명 문서 작성",
            tool_label: "예비비 한도 계산기", tool_path: :contingency_fund_path %>

        <%= render "guides/audit_item", number: 18, severity: "high", title: "집행잔액 과다 발생(불용)",
            law: "지방재정법 제82조 (결산 및 보고)",
            issue: "연말 예산집행률 저조, 사업 지연으로 인한 과다 불용, 연도 내 집행 계획 없이 예산 편성",
            prevention: "분기별 집행률 모니터링. 집행 부진 사업 원인 분석 후 계획 재수립 또는 감액 처리",
            tool_label: "예산 집행률 계산기", tool_path: :budget_execution_rate_path %>

        <%= render "guides/audit_item", number: 19, severity: "medium", title: "업무추진비 집행 부적정",
            law: "지방자치단체 예산편성 운영기준 제3장",
            issue: "건당 한도 초과, 영수증 불비, 적격 집행 대상·용도 위반, 월간 한도 초과",
            prevention: "직위별·유형별 1건당·월간 한도 숙지. 집행 후 24시간 이내 영수증 수취. 카드 집행 원칙",
            tool_label: nil, tool_path: nil %>

        <%= render "guides/audit_item", number: 20, severity: "medium", title: "세입 징수 누락 또는 지연",
            law: "지방세징수법, 지방재정법 제34조",
            issue: "각종 사용료·수수료·과징금 등 세입 미징수, 납부 기한 경과 후 방치, 소멸시효 완성",
            prevention: "연간 세입 징수 계획 수립. 체납 현황 정기 점검. 소멸시효(5년) 임박 채권 우선 처리",
            tool_label: nil, tool_path: nil %>

        <%= render "guides/audit_item", number: 21, severity: "medium", title: "세출예산 과목 오류 편성",
            law: "지방자치단체 예산편성 운영기준",
            issue: "물건비를 자본지출로 편성하거나, 이전경비를 물건비로 편성하는 등 성질별 과목 오류",
            prevention: "행안부 예산편성 운영기준 과목 해설 참조. 새로운 지출 항목은 사전에 예산 부서와 협의",
            tool_label: "예산 과목 분류 도우미", tool_path: :budget_category_finder_path %>
      </div>
    </div>

    <!-- 인사 분야 -->
    <div class="audit-section" data-section="personnel">
      <h2 class="text-xl font-bold text-slate-900 mb-5 flex items-center gap-2">
        <span class="w-8 h-8 bg-blue-100 text-blue-700 rounded-lg flex items-center justify-center text-sm font-bold">인</span>
        인사 분야 빈출 지적 (5건)
      </h2>
      <div class="space-y-4 mb-10">
        <%= render "guides/audit_item", number: 22, severity: "high", title: "수당 지급 요건 미충족",
            law: "공무원수당 등에 관한 규정",
            issue: "가족수당 지급 대상 오류(부양 여부 미확인), 정근수당 지급률 오계산, 특수업무수당 비대상자 지급",
            prevention: "수당 지급 전 해당 수당의 지급 요건·대상·금액 법령 확인. 가족수당은 매년 부양 사실 재확인",
            tool_label: "수당 계산기", tool_path: :allowance_calculator_path %>

        <%= render "guides/audit_item", number: 23, severity: "high", title: "인사위원회 미개최 또는 절차 위반",
            law: "지방공무원법 제7조, 경찰공무원법 제9조",
            issue: "승진 임용 시 인사위원회 심의 생략, 위원 구성 요건 미충족, 회의록 미작성",
            prevention: "인사위원회 심의 대상 사항 사전 점검. 위원 수·구성 기준 충족 여부 확인. 회의록 작성 필수",
            tool_label: nil, tool_path: nil %>

        <%= render "guides/audit_item", number: 24, severity: "medium", title: "휴직·복직 처리 부적정",
            law: "지방공무원법 제63조~제65조",
            issue: "휴직 사유 소멸 후 복직 명령 지연, 휴직 기간 중 직무 수행, 휴직 중 보수 과다 지급",
            prevention: "휴직 만료일 사전 알림 시스템 구축. 복직 명령 절차 즉시 처리. 휴직 유형별 보수 지급률 확인",
            tool_label: nil, tool_path: nil %>

        <%= render "guides/audit_item", number: 25, severity: "medium", title: "기간제·임기제 임용 부적정",
            law: "지방공무원법 제25조의2, 공무원임용령",
            issue: "임용 기간 초과, 자격 요건 미충족자 임용, 공개경쟁 절차 없이 특정인 임용",
            prevention: "임기제 임용 요건(전문성·업무 한시성) 충족 여부 사전 검토. 임용 계획 수립 시 법무 협의",
            tool_label: nil, tool_path: nil %>

        <%= render "guides/audit_item", number: 26, severity: "medium", title: "복무 규정 위반 (연가·병가 등)",
            law: "국가공무원 복무규정, 지방공무원 복무규정",
            issue: "연가 부여일수 오류, 병가 급여 지급률 잘못 적용, 출장 처리 기준 위반",
            prevention: "재직기간별 연가일수 정확 산정. 병가 유형(일반·공무상)별 급여 지급률 확인",
            tool_label: "연가일수 계산기", tool_path: :annual_leave_calculator_path %>
      </div>
    </div>

    <!-- 보조금 분야 -->
    <div class="audit-section" data-section="subsidy">
      <h2 class="text-xl font-bold text-slate-900 mb-5 flex items-center gap-2">
        <span class="w-8 h-8 bg-green-100 text-green-700 rounded-lg flex items-center justify-center text-sm font-bold">보</span>
        보조금 분야 빈출 지적 (4건)
      </h2>
      <div class="space-y-4 mb-10">
        <%= render "guides/audit_item", number: 27, severity: "critical", title: "보조금 목적 외 사용",
            law: "보조금 관리에 관한 법률 제22조, 지방보조금 관리기준",
            issue: "교부 목적이 아닌 용도로 보조금 집행, 보조금으로 인건비 충당(허용된 경우 제외)",
            prevention: "집행 전 교부결정서 사업계획과 일치 여부 확인. 목적 외 사용 의심 시 교부기관에 사전 문의",
            tool_label: "보조금 정산 체크리스트", tool_path: :subsidy_settlement_checker_path %>

        <%= render "guides/audit_item", number: 28, severity: "critical", title: "자부담 미확보 또는 과소 집행",
            law: "지방보조금 관리기준 제15조",
            issue: "교부결정서상 자부담 비율 미충족, 타 보조금을 자부담으로 전용",
            prevention: "자부담 집행 계획 사전 수립. 자부담 증빙(별도 계좌 구분 관리 권장) 철저히 구비",
            tool_label: "보조금 정산 체크리스트", tool_path: :subsidy_settlement_checker_path %>

        <%= render "guides/audit_item", number: 29, severity: "high", title: "보조금 정산 부적정·지연",
            law: "보조금법 제30조 (사업 종료 후 2개월 이내 정산)",
            issue: "정산보고서 허위 작성, 증빙서류 미비, 정산 보고 기한 초과",
            prevention: "사업 종료 즉시 정산 준비. 집행내역서·증빙서류 사전 정리. e나라도움 제출 기한 알림 설정",
            tool_label: "보조금 정산 체크리스트", tool_path: :subsidy_settlement_checker_path %>

        <%= render "guides/audit_item", number: 30, severity: "high", title: "집행잔액 반납 의무 미이행",
            law: "보조금법 제31조, 지방보조금 관리기준",
            issue: "사업 완료 후 잔액 반납 미이행, 반납 기한(정산 확인 후 30일) 초과",
            prevention: "정산 완료 후 잔액 즉시 반납. 이자까지 포함하여 반납(국고보조금의 경우)",
            tool_label: "보조금 정산 체크리스트", tool_path: :subsidy_settlement_checker_path %>
      </div>
    </div>

    <!-- 관련 도구 -->
    <div class="card p-6 bg-gradient-to-r from-slate-50 to-blue-50 border border-slate-200">
      <h2 class="text-base font-bold text-slate-900 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-blue-600">build</span>
        감사 대비 실무 도구
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <%= link_to audit_readiness_checker_path, class: "p-3 bg-white rounded-xl border border-slate-200 hover:border-blue-300 hover:shadow-sm transition-all" do %>
          <span class="material-symbols-outlined text-blue-500 text-lg block mb-1">shield</span>
          <span class="text-xs font-semibold text-slate-700">부서별 감사 대비<br>체크리스트</span>
        <% end %>
        <%= link_to subsidy_settlement_checker_path, class: "p-3 bg-white rounded-xl border border-slate-200 hover:border-indigo-300 hover:shadow-sm transition-all" do %>
          <span class="material-symbols-outlined text-indigo-500 text-lg block mb-1">fact_check</span>
          <span class="text-xs font-semibold text-slate-700">보조금 정산<br>체크리스트</span>
        <% end %>
        <%= link_to contract_legality_check_path, class: "p-3 bg-white rounded-xl border border-slate-200 hover:border-red-300 hover:shadow-sm transition-all" do %>
          <span class="material-symbols-outlined text-red-500 text-lg block mb-1">gavel</span>
          <span class="text-xs font-semibold text-slate-700">계약 적법성<br>자가진단</span>
        <% end %>
        <%= link_to split_contract_checker_path, class: "p-3 bg-white rounded-xl border border-slate-200 hover:border-rose-300 hover:shadow-sm transition-all" do %>
          <span class="material-symbols-outlined text-rose-500 text-lg block mb-1">rule</span>
          <span class="text-xs font-semibold text-slate-700">분할계약<br>판단 체크리스트</span>
        <% end %>
        <%= link_to budget_transfer_checker_path, class: "p-3 bg-white rounded-xl border border-slate-200 hover:border-amber-300 hover:shadow-sm transition-all" do %>
          <span class="material-symbols-outlined text-amber-500 text-lg block mb-1">swap_horiz</span>
          <span class="text-xs font-semibold text-slate-700">이월·전용<br>적법성 판단기</span>
        <% end %>
        <%= link_to budget_category_finder_path, class: "p-3 bg-white rounded-xl border border-slate-200 hover:border-emerald-300 hover:shadow-sm transition-all" do %>
          <span class="material-symbols-outlined text-emerald-500 text-lg block mb-1">category</span>
          <span class="text-xs font-semibold text-slate-700">예산 과목<br>분류 도우미</span>
        <% end %>
      </div>
    </div>
  </div>
</section>

<style>
  .tab-btn { background: #f1f5f9; color: #475569; transition: all 0.2s; }
  .tab-btn:hover { background: #fee2e2; color: #b91c1c; }
  .tab-btn.active { background: #dc2626; color: white; }
</style>

<script>
  function showSection(section) {
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    document.querySelector(`[data-section="${section}"]`).classList.add('active');

    document.querySelectorAll('.audit-section').forEach(el => {
      if (section === 'all' || el.dataset.section === section) {
        el.style.display = 'block';
      } else {
        el.style.display = 'none';
      }
    });
  }
</script>
