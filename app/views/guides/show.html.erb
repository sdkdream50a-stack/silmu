<%# 가이드 상세 페이지 - 동적 렌더링 %>

<% content_for :head do %>
  <%= json_ld({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": @guide.title,
    "description": @guide.description,
    "inLanguage": "ko",
    "image": "https://silmu.kr/og-image.png",
    "datePublished": (@guide.published_on&.iso8601 || @guide.created_at.iso8601),
    "dateModified": @guide.updated_at.iso8601,
    "author": { "@type": "Organization", "name": "실무.kr", "url": "https://silmu.kr" },
    "step": (@guide.sections ? [
      @guide.sections[:step1],
      @guide.sections[:step2],
      @guide.sections[:step3],
      @guide.sections[:step4]
    ].compact.each_with_index.map { |step, i|
      { "@type": "HowToStep", "position": i + 1, "name": step[:title], "text": Array(step[:items]).join(". ") }
    } : [])
  }) %>
  <%= json_ld({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "홈", "item": "https://silmu.kr" },
      { "@type": "ListItem", "position": 2, "name": "실무가이드", "item": "https://silmu.kr/guides" },
      { "@type": "ListItem", "position": 3, "name": @guide.title, "item": "https://silmu.kr#{guide_path(@guide)}" }
    ]
  }) %>
  <%# FAQPage JSON-LD: flashcards(앞/뒤) → FAQ 스키마 — AEO/GEO 최적화 %>
  <% faq_items = @guide.rich_media&.dig(:flashcards).presence %>
  <% if faq_items.present? %>
    <%= json_ld({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq_items.map { |fc|
        {
          "@type": "Question",
          "name": fc[:front],
          "acceptedAnswer": { "@type": "Answer", "text": fc[:back] }
        }
      }
    }) %>
  <% end %>
<% end %>

<section class="py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- 뒤로가기 -->
    <div class="mb-6">
      <%= link_to guides_path, class: "inline-flex items-center text-gray-600 hover:text-emerald-600 transition-colors" do %>
        <span class="material-symbols-outlined mr-1">arrow_back</span>
        가이드 목록으로
      <% end %>
    </div>

    <%# ── 시리즈 진행 배너 ── %>
    <% if @series_guides.present? %>
    <div class="mb-6 bg-gradient-to-r from-emerald-50 to-teal-50 border border-emerald-200 rounded-2xl px-5 py-4">
      <div class="flex items-center justify-between flex-wrap gap-3">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-emerald-600">menu_book</span>
          <span class="text-sm font-bold text-emerald-800"><%= @guide.series %></span>
          <span class="text-xs text-emerald-600 bg-emerald-100 px-2 py-0.5 rounded-full font-medium">
            <%= @series_guides.size %>편 시리즈
          </span>
        </div>
        <div class="flex items-center gap-1 overflow-x-auto max-w-full">
          <% @series_guides.each_with_index do |sg, i| %>
            <% is_current = sg.id == @guide.id %>
            <%= link_to guide_path(sg),
                  class: "shrink-0 flex items-center justify-center w-7 h-7 rounded-full text-xs font-bold transition-colors
                    #{is_current ? 'bg-emerald-600 text-white ring-2 ring-emerald-400 ring-offset-1' : 'bg-white border border-emerald-200 text-emerald-600 hover:bg-emerald-100'}" do %>
              <%= i + 1 %>
            <% end %>
          <% end %>
        </div>
      </div>
      <p class="mt-2 text-xs text-emerald-700">
        현재 <strong><%= @guide.series_order %>편</strong>을 읽고 있습니다.
        <% if @next_guide %>
          다음: <%= link_to @next_guide.title.truncate(30), guide_path(@next_guide), class: "underline hover:text-emerald-900 font-medium" %>
        <% end %>
      </p>
    </div>
    <% end %>

    <div class="lg:flex lg:gap-8">
      <!-- 목차 사이드바 (왼쪽) -->
      <div class="hidden lg:block lg:w-[250px] shrink-0">
        <div class="sticky top-24 bg-white rounded-xl border border-gray-200 p-6">
          <%# 시리즈 사이드바 목록 %>
          <% if @series_guides.present? %>
          <div class="mb-5 pb-5 border-b border-gray-100">
            <h3 class="font-bold text-gray-900 mb-3 flex items-center gap-1.5 text-sm">
              <span class="material-symbols-outlined text-emerald-500 text-base">menu_book</span>
              시리즈 전편
            </h3>
            <nav class="space-y-1 text-xs">
              <% @series_guides.each_with_index do |sg, i| %>
                <% is_current = sg.id == @guide.id %>
                <%= link_to guide_path(sg),
                      class: "flex items-center gap-2 py-1.5 px-2 rounded-lg transition-colors
                        #{is_current ? 'bg-emerald-50 text-emerald-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
                  <span class="shrink-0 w-5 h-5 flex items-center justify-center rounded-full text-xs font-bold
                    <%= is_current ? 'bg-emerald-600 text-white' : 'bg-gray-100 text-gray-500' %>">
                    <%= i + 1 %>
                  </span>
                  <span class="truncate"><%= sg.title.gsub(/^.*?완전정복\s*\d*편?\s*[—\-:]?\s*/, '') %></span>
                <% end %>
              <% end %>
            </nav>
          </div>
          <% end %>
          <h3 class="font-bold text-gray-900 mb-4">목차</h3>
          <nav class="space-y-2 text-sm">
            <% toc_num = 1 %>
            <a href="#overview" class="block py-2 px-3 bg-emerald-50 text-emerald-600 rounded-lg font-medium"><%= toc_num %>. 개요</a>
            <% toc_num += 1 %>
            <% if @guide.sections&.dig(:requirements)&.any? %>
              <a href="#requirements" class="block py-2 px-3 text-gray-600 hover:bg-gray-50 rounded-lg transition-colors"><%= toc_num %>. 사전 준비 사항</a>
              <% toc_num += 1 %>
            <% end %>
            <% [:step1, :step2, :step3, :step4].each_with_index do |step_key, i| %>
              <% if @guide.sections&.dig(step_key)&.dig(:title).present? %>
                <a href="#<%= step_key %>" class="block py-2 px-3 text-gray-600 hover:bg-gray-50 rounded-lg transition-colors"><%= toc_num %>. Step <%= i + 1 %>: <%= @guide.sections[step_key][:title] %></a>
                <% toc_num += 1 %>
              <% end %>
            <% end %>
            <% if @guide.sections&.dig(:cautions)&.any? %>
              <a href="#cautions" class="block py-2 px-3 text-gray-600 hover:bg-gray-50 rounded-lg transition-colors"><%= toc_num %>. 주의사항</a>
              <% toc_num += 1 %>
            <% end %>
            <% if @guide.sections&.dig(:laws)&.any? %>
              <a href="#related" class="block py-2 px-3 text-gray-600 hover:bg-gray-50 rounded-lg transition-colors"><%= toc_num %>. 관련 법령</a>
            <% end %>
          </nav>
        </div>
      </div>

      <!-- 메인 콘텐츠 -->
      <div class="flex-1 min-w-0">
        <article class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <!-- 헤더 -->
          <div class="p-6 md:p-8 border-b">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xs font-semibold px-3 py-1 bg-<%= @guide.category_color %>-100 text-<%= @guide.category_color %>-600 rounded-full"><%= @guide.category %></span>
              <% if @guide.badge.present? %>
                <span class="text-xs font-semibold px-3 py-1 bg-amber-100 text-amber-600 rounded-full"><%= @guide.badge %></span>
              <% end %>
            </div>
            <h1 class="text-xl md:text-2xl font-bold text-gray-900 mb-4"><%= @guide.title %></h1>
            <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-lg">calendar_today</span>
                <%= @guide.published_on&.strftime("%Y.%m.%d") %>
              </span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-lg">visibility</span>
                <%= @guide.view_count %>회
              </span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-lg">person</span>
                <%= @guide.author %>
              </span>
            </div>

            <div class="flex gap-2 mt-6">
              <button onclick="if(navigator.share){navigator.share({title:document.title,url:location.href})}else{navigator.clipboard.writeText(location.href);this.querySelector('.label').textContent='복사됨!';setTimeout(()=>{this.querySelector('.label').textContent='공유'},1500)}" class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors">
                <span class="material-symbols-outlined text-lg">share</span>
                <span class="label">공유</span>
              </button>
              <button onclick="window.print()" class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors">
                <span class="material-symbols-outlined text-lg">print</span>
                인쇄
              </button>
              <%= bookmark_button(@guide) %>
            </div>
          </div>

          <!-- 법령 전문 연결 (상단 인라인 배너) -->
          <% if @related_topic.present? %>
          <div class="px-6 md:px-8 py-3 bg-indigo-50 border-b border-indigo-100 flex items-center justify-between gap-4 flex-wrap">
            <div class="flex items-center gap-2 text-sm text-indigo-700">
              <span class="material-symbols-outlined text-base">balance</span>
              <span>이 가이드의 법령 근거: <strong><%= @related_topic.name %></strong></span>
            </div>
            <%= link_to topic_path(@related_topic.slug), class: "inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 hover:text-indigo-800 whitespace-nowrap transition-colors" do %>
              법령 전문 보기
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            <% end %>
          </div>
          <% end %>

          <!-- 본문 -->
          <% cache [@guide, "body", @guide.updated_at.to_i] do %>
          <% sec_num = 1 %>
          <div class="p-6 md:p-8 prose-premium">

            <!-- 핵심 요약 박스 -->
            <div class="guide-meta-box">
              <div class="bg-emerald-500 px-5 py-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-white text-base">summarize</span>
                <span class="text-white text-sm font-semibold">이 가이드 핵심 요약</span>
              </div>
              <div class="bg-white px-5 py-4 grid sm:grid-cols-3 gap-4 text-sm">
                <div>
                  <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-1">카테고리</p>
                  <p class="text-slate-700"><%= @guide.category %></p>
                </div>
                <div class="sm:col-span-2">
                  <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-1">한 줄 요약</p>
                  <p class="text-slate-700"><%= @guide.description.to_s.truncate(120) %></p>
                </div>
                <% if @guide.sections&.dig(:requirements)&.any? %>
                <div class="sm:col-span-3 border-t border-emerald-100 pt-3 mt-1">
                  <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wide mb-2">사전 준비</p>
                  <ul class="flex flex-wrap gap-2">
                    <% @guide.sections[:requirements].each do |req| %>
                      <li class="inline-flex items-center gap-1 px-2.5 py-1 bg-emerald-50 text-emerald-700 rounded-full text-xs font-medium">
                        <span class="material-symbols-outlined text-xs">check</span>
                        <%= req[:title] %>
                      </li>
                    <% end %>
                  </ul>
                </div>
                <% end %>
              </div>
            </div>

            <%# ── Hook: 시나리오 도입부 ── %>
            <% if @guide.sections&.dig(:hook).present? %>
            <div class="mb-8 bg-gradient-to-r from-amber-50 to-yellow-50 border-l-4 border-amber-400 rounded-r-2xl p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-amber-500">lightbulb</span>
                <span class="text-sm font-bold text-amber-800">이런 상황, 낯설지 않으신가요?</span>
              </div>
              <p class="text-slate-700 leading-relaxed text-sm whitespace-pre-line"><%= @guide.sections[:hook] %></p>
            </div>
            <% end %>

            <%# ── Why It Matters ── %>
            <% if @guide.sections&.dig(:why_it_matters).present? %>
            <div class="mb-8 bg-red-50 border border-red-200 rounded-2xl p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-red-500">error</span>
                <span class="text-sm font-bold text-red-800">왜 반드시 알아야 하나요?</span>
              </div>
              <p class="text-slate-700 leading-relaxed text-sm whitespace-pre-line"><%= @guide.sections[:why_it_matters] %></p>
            </div>
            <% end %>

            <section id="overview" class="mb-12">
              <h2 class="text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 flex items-center justify-center bg-emerald-500 text-white rounded-lg text-sm font-bold"><%= sec_num %></span>
                개요
              </h2>
              <% sec_num += 1 %>
              <p class="text-gray-700 leading-relaxed">
                <%= @guide.description %>
              </p>
            </section>

            <% if @guide.sections&.dig(:requirements)&.any? %>
            <section id="requirements" class="mb-12">
              <h2 class="text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 flex items-center justify-center bg-emerald-500 text-white rounded-lg text-sm font-bold"><%= sec_num %></span>
                사전 준비 사항
              </h2>
              <% sec_num += 1 %>
              <ul class="space-y-3 text-gray-700">
                <% @guide.sections[:requirements].each do |req| %>
                  <li class="flex gap-3 bg-slate-50 rounded-lg p-3 hover:bg-emerald-50 transition-colors">
                    <span class="material-symbols-outlined text-emerald-500 shrink-0">check_circle</span>
                    <p><strong class="text-slate-800"><%= req[:title] %>:</strong> <span class="text-slate-600"><%= req[:desc] %></span></p>
                  </li>
                <% end %>
              </ul>
            </section>
            <% end %>

            <% [:step1, :step2, :step3, :step4].each_with_index do |step_key, index| %>
              <% step = @guide.sections&.dig(step_key) %>
              <% next if step.blank? %>
              <section id="<%= step_key %>" class="mb-12">
                <h2 class="text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <span class="w-8 h-8 flex items-center justify-center bg-emerald-500 text-white rounded-lg text-sm font-bold"><%= sec_num %></span>
                  <% sec_num += 1 %>
                  Step <%= index + 1 %>: <%= step[:title] %>
                </h2>
                <% if step[:body].present? %>
                  <p class="text-slate-700 leading-relaxed text-sm whitespace-pre-line bg-slate-50 rounded-xl p-4"><%= step[:body] %></p>
                <% end %>
                <% if step[:items].present? %>
                <ol class="space-y-3 text-gray-700">
                  <% step[:items].each_with_index do |item, i| %>
                    <li class="flex gap-3 bg-slate-50 rounded-lg p-3 hover:bg-blue-50 transition-colors">
                      <span class="w-6 h-6 flex items-center justify-center bg-emerald-500 text-white rounded-full text-xs font-bold shrink-0 mt-0.5"><%= i + 1 %></span>
                      <p class="text-slate-700"><%= item %></p>
                    </li>
                  <% end %>
                </ol>
                <% end %>
              </section>
            <% end %>

            <% if @guide.sections&.dig(:cautions)&.any? %>
            <section id="cautions" class="mb-12">
              <h2 class="text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 flex items-center justify-center bg-amber-500 text-white rounded-lg text-sm font-bold">!</span>
                주의사항
              </h2>
              <div class="guide-alert-box">
                <ul class="space-y-3 text-amber-800">
                  <% @guide.sections[:cautions].each do |caution| %>
                    <li class="flex gap-2">
                      <span class="material-symbols-outlined text-amber-600 shrink-0 text-base mt-0.5">warning</span>
                      <p class="text-sm leading-relaxed"><%= caution %></p>
                    </li>
                  <% end %>
                </ul>
              </div>
            </section>
            <% end %>

            <%# ── 실제 감사 지적 사례 ── %>
            <% if @guide.sections&.dig(:real_case).present? %>
            <section class="mb-10">
              <div class="bg-orange-50 border border-orange-200 rounded-2xl overflow-hidden">
                <div class="bg-orange-100 px-5 py-3 flex items-center gap-2 border-b border-orange-200">
                  <span class="material-symbols-outlined text-orange-600">gavel</span>
                  <span class="text-sm font-bold text-orange-800">실제 감사 지적 사례</span>
                </div>
                <div class="p-5">
                  <p class="text-slate-700 text-sm leading-relaxed whitespace-pre-line"><%= @guide.sections[:real_case] %></p>
                </div>
              </div>
            </section>
            <% end %>

            <%# ── 선배 꿀팁 ── %>
            <% if @guide.sections&.dig(:tip_box).present? %>
            <section class="mb-10">
              <div class="bg-blue-50 border border-blue-200 rounded-2xl overflow-hidden">
                <div class="bg-blue-100 px-5 py-3 flex items-center gap-2 border-b border-blue-200">
                  <span class="material-symbols-outlined text-blue-600">record_voice_over</span>
                  <span class="text-sm font-bold text-blue-800">선배가 알려주는 꿀팁</span>
                </div>
                <div class="p-5">
                  <p class="text-slate-700 text-sm leading-relaxed whitespace-pre-line"><%= @guide.sections[:tip_box] %></p>
                </div>
              </div>
            </section>
            <% end %>

            <%# ── 오늘 당장 해야 할 것 ── %>
            <% if @guide.sections&.dig(:today_checklist)&.any? %>
            <section class="mb-10">
              <div class="bg-emerald-50 border border-emerald-200 rounded-2xl overflow-hidden">
                <div class="bg-emerald-100 px-5 py-3 flex items-center gap-2 border-b border-emerald-200">
                  <span class="material-symbols-outlined text-emerald-700">checklist</span>
                  <span class="text-sm font-bold text-emerald-800">오늘 당장 해야 할 것</span>
                </div>
                <div class="p-5">
                  <ul class="space-y-3">
                    <% @guide.sections[:today_checklist].each do |item| %>
                      <li class="flex items-start gap-3 text-sm text-slate-700">
                        <span class="w-5 h-5 border-2 border-emerald-400 rounded mt-0.5 flex-shrink-0"></span>
                        <%= item %>
                      </li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </section>
            <% end %>

            <% if @guide.sections&.dig(:laws)&.any? %>
            <section id="related" class="mb-12">
              <h2 class="text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 flex items-center justify-center bg-blue-500 text-white rounded-lg text-sm font-bold">
                  <span class="material-symbols-outlined text-sm">balance</span>
                </span>
                관련 법령
              </h2>
              <div class="bg-blue-50 rounded-xl p-6">
                <ul class="space-y-3 text-sm">
                  <% @guide.sections[:laws].each do |law| %>
                    <li>
                      <% if law.is_a?(Hash)
                           law_name = law[:name] || law[:label]
                           law_text = law[:text]
                         end %>
                      <% if law.is_a?(Hash) && law[:url] %>
                        <a href="<%= law[:url] %>" target="_blank" class="text-blue-600 hover:underline flex items-center gap-1">
                          <%= law_name %>
                          <span class="material-symbols-outlined text-xs">open_in_new</span>
                        </a>
                        <% if law_text.present? %>
                          <p class="text-gray-500 text-xs mt-0.5 ml-0"><%= law_text %></p>
                        <% end %>
                      <% elsif law.is_a?(Hash) %>
                        <span class="font-medium text-gray-800"><%= law_name %></span>
                        <% if law_text.present? %>
                          <p class="text-gray-500 text-xs mt-0.5"><%= law_text %></p>
                        <% end %>
                      <% else %>
                        <span class="text-gray-600"><%= law %></span>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </div>
            </section>
            <% end %>
          </div>
          <% end %>
        </article>

        <%# ═══ Rich Media 섹션 (rich_media JSONB) ═══ %>
        <% rm = @guide.rich_media&.with_indifferent_access %>
        <% if rm.present? %>

          <%# ── 1. AI 오디오 (NotebookLM 오버뷰) ── %>
          <% if rm[:audio_url].present? %>
          <section class="mt-8" data-controller="guide-audio" data-guide-audio-url-value="<%= rm[:audio_url] %>">
            <audio data-guide-audio-target="audio" preload="metadata" class="hidden"></audio>
            <div class="bg-gradient-to-r from-teal-50 to-emerald-50 border border-teal-200 rounded-2xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 bg-teal-100 rounded-xl flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined text-teal-600">headphones</span>
                </div>
                <div>
                  <p class="text-xs font-semibold text-teal-600 uppercase tracking-wide">AI 오디오 요약</p>
                  <p class="text-sm font-bold text-slate-800">들으면서 이해하기 — NotebookLM 생성</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <button data-action="click->guide-audio#togglePlay"
                        data-guide-audio-target="playBtn"
                        class="w-11 h-11 rounded-full bg-emerald-600 hover:bg-emerald-700 flex items-center justify-center text-white transition-colors shrink-0">
                  <span class="material-symbols-outlined text-xl" data-guide-audio-target="playIcon">play_arrow</span>
                </button>
                <div class="flex-1">
                  <div class="relative h-2 bg-teal-100 rounded-full cursor-pointer"
                       data-action="click->guide-audio#seek">
                    <div class="absolute left-0 top-0 h-2 bg-emerald-500 rounded-full transition-all"
                         data-guide-audio-target="progressBar" style="width:0%"></div>
                  </div>
                  <div class="flex justify-between text-xs text-slate-400 mt-1">
                    <span data-guide-audio-target="currentTime">0:00</span>
                    <span data-guide-audio-target="duration">--:--</span>
                  </div>
                </div>
                <button data-action="click->guide-audio#changeSpeed"
                        data-guide-audio-target="speed"
                        class="text-xs font-bold text-teal-600 bg-teal-100 hover:bg-teal-200 px-2.5 py-1.5 rounded-lg transition-colors">
                  1×
                </button>
              </div>
            </div>
          </section>
          <% end %>

          <%# ── 2. 인포그래픽 ── %>
          <% if rm[:infographic_url].present? %>
          <section class="mt-8">
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
              <div class="px-5 py-3 border-b bg-slate-50 flex items-center gap-2">
                <span class="material-symbols-outlined text-violet-500">bar_chart</span>
                <span class="text-sm font-bold text-slate-700">한눈에 보는 인포그래픽</span>
              </div>
              <div class="p-4">
                <%= image_tag rm[:infographic_url],
                      alt: "#{@guide.title} 인포그래픽",
                      class: "w-full rounded-xl object-contain max-h-[600px]",
                      loading: "lazy" %>
              </div>
            </div>
          </section>
          <% end %>

          <%# ── 3. 플로우차트 (Mermaid flowchart — 마인드맵보다 명확) ── %>
          <% if rm[:flowchart].present? %>
          <section class="mt-8" data-controller="mermaid">
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
              <div class="px-5 py-3 border-b bg-blue-50 flex items-center gap-2">
                <span class="material-symbols-outlined text-blue-500">account_tree</span>
                <span class="text-sm font-bold text-slate-700">단계별 흐름도</span>
              </div>
              <div class="p-4 overflow-x-auto">
                <pre data-mermaid-target="source" class="text-xs"><%= rm[:flowchart] %></pre>
              </div>
            </div>
          </section>
          <% end %>

          <%# ── 마인드맵 (flowchart 없을 때만 표시) ── %>
          <% if rm[:mindmap].present? && rm[:flowchart].blank? %>
          <section class="mt-8" data-controller="mermaid">
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
              <div class="px-5 py-3 border-b bg-slate-50 flex items-center gap-2">
                <span class="material-symbols-outlined text-blue-500">account_tree</span>
                <span class="text-sm font-bold text-slate-700">전체 구조 파악</span>
              </div>
              <div class="p-4 overflow-x-auto">
                <pre data-mermaid-target="source" class="text-xs"><%= rm[:mindmap] %></pre>
              </div>
            </div>
          </section>
          <% end %>

          <%# ── 4. 벤다이어그램 (Mermaid block / venn SVG) ── %>
          <% if rm[:venn].present? %>
          <section class="mt-8" data-controller="mermaid">
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
              <div class="px-5 py-3 border-b bg-slate-50 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-500">donut_large</span>
                <span class="text-sm font-bold text-slate-700">벤다이어그램으로 개념 비교</span>
              </div>
              <div class="p-4 overflow-x-auto">
                <pre data-mermaid-target="source" class="text-xs"><%= rm[:venn] %></pre>
              </div>
            </div>
          </section>
          <% end %>

          <%# ── 5. 4단 만화 (Gemini 생성) ── %>
          <% if rm[:comic_images].present? && rm[:comic_images].any? %>
          <section class="mt-8" data-controller="guide-comic">
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
              <div class="px-5 py-3 border-b bg-amber-50 border-amber-100 flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-500">auto_stories</span>
                <span class="text-sm font-bold text-slate-700">4컷 만화로 핵심 이해</span>
                <span class="text-xs text-amber-600 bg-amber-100 px-2 py-0.5 rounded-full ml-auto">클릭하면 확대</span>
              </div>
              <div class="p-4 grid grid-cols-2 gap-3">
                <% rm[:comic_images].first(4).each_with_index do |img_url, i| %>
                <div class="relative cursor-pointer rounded-xl overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow group"
                     data-action="click->guide-comic#open"
                     data-guide-comic-target="panel">
                  <%= image_tag img_url,
                        alt: "#{@guide.title} 4컷만화 #{i+1}편",
                        class: "w-full object-cover aspect-square group-hover:scale-105 transition-transform duration-200",
                        loading: "lazy" %>
                  <div class="absolute top-2 left-2 w-6 h-6 bg-amber-500 text-white text-xs font-bold rounded-full flex items-center justify-center shadow">
                    <%= i + 1 %>
                  </div>
                </div>
                <% end %>
              </div>
            </div>
            <%# 라이트박스 오버레이 %>
            <div data-guide-comic-target="overlay"
                 data-action="click->guide-comic#closeOnBackdrop"
                 class="hidden fixed inset-0 z-50 bg-black/80 flex items-center justify-center p-4">
              <button data-action="click->guide-comic#close"
                      class="absolute top-4 right-4 text-white bg-white/20 hover:bg-white/40 rounded-full w-10 h-10 flex items-center justify-center transition-colors">
                <span class="material-symbols-outlined">close</span>
              </button>
              <img data-guide-comic-target="overlayImg" src="" alt="만화 확대"
                   class="max-w-full max-h-[90vh] rounded-2xl shadow-2xl object-contain">
            </div>
          </section>
          <% end %>

          <%# ── 6. 플래시카드 ── %>
          <% if rm[:flashcards].present? && rm[:flashcards].any? %>
          <section class="mt-8"
                   data-controller="guide-flashcard"
                   data-guide-flashcard-cards-value="<%= rm[:flashcards].to_json %>">
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
              <div class="px-5 py-3 border-b bg-emerald-50 border-emerald-100 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-emerald-500">style</span>
                  <span class="text-sm font-bold text-slate-700">핵심 용어 플래시카드</span>
                  <span class="text-xs text-emerald-600 bg-emerald-100 px-2 py-0.5 rounded-full"><%= rm[:flashcards].size %>개</span>
                </div>
                <span class="text-xs text-slate-400" data-guide-flashcard-target="counter"></span>
              </div>
              <div class="p-4">
                <%# 진행 바 %>
                <div class="h-1.5 bg-gray-100 rounded-full mb-5">
                  <div class="h-1.5 bg-emerald-500 rounded-full transition-all duration-300"
                       data-guide-flashcard-target="progress" style="width:0%"></div>
                </div>
                <%# 카드 영역 %>
                <div data-card-area class="relative" style="perspective: 1000px;">
                  <div class="relative w-full cursor-pointer transition-transform duration-500"
                       style="transform-style: preserve-3d; min-height: 180px;"
                       data-guide-flashcard-target="card"
                       data-action="click->guide-flashcard#flip">
                    <%# 앞면 %>
                    <div class="absolute inset-0 flex items-center justify-center p-6 bg-gradient-to-br from-emerald-50 to-teal-50 rounded-xl border border-emerald-100"
                         style="backface-visibility: hidden;">
                      <p class="text-base font-bold text-slate-800 text-center" data-guide-flashcard-target="front"></p>
                    </div>
                    <%# 뒷면 %>
                    <div class="absolute inset-0 flex items-center justify-center p-6 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl border border-blue-100"
                         style="backface-visibility: hidden; transform: rotateY(180deg);">
                      <p class="text-sm text-slate-700 text-center leading-relaxed" data-guide-flashcard-target="back"></p>
                    </div>
                  </div>
                  <p class="mt-3 text-xs text-center text-slate-400">카드를 클릭하면 정답이 보여요</p>
                  <%# 알았어/다시 버튼 %>
                  <div class="flex gap-3 mt-4">
                    <button data-action="click->guide-flashcard#again"
                            class="flex-1 py-2.5 bg-red-50 hover:bg-red-100 border border-red-200 text-red-600 rounded-xl text-sm font-semibold transition-colors flex items-center justify-center gap-1">
                      <span class="material-symbols-outlined text-base">refresh</span> 다시
                    </button>
                    <button data-action="click->guide-flashcard#knew"
                            class="flex-1 py-2.5 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 text-emerald-700 rounded-xl text-sm font-semibold transition-colors flex items-center justify-center gap-1">
                      <span class="material-symbols-outlined text-base">check</span> 알았어
                    </button>
                  </div>
                </div>
                <%# 완료 결과 %>
                <div data-guide-flashcard-target="result" class="hidden text-center py-8">
                  <span class="material-symbols-outlined text-4xl text-emerald-500 block mb-2">workspace_premium</span>
                  <p class="text-lg font-bold text-slate-800 mb-1">완주!</p>
                  <p class="text-sm text-slate-500 mb-1">정답률 <strong data-score class="text-emerald-600"></strong></p>
                  <p class="text-xs text-slate-400 mb-4">(<span data-count></span> 정답)</p>
                  <button data-action="click->guide-flashcard#restart"
                          class="px-6 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-sm font-semibold transition-colors">
                    다시 풀기
                  </button>
                </div>
              </div>
            </div>
          </section>
          <% end %>

        <% end %>
        <%# ═══ /Rich Media 섹션 ═══ %>

        <!-- 법령 근거 연결 카드 (2단계: Guide → Topic 연결) -->
        <% if @related_topic.present? %>
        <section class="mt-8">
          <div class="bg-gradient-to-r from-indigo-50 to-violet-50 border border-indigo-100 rounded-2xl p-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-indigo-600 text-2xl">library_books</span>
              </div>
              <div class="flex-1">
                <p class="text-xs font-semibold text-indigo-500 uppercase tracking-wider mb-1">법령 근거</p>
                <h3 class="font-bold text-base text-slate-900 mb-1"><%= @related_topic.name %> — 법령·시행령·규칙 전문</h3>
                <p class="text-sm text-slate-600 mb-4"><%= @related_topic.summary.to_s.truncate(100) %></p>
                <div class="flex flex-wrap gap-2">
                  <% if @related_topic.law_content.present? %>
                    <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 bg-white border border-indigo-200 text-indigo-700 rounded-lg font-medium">
                      <span class="material-symbols-outlined text-sm">balance</span> 법률 조항
                    </span>
                  <% end %>
                  <% if @related_topic.decree_content.present? %>
                    <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 bg-white border border-violet-200 text-violet-700 rounded-lg font-medium">
                      <span class="material-symbols-outlined text-sm">policy</span> 시행령
                    </span>
                  <% end %>
                  <% if @related_topic.rule_content.present? %>
                    <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 bg-white border border-blue-200 text-blue-700 rounded-lg font-medium">
                      <span class="material-symbols-outlined text-sm">rule</span> 시행규칙·기준
                    </span>
                  <% end %>
                </div>
              </div>
              <%= link_to topic_path(@related_topic.slug), class: "shrink-0 flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors self-center" do %>
                법령 전문 보기
                <span class="material-symbols-outlined text-lg">arrow_forward</span>
              <% end %>
            </div>
          </div>
        </section>
        <% end %>

        <%# ── 시리즈 이전/다음 편 네비게이션 ── %>
        <% if @series_guides.present? && (@prev_guide || @next_guide) %>
        <section class="mt-8">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <% if @prev_guide %>
                <%= link_to guide_path(@prev_guide),
                      class: "group flex flex-col gap-1 p-4 bg-white border border-gray-200 rounded-xl hover:border-emerald-300 hover:shadow-md transition-all h-full" do %>
                  <span class="text-xs text-gray-400 flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                    이전 편
                  </span>
                  <span class="text-sm font-semibold text-gray-800 group-hover:text-emerald-700 leading-snug line-clamp-2 transition-colors">
                    <%= @prev_guide.title %>
                  </span>
                <% end %>
              <% end %>
            </div>
            <div>
              <% if @next_guide %>
                <%= link_to guide_path(@next_guide),
                      class: "group flex flex-col gap-1 p-4 bg-white border border-gray-200 rounded-xl hover:border-emerald-300 hover:shadow-md transition-all h-full text-right" do %>
                  <span class="text-xs text-gray-400 flex items-center justify-end gap-1">
                    다음 편
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </span>
                  <span class="text-sm font-semibold text-gray-800 group-hover:text-emerald-700 leading-snug line-clamp-2 transition-colors">
                    <%= @next_guide.title %>
                  </span>
                <% end %>
              <% end %>
            </div>
          </div>
          <div class="mt-3 text-center">
            <%= link_to guides_path(category: @guide.series),
                  class: "text-xs text-emerald-600 hover:text-emerald-800 underline transition-colors" do %>
              <%= @guide.series %> 전편 보기
            <% end %>
          </div>
        </section>
        <% end %>

        <!-- 추천 가이드 -->
        <section class="mt-12">
          <h2 class="text-lg font-bold text-gray-900 mb-6">관련 가이드</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <% @related_guides.each do |related| %>
              <% related_link = related.has_full_content? ? guide_path(related) : (related.external_link.present? ? related.external_link : guide_path(related)) %>
              <%= link_to related_link, class: "bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg transition-shadow" do %>
                <span class="text-xs font-semibold px-2 py-1 bg-<%= related.category_color %>-100 text-<%= related.category_color %>-600 rounded-full"><%= related.category %></span>
                <h3 class="text-base font-semibold text-gray-900 mt-3 mb-2"><%= related.title %></h3>
                <p class="text-gray-500 text-sm"><%= related.summary.to_s.truncate(50) %></p>
              <% end %>
            <% end %>
          </div>
        </section>
      </div>
    </div>
  </div>
</section>

<%= render 'shared/recent_items',
      title: @guide.title,
      url: guide_path(@guide),
      type: 'guide' %>
