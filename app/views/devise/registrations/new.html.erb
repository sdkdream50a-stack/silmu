<%# 회원가입 페이지 - 프리미엄 디자인 시스템 %>

<div class="min-h-screen bg-surface-50 flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full">
    <!-- 로고 -->
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-flex items-center gap-3" do %>
        <svg width="48" height="48" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="drop-shadow-md">
          <defs>
            <linearGradient id="logo_grad_reg" gradientUnits="userSpaceOnUse" x1="20" y1="20" x2="180" y2="180">
              <stop stop-color="#137fec"/>
              <stop offset="1" stop-color="#0ea5e9"/>
            </linearGradient>
          </defs>
          <path d="M100 20C60 20 40 45 40 45V140C40 165 70 180 100 180C130 180 160 165 160 140V45C160 45 140 20 100 20Z" fill="url(#logo_grad_reg)"/>
          <path d="M85 70H115" stroke="white" stroke-linecap="round" stroke-opacity="0.9" stroke-width="8"/>
          <path d="M70 100H130" stroke="white" stroke-linecap="round" stroke-opacity="0.9" stroke-width="8"/>
          <path d="M85 130H115" stroke="white" stroke-linecap="round" stroke-opacity="0.9" stroke-width="8"/>
          <circle cx="100" cy="50" fill="white" fill-opacity="0.9" r="6"/>
        </svg>
        <span class="text-2xl font-bold text-slate-900">실무</span>
      <% end %>
    </div>

    <!-- 회원가입 카드 -->
    <div class="card p-8 shadow-strong">
      <h2 class="text-2xl font-bold text-slate-900 text-center mb-2">회원가입</h2>
      <p class="text-slate-500 text-center mb-8">실무와 함께 더 나은 업무 환경을 만들어보세요</p>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, "이메일", class: "block text-sm font-semibold text-slate-700 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "이메일 주소", class: "input" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-semibold text-slate-700 mb-2" do %>
            비밀번호
            <% if @minimum_password_length %>
              <span class="font-normal text-slate-400 ml-1">(<%= @minimum_password_length %>자 이상)</span>
            <% end %>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "input" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "비밀번호 확인", class: "block text-sm font-semibold text-slate-700 mb-2" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", class: "input" %>
        </div>

        <!-- 이용약관 동의 -->
        <div class="space-y-3">
          <label class="flex items-start cursor-pointer group">
            <input type="checkbox" required class="text-indigo-600 focus:ring-indigo-500 rounded w-4 h-4 mt-0.5">
            <span class="ml-2 text-sm text-slate-600">
              <%= link_to "이용약관", terms_path, target: "_blank", class: "text-indigo-600 hover:underline" %> 및
              <%= link_to "개인정보처리방침", privacy_path, target: "_blank", class: "text-indigo-600 hover:underline" %>에 동의합니다 (필수)
            </span>
          </label>
          <label class="flex items-start cursor-pointer group">
            <%= f.check_box :newsletter_agreed, class: "text-indigo-600 focus:ring-indigo-500 rounded w-4 h-4 mt-0.5" %>
            <span class="ml-2 text-sm text-slate-600">유용한 업무 팁과 새로운 기능 소식을 받아보시겠습니까? (선택)</span>
          </label>
        </div>

        <div>
          <%= f.submit "회원가입", class: "w-full btn btn-primary btn-lg cursor-pointer" %>
        </div>
      <% end %>

      <!-- 소셜 로그인 구분선 -->
      <div class="mt-6 relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-slate-200"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="bg-white px-3 text-slate-500">또는 소셜 계정으로 가입</span>
        </div>
      </div>

      <!-- 소셜 로그인 버튼 -->
      <div class="mt-4 space-y-3">
        <%= link_to user_kakao_omniauth_authorize_path,
            data: { turbo: false },
            class: "flex items-center justify-center gap-3 w-full py-2.5 px-4 bg-yellow-400 rounded-lg text-gray-900 font-semibold text-sm hover:bg-yellow-500 transition-colors" do %>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="12" cy="11" rx="10" ry="9" fill="#3C1E1E"/>
            <path d="M12 5C8.13 5 5 7.46 5 10.5c0 1.9 1.13 3.57 2.85 4.6l-.73 2.7a.3.3 0 0 0 .45.33L10.6 16.4c.45.07.92.1 1.4.1 3.87 0 7-2.46 7-5.5S15.87 5 12 5Z" fill="#FFE812"/>
          </svg>
          카카오로 시작하기
        <% end %>

        <%= link_to user_naver_omniauth_authorize_path,
            data: { turbo: false },
            class: "flex items-center justify-center gap-3 w-full py-2.5 px-4 bg-[#03C75A] rounded-lg text-white font-semibold text-sm hover:bg-[#02b350] transition-colors" do %>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M16.273 12.845L7.376 0H0v24h7.727V11.155L16.624 24H24V0h-7.727z" fill="white"/>
          </svg>
          네이버로 시작하기
        <% end %>
      </div>

      <!-- 로그인 링크 -->
      <p class="mt-8 text-center text-sm text-slate-600">
        이미 계정이 있으신가요?
        <%= link_to "로그인", new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-700 font-semibold ml-1 transition-colors" %>
      </p>
    </div>
  </div>
</div>
