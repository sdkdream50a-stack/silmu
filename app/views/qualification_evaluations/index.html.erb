<%# Created: 2026-02-22, Updated: 2026-03-05 (종심제 지원 추가) %>
<div class="max-w-5xl mx-auto" data-controller="qualification-evaluation">
  <!-- 헤더 -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="iconify w-10 h-10 text-forest-600" data-icon="mdi:clipboard-check-outline"></span>
      <h1 class="text-3xl font-bold text-gray-900">적격심사·종심제 자동 채점기</h1>
    </div>
    <p class="text-lg text-gray-600">
      공사·용역 입찰의 적격심사(300억 미만)와 종합심사낙찰제(300억 이상) 점수를 자동으로 계산합니다
    </p>
    <%= render 'shared/use_when_badge', tool: 'qualification-evaluation' %>
  </div>

  <!-- 모드 탭 + 설명 -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5 mb-6">
    <!-- 모드 탭 -->
    <div class="flex gap-2 mb-5">
      <button type="button"
              data-action="click->qualification-evaluation#switchMode"
              data-mode="qualification"
              data-qualification-evaluation-target="modeTab"
              class="flex-1 py-3 px-4 text-sm font-bold rounded-lg bg-forest-600 text-white cursor-pointer transition-colors">
        ✅ 적격심사
        <span class="block text-xs font-normal mt-0.5 opacity-80">추정가격 300억 미만</span>
      </button>
      <button type="button"
              data-action="click->qualification-evaluation#switchMode"
              data-mode="comprehensive"
              data-qualification-evaluation-target="modeTab"
              class="flex-1 py-3 px-4 text-sm font-bold rounded-lg bg-gray-100 text-gray-600 cursor-pointer transition-colors hover:bg-gray-200">
        📊 종합심사낙찰제(종심제)
        <span class="block text-xs font-normal mt-0.5">추정가격 300억 이상 공사</span>
      </button>
    </div>

    <!-- 적격심사 설명 -->
    <div data-qualification-evaluation-target="qualificationInfo">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
        <div class="bg-blue-50 p-4 rounded-lg">
          <h3 class="font-bold text-blue-900 mb-2">🏗️ 공사</h3>
          <ul class="text-sm text-blue-800 space-y-1">
            <li>• 가격점수: 60점 / 비가격점수: 40점</li>
            <li>• 낙찰하한율: 89.745%</li>
            <li>• 적격 기준: <strong>95점 이상</strong></li>
          </ul>
        </div>
        <div class="bg-indigo-50 p-4 rounded-lg">
          <h3 class="font-bold text-indigo-900 mb-2">💼 용역</h3>
          <ul class="text-sm text-indigo-800 space-y-1">
            <li>• 가격점수: 70점 / 비가격점수: 30점</li>
            <li>• 낙찰하한율: 없음</li>
            <li>• 적격 기준: <strong>95점 이상</strong></li>
          </ul>
        </div>
      </div>
      <p class="text-xs text-gray-500">근거: 지방계약법 시행령 제42조 (재정지출의 부담이 되는 입찰에서의 낙찰자 결정) + 행정안전부 예규 「지방자치단체 입찰 및 계약 집행기준」 — 적격자 중 최저가 낙찰</p>
    </div>

    <!-- 종심제 설명 -->
    <div data-qualification-evaluation-target="comprehensiveInfo" class="hidden">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-3">
        <% @comprehensive_structure.each_with_index do |(key, info), idx| %>
          <div class="<%= idx == 0 ? 'bg-blue-50' : 'bg-purple-50' %> p-3 rounded-lg text-center">
            <div class="text-xl font-bold <%= idx == 0 ? 'text-blue-900' : 'text-purple-900' %>"><%= info[:max] %>점</div>
            <div class="text-xs font-bold <%= idx == 0 ? 'text-blue-800' : 'text-purple-800' %> mt-0.5"><%= info[:name] %></div>
            <div class="text-xs <%= idx == 0 ? 'text-blue-600' : 'text-purple-600' %> mt-1 leading-tight"><%= info[:desc] %></div>
          </div>
        <% end %>
      </div>
      <div class="bg-amber-50 border-l-4 border-amber-400 p-3 rounded text-xs text-amber-800">
        <strong>적용 대상:</strong> 추정가격 300억원 이상 공사 (지방계약법 시행령 제42조의3 — 지자체에 가장 유리하게 입찰한 자에 대한 낙찰자 결정) &nbsp;|&nbsp;
        <strong>적격 기준:</strong> 총점 92점 이상인 업체 중 최고점 낙찰
      </div>
    </div>
  </div>

  <!-- 입력 폼 -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
    <%= form_with url: qualification_evaluations_evaluate_path, method: :post, local: false,
          data: { action: "submit->qualification-evaluation#submit" } do |f| %>

      <!-- 1. 사업 기본 정보 -->
      <div class="mb-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">1. 사업 기본 정보</h3>

        <!-- 300억 임계값 감지 배너 -->
        <div data-qualification-evaluation-target="priceBanner"
             class="hidden mb-4 p-3 bg-purple-50 border border-purple-200 rounded-lg text-sm text-purple-800 flex items-center gap-3">
          <span>📊 <strong>300억 이상</strong> — 종합심사낙찰제(종심제) 적용 대상입니다.</span>
          <button type="button"
                  data-action="click->qualification-evaluation#switchModeToComprehensive"
                  class="ml-auto px-3 py-1 bg-purple-600 text-white rounded text-xs font-bold hover:bg-purple-700 whitespace-nowrap flex-shrink-0">
            종심제로 전환
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- 사업 종류 (적격심사만 표시) -->
          <div data-qualification-evaluation-target="projectTypeSection">
            <label class="block text-sm font-medium text-gray-700 mb-2">사업 종류</label>
            <%= select_tag :project_type,
                options_for_select([
                  ["공사 (가격 60점 / 비가격 40점)", "construction"],
                  ["용역 (가격 70점 / 비가격 30점)", "service"]
                ], "construction"),
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-500 focus:border-transparent",
                data: { action: "change->qualification-evaluation#updateScoreStructure" }
            %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">예정가격 (원)</label>
            <%= number_field_tag :estimated_price, nil,
                placeholder: "예: 500000000",
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-500 focus:border-transparent",
                data: { action: "input->qualification-evaluation#checkThreshold" }
            %>
          </div>

          <div data-qualification-evaluation-target="floorRateContainer">
            <label class="block text-sm font-medium text-gray-700 mb-2">낙찰하한율 (%)</label>
            <%= number_field_tag :floor_rate, 89.745,
                step: 0.001,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-500 focus:border-transparent"
            %>
            <p class="text-xs text-gray-500 mt-1" data-qualification-evaluation-target="floorRateNote">공사: 89.745% (2026년 1월 변경)</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">입찰 업체 수</label>
            <%= number_field_tag :bidder_count, 3,
                min: 1, max: 10,
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-forest-500 focus:border-transparent",
                data: { action: "change->qualification-evaluation#updateBidderFields" }
            %>
          </div>
        </div>
      </div>

      <!-- 2. 입찰 업체 정보 -->
      <div class="mb-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">2. 입찰 업체 정보</h3>
        <div data-qualification-evaluation-target="bidderFields">
          <!-- Stimulus controller가 동적으로 생성 -->
        </div>
      </div>

      <!-- 제출 버튼 -->
      <div class="flex justify-end">
        <%= button_tag type: :submit,
            class: "bg-forest-600 hover:bg-forest-700 text-white font-bold py-3 px-8 rounded-lg transition-colors duration-200",
            data: { qualification_evaluation_target: "submitBtn" } do %>
          <span class="flex items-center gap-2">
            <span class="iconify" data-icon="mdi:calculator"></span>
            <span data-qualification-evaluation-target="submitBtnText">적격심사 계산하기</span>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- 결과 표시 영역 -->
  <div class="hidden" data-qualification-evaluation-target="result">
    <!-- 결과가 여기에 표시됩니다 -->
  </div>

  <!-- 법령 근거 -->
  <div class="bg-gray-50 rounded-lg border border-gray-200 p-6 mt-8">
    <h3 class="text-lg font-bold text-gray-900 mb-4">📖 법령 근거</h3>
    <div class="space-y-3 text-sm text-gray-700">
      <div>
        <strong class="text-forest-600">적격심사 (추정가격 2억 이상 ~ 300억 미만)</strong>
        <p class="mt-1">지방계약법 시행령 제42조 + 행안부 예규 「지방자치단체 입찰 및 계약 집행기준」: 가격(60~70점) + 비가격(30~40점) 종합평가, 95점 이상 업체 중 최저가 낙찰 (시행령 §42의2는 2022년 삭제)</p>
      </div>
      <div>
        <strong class="text-forest-600">종합심사낙찰제 (추정가격 300억 이상 공사)</strong>
        <p class="mt-1">지방계약법 시행령 제42조의3 (지자체에 가장 유리하게 입찰한 자에 대한 낙찰자 결정): 가격50 + 시공실적20 + 시공능력15 + 경영상태10 + 사회적책임5 = 100점, 92점 이상 업체 중 최고점 낙찰</p>
      </div>
    </div>
  </div>

  <!-- 면책 조항 -->
  <div class="mt-6 p-4 bg-red-50 border-l-4 border-red-500 rounded">
    <p class="text-sm text-red-900">
      <strong>⚠️ 법적 책임 안내</strong><br>
      본 도구는 일반적인 적격심사·종심제 계산 방법을 구현한 것으로, 참고용으로만 사용하시기 바랍니다.
      실제 입찰의 평가는 기관별 세부 기준, 평가항목, 배점 방식이 다를 수 있으므로 반드시 해당 입찰공고문과 심사기준표를 확인하시고, 담당 부서의 검토를 받으시기 바랍니다.
    </p>
  </div>
</div>
