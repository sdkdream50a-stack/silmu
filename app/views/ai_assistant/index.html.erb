<%# AI 실무 어시스턴트 페이지 %>

<section class="gradient-premium text-white py-12 lg:py-16">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <div class="w-16 h-16 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/20 shadow-lg mx-auto mb-4">
      <span class="material-symbols-outlined text-4xl text-white">psychology</span>
    </div>
    <h1 class="text-3xl font-bold mb-2 text-white">AI 실무 어시스턴트</h1>
    <p class="text-slate-200">법령을 근거로 공무원 계약·예산 실무 질문에 답변합니다</p>
    <% if @topic %>
      <div class="mt-3 inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 rounded-full text-sm text-white/80">
        <span class="material-symbols-outlined text-sm">gavel</span>
        「<%= @topic.name %>」 관련 법령 컨텍스트 적용 중
      </div>
    <% end %>
  </div>
</section>

<section class="max-w-3xl mx-auto px-4 py-10">
  <div class="card p-6 shadow-strong"
       data-controller="ai-chat"
       data-ai-chat-topic-slug-value="<%= @topic&.slug.to_s %>"
       data-ai-chat-session-id-value="<%= session.id.to_s %>">

    <!-- 대화 영역 -->
    <div data-ai-chat-target="messages"
         class="min-h-[300px] max-h-[500px] overflow-y-auto space-y-4 mb-6 pr-1">
      <div class="flex gap-3">
        <div class="w-8 h-8 rounded-full bg-indigo-600 flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-white text-base">psychology</span>
        </div>
        <div class="bg-indigo-50 rounded-2xl rounded-tl-none px-4 py-3 max-w-prose">
          <p class="text-sm text-slate-700">
            안녕하세요! 계약·예산 실무에 관한 질문을 입력해주세요.<br/>
            법령을 근거로 정확하게 답변해드리겠습니다.
            <% if @topic %>
              「<%= @topic.name %>」 관련 법령을 참고하여 답변합니다.
            <% end %>
          </p>
        </div>
      </div>
    </div>

    <!-- 로딩 인디케이터 -->
    <div data-ai-chat-target="loading" class="hidden flex gap-3 mb-4">
      <div class="w-8 h-8 rounded-full bg-indigo-600 flex items-center justify-center flex-shrink-0">
        <span class="material-symbols-outlined text-white text-base animate-spin">refresh</span>
      </div>
      <div class="bg-indigo-50 rounded-2xl rounded-tl-none px-4 py-3">
        <p class="text-sm text-slate-500">답변 작성 중...</p>
      </div>
    </div>

    <!-- 입력 폼 -->
    <div class="flex gap-3 mt-2">
      <input data-ai-chat-target="input"
             type="text"
             placeholder="질문을 입력하세요 (예: 수의계약 한도는 얼마인가요?)"
             class="input flex-1"
             maxlength="500" />
      <button data-action="click->ai-chat#send"
              data-ai-chat-target="submit"
              class="btn btn-primary shrink-0">
        <span class="material-symbols-outlined">send</span>
        질문
      </button>
    </div>

    <!-- 남은 횟수 -->
    <p data-ai-chat-target="remaining"
       class="text-xs text-slate-400 mt-2 text-right">
    </p>

    <!-- 예시 질문 -->
    <div class="mt-5 pt-4 border-t border-slate-100">
      <p class="text-xs text-slate-400 mb-3 font-medium">예시 질문</p>
      <div class="flex flex-wrap gap-2">
        <% [
          "수의계약 한도 금액은 얼마인가요?",
          "예비비 사용 절차를 알려주세요",
          "국내 출장비 지급 기준이 어떻게 되나요?",
          "선금 지급 비율은 몇 %인가요?"
        ].each do |q| %>
          <button data-action="click->ai-chat#setQuestion"
                  data-question="<%= q %>"
                  class="px-3 py-1.5 bg-slate-100 text-slate-600 text-xs rounded-full hover:bg-indigo-100 hover:text-indigo-700 transition-colors">
            <%= q %>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <p class="text-xs text-slate-400 text-center mt-4">
    ⚠️ AI 답변은 참고용입니다. 중요한 사항은 반드시 담당 기관이나 법무 부서에 확인하세요.
    <% if !current_user %>
      · 비로그인 시 하루 <%= AiAssistantService::DAILY_LIMIT_GUEST %>회까지 이용 가능
      (<%= link_to "로그인", new_user_session_path, class: "text-indigo-600 hover:underline" %>하면 <%= AiAssistantService::DAILY_LIMIT_USER %>회)
    <% end %>
  </p>
</section>
