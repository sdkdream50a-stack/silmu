<%= turbo_frame_tag "search-results" do %>
  <div class="max-w-4xl mx-auto px-4 mt-6">
    <% if @query.present? %>

      <%# 결과 없음 %>
      <% no_results = @topics.blank? && @audit_cases.blank? && @templates.blank? %>
      <% if no_results %>
        <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center">
          <span class="material-symbols-outlined text-slate-300 text-5xl">search_off</span>
          <h3 class="text-base font-semibold text-slate-700 mt-3 mb-1">"<%= @query %>" 검색 결과가 없습니다</h3>
          <p class="text-slate-400 text-sm mb-5">다른 키워드로 검색하거나 아래 항목을 확인해보세요</p>
          <div class="flex flex-wrap gap-2 justify-center">
            <% ["수의계약", "적격심사", "입찰", "검수", "예산"].each do |kw| %>
              <button onclick="document.querySelector('[name=q]').value='<%= kw %>'; document.querySelector('[name=q]').closest('form').requestSubmit();"
                      class="px-3 py-1.5 bg-slate-100 hover:bg-blue-50 hover:text-blue-700 text-slate-600 rounded-full text-sm transition-colors">
                <%= kw %>
              </button>
            <% end %>
          </div>
        </div>

      <% else %>

        <%# ── 법령 가이드 결과 ── %>
        <% if @topics.present? %>
          <div class="mb-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="material-symbols-outlined text-indigo-500 text-lg">menu_book</span>
              <h3 class="text-sm font-bold text-slate-600">법령 가이드 (<%= @topics.size %>)</h3>
            </div>
            <div class="space-y-2">
              <% @topics.each do |topic| %>
                <%= link_to topic_path(topic.slug),
                      class: "flex items-start gap-4 bg-white border border-slate-200 hover:border-indigo-300 hover:shadow-sm rounded-xl p-4 transition-all group",
                      data: { turbo_frame: "_top" } do %>
                  <div class="w-9 h-9 bg-indigo-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="material-symbols-outlined text-indigo-500 text-lg">gavel</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-slate-800 group-hover:text-indigo-700 truncate"><%= topic.name %></div>
                    <div class="text-xs text-slate-500 mt-0.5 line-clamp-1"><%= topic.summary %></div>
                  </div>
                  <span class="material-symbols-outlined text-slate-300 group-hover:text-indigo-400 text-base flex-shrink-0 mt-1">chevron_right</span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── 감사사례 결과 ── %>
        <% if @audit_cases.present? %>
          <div class="mb-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="material-symbols-outlined text-orange-500 text-lg">policy</span>
              <h3 class="text-sm font-bold text-slate-600">감사사례 (<%= @audit_cases.size %>)</h3>
            </div>
            <div class="space-y-2">
              <% @audit_cases.each do |ac| %>
                <% severity_color = ac.severity == "중대" ? "red" : ac.severity == "보통" ? "orange" : "amber" %>
                <%= link_to audit_case_path(ac.slug),
                      class: "flex items-start gap-4 bg-white border border-slate-200 hover:border-orange-300 hover:shadow-sm rounded-xl p-4 transition-all group",
                      data: { turbo_frame: "_top" } do %>
                  <div class="w-9 h-9 bg-orange-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="material-symbols-outlined text-orange-500 text-lg">warning</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-slate-800 group-hover:text-orange-700 truncate"><%= ac.title %></div>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class="text-xs bg-orange-50 text-orange-600 px-2 py-0.5 rounded-full"><%= ac.category %></span>
                      <span class="text-xs text-slate-400"><%= ac.severity %></span>
                    </div>
                  </div>
                  <span class="material-symbols-outlined text-slate-300 group-hover:text-orange-400 text-base flex-shrink-0 mt-1">chevron_right</span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── 서식 템플릿 결과 ── %>
        <% if @templates.present? %>
          <div class="mb-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="material-symbols-outlined text-teal-500 text-lg">description</span>
              <h3 class="text-sm font-bold text-slate-600">서식 템플릿 (<%= @templates.size %>)</h3>
            </div>
            <div class="space-y-2">
              <% @templates.each do |tmpl| %>
                <%= link_to templates_path,
                      class: "flex items-start gap-4 bg-white border border-slate-200 hover:border-teal-300 hover:shadow-sm rounded-xl p-4 transition-all group",
                      data: { turbo_frame: "_top" } do %>
                  <div class="w-9 h-9 bg-teal-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="material-symbols-outlined text-teal-500 text-lg">draft</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-slate-800 group-hover:text-teal-700 truncate"><%= tmpl[:title] %></div>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class="text-xs bg-teal-50 text-teal-600 px-2 py-0.5 rounded-full"><%= tmpl[:category] %></span>
                      <span class="text-xs text-slate-400"><%= tmpl[:formats].join(" · ") %></span>
                    </div>
                  </div>
                  <span class="material-symbols-outlined text-slate-300 group-hover:text-teal-400 text-base flex-shrink-0 mt-1">chevron_right</span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── 전체 결과 링크 ── %>
        <div class="border-t border-slate-100 pt-4 flex flex-wrap gap-3">
          <% if @topics.present? %>
            <%= link_to topics_path, class: "text-xs text-indigo-600 hover:text-indigo-800 flex items-center gap-1", data: { turbo_frame: "_top" } do %>
              <span class="material-symbols-outlined text-sm">menu_book</span>
              법령 가이드 전체 보기
            <% end %>
          <% end %>
          <% if @audit_cases.present? %>
            <%= link_to audit_cases_path, class: "text-xs text-orange-600 hover:text-orange-800 flex items-center gap-1", data: { turbo_frame: "_top" } do %>
              <span class="material-symbols-outlined text-sm">policy</span>
              감사사례 전체 보기
            <% end %>
          <% end %>
          <% if @templates.present? %>
            <%= link_to templates_path, class: "text-xs text-teal-600 hover:text-teal-800 flex items-center gap-1", data: { turbo_frame: "_top" } do %>
              <span class="material-symbols-outlined text-sm">description</span>
              서식 전체 보기
            <% end %>
          <% end %>
        </div>

      <% end %>
    <% end %>
  </div>
<% end %>
