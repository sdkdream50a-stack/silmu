<script>
  var selectedType = null;
  var selectedSpecial = null;
  var estimatedPrice = 0;

  function selectMainType(type) {
    const subGrid = document.getElementById('construction-sub');
    const specialSection = document.querySelector('.special-section');

    if (type === 'construction') {
      // 공사 선택 → 하위 옵션 펼치기, 특례기업 숨기기 (물품/용역만 해당)
      document.querySelectorAll('.type-option').forEach(el => {
        el.classList.toggle('selected', el.dataset.type === 'construction');
      });
      subGrid.classList.add('show');
      specialSection.style.display = 'none';
      selectedSpecial = null;
      // 이전 하위 선택 초기화
      document.querySelectorAll('.type-sub-option').forEach(el => el.classList.remove('selected'));
      selectedType = null;
      checkFormValid();
    } else {
      // 물품/용역 선택 → 하위 옵션 닫기, 특례기업 보이기
      subGrid.classList.remove('show');
      specialSection.style.display = '';
      document.querySelectorAll('.type-option').forEach(el => {
        el.classList.toggle('selected', el.dataset.type === type);
      });
      document.querySelectorAll('.type-sub-option').forEach(el => el.classList.remove('selected'));
      selectedType = type;
      checkFormValid();
    }
  }

  function selectConstructionType(type) {
    selectedType = type;
    // 하위 옵션 하이라이트
    document.querySelectorAll('.type-sub-option').forEach(el => {
      el.classList.toggle('selected', el.dataset.type === type);
    });
    // 메인 '공사' 계속 하이라이트
    document.querySelectorAll('.type-option').forEach(el => {
      el.classList.toggle('selected', el.dataset.type === 'construction');
    });
    checkFormValid();
  }

  function selectSpecial(special) {
    selectedSpecial = special === 'none' ? null : special;
    document.querySelectorAll('.special-option').forEach(el => {
      el.classList.toggle('selected', el.dataset.special === special);
    });
  }

  function formatPrice(input) {
    let value = input.value.replace(/[^0-9]/g, '');
    if (value) {
      estimatedPrice = parseInt(value);
      input.value = estimatedPrice.toLocaleString('ko-KR');
    } else {
      estimatedPrice = 0;
    }
    updateAmountHint();
    checkFormValid();
  }

  function checkVatWarning(input) {
    const warning = document.getElementById('vat-warning');
    if (!warning) return;
    if (estimatedPrice > 10000000) {
      warning.style.display = 'flex';
    } else {
      warning.style.display = 'none';
    }
  }

  function addAmount(amount) {
    estimatedPrice += amount;
    document.getElementById('estimated-price').value = estimatedPrice.toLocaleString('ko-KR');
    updateAmountHint();
    checkFormValid();
  }

  function resetAmount() {
    estimatedPrice = 0;
    document.getElementById('estimated-price').value = '';
    updateAmountHint();
    checkFormValid();
  }

  function updateAmountHint() {
    const hint = document.getElementById('amount-hint');
    if (estimatedPrice > 0) {
      hint.textContent = toKoreanUnit(estimatedPrice);
      hint.style.color = 'var(--color-emerald-600)';
      hint.style.fontWeight = '600';
    } else {
      hint.textContent = '추정가격 산정을 위한 대략적인 예상 금액을 입력하세요';
      hint.style.color = '#64748b';
      hint.style.fontWeight = '400';
    }
  }

  function toKoreanUnit(num) {
    if (num === 0) return '0원';
    const units = [
      { value: 100000000, label: '억' },
      { value: 10000, label: '만' }
    ];
    let result = '';
    let remaining = num;
    for (const unit of units) {
      if (remaining >= unit.value) {
        const count = Math.floor(remaining / unit.value);
        result += count.toLocaleString('ko-KR') + unit.label + ' ';
        remaining %= unit.value;
      }
    }
    if (remaining > 0) {
      result += remaining.toLocaleString('ko-KR');
    }
    return result.trim() + '원';
  }

  function checkFormValid() {
    const btn = document.getElementById('determine-btn');
    btn.disabled = !(selectedType && estimatedPrice > 0);
  }

  function showError(message) {
    const el = document.getElementById('error-message');
    el.textContent = message;
    el.style.display = 'block';
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function hideError() {
    document.getElementById('error-message').style.display = 'none';
  }

  function setLoading(loading) {
    const btn = document.getElementById('determine-btn');
    const icon = document.getElementById('btn-icon');
    const text = document.getElementById('btn-text');
    if (loading) {
      btn.disabled = true;
      if (icon) {
        icon.setAttribute('data-icon', 'material-symbols:hourglass-empty');
        if (typeof Iconify !== 'undefined') Iconify.scan();
      }
      icon.classList.add('animate-spin');
      text.textContent = '확인 중...';
    } else {
      btn.disabled = !(selectedType && estimatedPrice > 0);
      if (icon) {
        icon.setAttribute('data-icon', 'material-symbols:search');
        if (typeof Iconify !== 'undefined') Iconify.scan();
      }
      icon.classList.remove('animate-spin');
      text.textContent = '계약방식 확인하기';
    }
  }

  // 필드 에러 표시 헬퍼 함수
  function showFieldError(message) {
    const priceInput = document.getElementById('estimated-price');
    if (!priceInput) return;

    // 기존 에러 제거
    clearFieldError();

    // 필드에 에러 스타일 추가
    priceInput.style.borderColor = '#dc2626';
    priceInput.style.boxShadow = '0 0 0 3px rgba(220, 38, 38, 0.1)';

    // 에러 메시지 추가
    const hintEl = document.getElementById('amount-hint');
    if (hintEl) {
      hintEl.style.color = '#dc2626';
      hintEl.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;margin-right:4px;" data-icon="material-symbols:error">error</span>' + message;
      if (typeof Iconify !== 'undefined') Iconify.scan();
    }

    // 스크롤하여 필드 표시
    priceInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function clearFieldError() {
    const priceInput = document.getElementById('estimated-price');
    const hintEl = document.getElementById('amount-hint');

    if (priceInput) {
      priceInput.style.borderColor = '';
      priceInput.style.boxShadow = '';
    }

    if (hintEl) {
      hintEl.style.color = '';
      hintEl.textContent = '추정가격 산정을 위한 대략적인 예상 금액을 입력하세요';
    }
  }

  async function determineMethod() {
    // 검증: 계약 유형 선택 여부
    if (!selectedType) {
      showError('계약 유형을 선택해 주세요');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      return;
    }

    // 검증: 추정가격 입력 여부
    if (estimatedPrice <= 0) {
      showFieldError('추정가격을 입력해 주세요');
      return;
    }

    clearFieldError();

    hideError();
    setLoading(true);

    try {
      const response = await fetch('/contract-methods/determine', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]')?.content || ''
        },
        body: JSON.stringify({
          contract_type: selectedType,
          estimated_price: estimatedPrice,
          special_enterprise: selectedSpecial
        })
      });

      const result = await response.json();

      if (result.success) {
        renderResult(result);
      } else {
        showError(result.error || '오류가 발생했습니다.');
      }
    } catch (error) {
      console.error('Error:', error);
      showError('서버와 통신할 수 없습니다. 잠시 후 다시 시도해주세요.');
    } finally {
      setLoading(false);
    }
  }

  function renderResult(result) {
    // 헤더 색상 설정
    const header = document.getElementById('result-header');
    header.className = 'result-header ' + result.result.method;

    // 계약방식 표시
    document.getElementById('result-method').textContent = result.result.method;
    document.getElementById('result-detail').textContent = result.result.method_detail;

    // 결론 요약 생성
    const typeName = result.contract_type.name;
    const price = result.formatted_price;
    const method = result.result.method;
    const detail = result.result.method_detail;
    let summaryText = '';

    if (method === '입찰') {
      summaryText = `${typeName} ${price}원은 경쟁입찰로 진행해야 합니다.`;
    } else {
      summaryText = `${typeName} ${price}원은 "${detail}"로 진행할 수 있습니다.`;
    }

    document.getElementById('result-summary-text').textContent = summaryText;

    // note 표시 (핵심 실무 정보)
    const noteEl = document.getElementById('result-summary-note');
    if (result.result.note) {
      noteEl.textContent = result.result.note;
      noteEl.style.display = 'block';
    } else {
      noteEl.style.display = 'none';
    }

    // 기본 정보
    document.getElementById('info-type').textContent = result.contract_type.name;
    document.getElementById('info-price').textContent = result.formatted_price + '원';

    // 특례 적용
    const specialRow = document.getElementById('info-special-row');
    if (result.result.special_applied && result.special_enterprise) {
      specialRow.style.display = 'flex';
      document.getElementById('info-special').textContent = result.special_enterprise.name + ' 특례';
    } else {
      specialRow.style.display = 'none';
    }

    // 법령 근거
    document.getElementById('basis-content').textContent = result.result.basis;

    // 낙찰하한율 표시 (입찰인 경우)
    const lowestBidRateBox = document.getElementById('lowest-bid-rate-box');
    if (result.lowest_bid_rate) {
      lowestBidRateBox.style.display = 'block';
      document.getElementById('lowest-bid-rate-value').textContent = result.lowest_bid_rate.rate;
      document.getElementById('lowest-bid-rate-note').textContent = result.lowest_bid_rate.note + ' (' + result.lowest_bid_rate.detail + ')';
    } else {
      lowestBidRateBox.style.display = 'none';
    }

    // 경고/안내 (안전한 DOM 조작)
    const warningsContainer = document.getElementById('warnings-container');
    warningsContainer.innerHTML = '';

    function createAlertBox(level, iconName, title, message, link) {
      const box = document.createElement('div');
      box.className = 'alert-box ' + level;
      const icon = document.createElement('span');
      icon.className = 'material-symbols-outlined';
      icon.textContent = iconName;
      const content = document.createElement('div');
      content.className = 'content';
      const h5 = document.createElement('h5');
      h5.textContent = title;
      const p = document.createElement('p');
      p.textContent = message;
      content.appendChild(h5);
      content.appendChild(p);
      if (link) {
        const a = document.createElement('a');
        a.href = link;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.textContent = '자세히 보기 →';
        content.appendChild(a);
      }
      box.appendChild(icon);
      box.appendChild(content);
      return box;
    }

    if (result.result.special_condition) {
      warningsContainer.appendChild(
        createAlertBox('info', 'lightbulb', '참고사항', result.result.special_condition)
      );
    }
    result.warnings.forEach(w => {
      warningsContainer.appendChild(
        createAlertBox(w.level, w.level === 'warning' ? 'warning' : 'info', w.title, w.message, w.link)
      );
    });

    // 필요 서류 (안전한 DOM 조작)
    const docList = document.getElementById('doc-list');
    docList.innerHTML = '';
    result.result.documents.forEach(doc => {
      const item = document.createElement('div');
      item.className = 'doc-item';
      const icon = document.createElement('span');
      icon.className = 'material-symbols-outlined';
      icon.setAttribute('data-icon', 'material-symbols:description');
      item.appendChild(icon);
      item.appendChild(document.createTextNode(doc));
      docList.appendChild(item);
    });
    if (typeof Iconify !== 'undefined') Iconify.scan();

    // 팁 (안전한 DOM 조작)
    const tipsContainer = document.getElementById('tips-container');
    tipsContainer.innerHTML = '';
    result.tips.forEach(tip => {
      const item = document.createElement('div');
      item.className = 'tip-item';
      item.textContent = tip;
      tipsContainer.appendChild(item);
    });

    // 수의계약인 경우 → 계약이유서 생성기 바로가기 버튼 추가
    const linksSection = document.querySelector('.links-section');
    const existingReasonBtn = document.getElementById('contract-reason-btn');
    if (existingReasonBtn) existingReasonBtn.remove();

    if (result.result.method === '수의계약') {
      const reasonUrl = buildContractReasonUrl(result);
      const reasonBtn = document.createElement('a');
      reasonBtn.id = 'contract-reason-btn';
      reasonBtn.href = reasonUrl;
      reasonBtn.className = 'link-btn';
      reasonBtn.style.cssText = 'background:#059669;color:#fff;border-color:#059669;';
      reasonBtn.innerHTML = '<span class="material-symbols-outlined">edit_document</span> 계약이유서 바로 작성';
      if (linksSection) linksSection.insertBefore(reasonBtn, linksSection.firstChild);
    }

    // 결과 표시
    document.getElementById('result-section').classList.add('show');
    document.getElementById('result-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function buildContractReasonUrl(result) {
    const params = new URLSearchParams();
    // 계약 유형 매핑: goods→물품, service→용역, construction→공사
    const typeMap = { goods: '물품', service: '용역', construction: '공사', construction_small: '공사' };
    const typeName = typeMap[result.contract_type?.id] || result.contract_type?.name || '';
    if (typeName) params.set('type', typeName);

    // 금액
    if (estimatedPrice > 0) params.set('amount', estimatedPrice);

    // 수의계약 사유 (method_detail에서 추출)
    const detail = result.result?.method_detail || '';
    if (detail.includes('소액')) params.set('reason', '소액');
    else if (detail.includes('긴급')) params.set('reason', '긴급');
    else if (detail.includes('유일')) params.set('reason', '유일품');
    else if (detail.includes('특례')) params.set('reason', '특례기업');

    return '/tools/contract-reason?' + params.toString();
  }

  function resetForm() {
    // 결과만 닫고 입력값은 유지 → 조건 바꿔 재조회 가능
    document.getElementById('result-section').classList.remove('show');
    document.getElementById('input-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // 초기화
  selectSpecial('none');
</script>
