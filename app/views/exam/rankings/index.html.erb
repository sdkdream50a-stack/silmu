<% content_for :head do %>
  <meta name="robots" content="noindex">
<% end %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <!-- 헤더 -->
  <div class="text-center mb-8">
    <div class="w-16 h-16 bg-amber-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <span class="material-symbols-outlined text-amber-500 text-3xl">emoji_events</span>
    </div>
    <h1 class="text-2xl font-extrabold text-slate-900 mb-2">주간 학습 랭킹</h1>
    <p class="text-slate-500 text-sm">이번 주 모의고사 응시 횟수 기준 • 매주 월요일 초기화</p>
    <div class="inline-flex items-center gap-2 mt-3 bg-amber-50 border border-amber-200 text-amber-700 text-xs font-semibold px-3 py-1.5 rounded-full">
      <span class="material-symbols-outlined text-sm">schedule</span>
      리셋까지 <strong><%= @days_until_reset %>일</strong> 남음
    </div>
  </div>

  <!-- 내 순위 (로그인 시) -->
  <% if user_signed_in? %>
    <div class="bg-blue-50 border border-blue-200 rounded-2xl p-5 mb-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center">
          <span class="material-symbols-outlined text-white text-lg">person</span>
        </div>
        <div>
          <p class="text-xs text-blue-600 font-semibold">내 순위</p>
          <p class="text-slate-800 font-bold">전체 <strong class="text-blue-700"><%= @my_rank %>위</strong></p>
        </div>
      </div>
      <div class="text-right">
        <p class="text-2xl font-extrabold text-blue-700"><%= @my_quiz_count %></p>
        <p class="text-xs text-slate-500">이번 주 응시</p>
      </div>
    </div>

    <!-- 닉네임 설정 -->
    <div class="bg-white border border-slate-200 rounded-2xl p-4 mb-6">
      <p class="text-xs text-slate-500 font-semibold mb-2 flex items-center gap-1">
        <span class="material-symbols-outlined text-sm">badge</span>
        랭킹 닉네임 (2~12자)
      </p>
      <div class="flex gap-2">
        <input type="text" id="nickname-input" maxlength="12"
               value="<%= @my_display_name %>"
               placeholder="조달수험생#{current_user.id}"
               class="flex-1 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
        <button onclick="saveNickname()" class="bg-blue-600 text-white text-sm font-bold px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors whitespace-nowrap">저장</button>
      </div>
      <p id="nickname-msg" class="text-xs mt-1.5 hidden"></p>
    </div>
  <% else %>
    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-5 mb-6 text-center">
      <p class="text-slate-600 text-sm mb-3">로그인하면 내 순위를 확인하고 서버에 학습 데이터가 저장됩니다.</p>
      <a href="<%= new_user_session_path %>" class="inline-flex items-center gap-2 bg-blue-600 text-white text-sm font-bold px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">
        <span class="material-symbols-outlined text-base">person</span>
        로그인
      </a>
    </div>
  <% end %>

  <!-- 리더보드 -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100">
      <h2 class="font-bold text-slate-800 flex items-center gap-2">
        <span class="material-symbols-outlined text-amber-500">star</span>
        이번 주 Top 20
      </h2>
    </div>

    <% if @rankings.empty? %>
      <div class="p-12 text-center">
        <span class="material-symbols-outlined text-slate-300 text-5xl block mb-3">search_off</span>
        <p class="text-slate-400 text-sm">아직 이번 주 학습 기록이 없습니다.</p>
        <p class="text-slate-400 text-xs mt-1">모의고사를 풀면 랭킹에 등재됩니다!</p>
        <a href="<%= exam_quiz_index_path %>" class="mt-4 inline-flex items-center gap-2 bg-blue-600 text-white text-sm font-bold px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">
          <span class="material-symbols-outlined text-base">quiz</span>
          모의고사 바로 가기
        </a>
      </div>
    <% else %>
      <div class="divide-y divide-slate-100">
        <% @rankings.each do |entry| %>
          <div class="flex items-center gap-4 px-5 py-4 <%= entry[:rank] <= 3 ? 'bg-amber-50/50' : '' %>">
            <!-- 순위 -->
            <div class="w-8 flex-shrink-0 text-center">
              <% if entry[:rank] == 1 %>
                <span class="text-2xl">🥇</span>
              <% elsif entry[:rank] == 2 %>
                <span class="text-2xl">🥈</span>
              <% elsif entry[:rank] == 3 %>
                <span class="text-2xl">🥉</span>
              <% else %>
                <span class="text-slate-400 font-bold text-sm"><%= entry[:rank] %></span>
              <% end %>
            </div>

            <!-- 닉네임 + 스트릭 -->
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-slate-800 truncate text-sm"><%= entry[:name] %></p>
              <% if entry[:streak] > 0 %>
                <p class="text-xs text-orange-500 flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs">local_fire_department</span>
                  <%= entry[:streak] %>일 연속 학습 중
                </p>
              <% end %>
            </div>

            <!-- 응시 횟수 -->
            <div class="text-right flex-shrink-0">
              <p class="font-extrabold text-slate-800"><%= entry[:quiz_count] %></p>
              <p class="text-xs text-slate-400">회 응시</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- 안내 -->
  <div class="mt-6 bg-slate-50 rounded-xl p-4 text-xs text-slate-500 space-y-1">
    <p>• 랭킹은 이번 주 월요일 00:00부터 집계됩니다.</p>
    <p>• 모의고사(과목별, 챕터별, 전체 시험) 완료 시 1회로 카운트됩니다.</p>
    <p>• 닉네임은 로그인 후 위 입력창에서 변경할 수 있습니다.</p>
  </div>

<script>
async function saveNickname() {
  const input = document.getElementById('nickname-input')
  const msg = document.getElementById('nickname-msg')
  const name = input.value.trim()

  if (name.length < 2 || name.length > 12) {
    msg.textContent = '닉네임은 2~12자여야 합니다.'
    msg.className = 'text-xs mt-1.5 text-red-500'
    return
  }

  try {
    const res = await fetch('<%= exam_rankings_nickname_path %>', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
      body: JSON.stringify({ display_name: name })
    })
    const data = await res.json()
    if (data.success) {
      msg.textContent = '닉네임이 저장되었습니다!'
      msg.className = 'text-xs mt-1.5 text-emerald-600'
    } else {
      msg.textContent = data.error || '저장 실패'
      msg.className = 'text-xs mt-1.5 text-red-500'
    }
  } catch {
    msg.textContent = '네트워크 오류가 발생했습니다.'
    msg.className = 'text-xs mt-1.5 text-red-500'
  }
  msg.classList.remove('hidden')
}
</script>

  <!-- 이동 버튼 -->
  <div class="mt-6 flex gap-3">
    <a href="<%= exam_quiz_index_path %>" class="flex-1 inline-flex items-center justify-center gap-2 bg-blue-600 text-white font-bold px-4 py-3 rounded-xl hover:bg-blue-700 transition-colors text-sm">
      <span class="material-symbols-outlined text-base">quiz</span>
      모의고사 도전
    </a>
    <a href="<%= exam_root_path %>" class="flex-1 inline-flex items-center justify-center gap-2 bg-white border-2 border-slate-200 text-slate-700 font-bold px-4 py-3 rounded-xl hover:border-blue-400 transition-colors text-sm">
      <span class="material-symbols-outlined text-base">home</span>
      홈으로
    </a>
  </div>
</div>
