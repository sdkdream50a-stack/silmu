<%# 모의고사 선택 페이지 — Stitch 'The Academic Atelier' 디자인 적용 %>

<!-- 히어로 — navy gradient -->
<section class="bg-gradient-to-br from-[#465f88] to-[#3a537c] text-white py-14 px-4 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-72 h-72 bg-white/5 rounded-full -mr-36 -mt-36 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full -ml-24 -mb-24 pointer-events-none"></div>
  <div class="max-w-5xl mx-auto relative z-10">
    <!-- 브레드크럼 -->
    <div class="flex items-center gap-1.5 text-white/50 text-xs mb-5 flex-wrap">
      <a href="https://exam.silmu.kr" class="hover:text-white/80 transition-colors">홈</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <span class="text-white/80 font-medium">모의고사</span>
    </div>
    <!-- 뱃지 -->
    <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 mb-5">
      <span class="material-symbols-outlined text-[#ffd166] text-base" style="font-variation-settings:'FILL' 1">quiz</span>
      <span class="text-white/90 text-xs font-semibold">모의고사 문제풀이</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-extrabold leading-snug mb-3 tracking-tight text-[#f6f7ff]">모의고사</h1>
    <p class="text-[#c8d6f5] text-base mb-6 max-w-2xl">실전 감각을 키우는 4지선다 문제풀이 · 즉시 채점 + 해설</p>
    <!-- 요약 지표 -->
    <div class="flex flex-wrap gap-6 mb-7 py-4 border-t border-b border-white/15">
      <div class="text-center">
        <div class="text-2xl font-extrabold text-[#ffd166]"><%= @total_count %></div>
        <div class="text-white/60 text-xs mt-0.5">전체 문항</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-[#ffd166]">3</div>
        <div class="text-white/60 text-xs mt-0.5">과목</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-extrabold text-[#ffd166]">즉시</div>
        <div class="text-white/60 text-xs mt-0.5">채점</div>
      </div>
    </div>
    <!-- 퀵 링크 -->
    <div class="flex flex-wrap gap-3">
      <a href="<%= exam_quiz_path(1) %>" class="inline-flex items-center gap-1.5 bg-white text-[#465f88] font-bold px-5 py-2.5 rounded-full hover:bg-[#f6f7ff] transition-colors text-sm shadow-lg">
        <span class="material-symbols-outlined text-base">quiz</span>과목별 모의고사
      </a>
      <a href="<%= exam_quiz_mini_path %>" class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm border border-white/30 text-white font-semibold px-5 py-2.5 rounded-full hover:bg-white/25 transition-colors text-sm">
        <span class="material-symbols-outlined text-base">bolt</span>미니 퀴즈
      </a>
      <a href="<%= exam_quiz_wrong_path %>" class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm border border-white/30 text-white font-semibold px-5 py-2.5 rounded-full hover:bg-white/25 transition-colors text-sm">
        <span class="material-symbols-outlined text-base">error_outline</span>오답 노트
      </a>
    </div>
  </div>
</section>

<div class="bg-slate-50 min-h-screen py-12 px-4">
  <div class="max-w-5xl mx-auto space-y-14">

    <!-- ① 과목별 모의고사 — 다크 tall 카드 (Stitch) -->
    <section>
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl font-extrabold text-slate-900 tracking-tight">과목별 모의고사</h2>
        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Main Subjects</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <% @exam_subjects.each do |subject| %>
          <% colors = ExamCurriculum.colors(subject[:color]) %>
          <% q_count = @total_count_by_exam_subject(subject[:id]) %>
          <a href="<%= exam_quiz_path(subject[:id]) %>"
             class="group relative overflow-hidden rounded-2xl bg-slate-800 p-8 h-56 flex flex-col justify-between shadow-lg hover:scale-[1.02] transition-all duration-300">
            <!-- 컬러 그래디언트 오버레이 -->
            <div class="absolute inset-0 bg-gradient-to-br <%= colors[:btn_gradient] %> opacity-80 pointer-events-none"></div>
            <!-- 노이즈 텍스처 효과 (pseudo via opacity pattern) -->
            <div class="absolute inset-0 opacity-[0.04] pointer-events-none"
                 style="background-image:url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\")"></div>

            <div class="relative z-10 flex justify-between items-start">
              <span class="material-symbols-outlined text-white/50 text-4xl"><%= subject[:icon] %></span>
              <% if subject[:id] == 1 %>
                <span class="bg-white/15 backdrop-blur text-white px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight">시험 1과목</span>
              <% elsif subject[:id] == 2 %>
                <span class="bg-white/15 backdrop-blur text-white px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight">시험 2과목</span>
              <% else %>
                <span class="bg-yellow-400/90 text-slate-900 px-3 py-1 rounded-full text-[10px] font-bold">인기과목</span>
              <% end %>
            </div>
            <div class="relative z-10">
              <h3 class="text-2xl font-extrabold text-white leading-tight mb-1"><%= subject[:title] %></h3>
              <p class="text-white/70 text-sm"><%= q_count %>문제 · 약 <%= (q_count * 1.5).ceil %>분</p>
            </div>
          </a>
        <% end %>
      </div>
    </section>

    <!-- ② 4권 챕터별 문제풀기 — 북 스타일 카드 (Stitch) -->
    <section>
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-xl font-extrabold text-slate-900 tracking-tight">4권 챕터별 문제풀기</h2>
        <a href="<%= exam_subjects_path %>" class="text-sm font-semibold text-slate-500 flex items-center gap-1 hover:text-slate-800 transition-colors">
          커리큘럼 보기 <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <% @curriculum_subjects.each do |subject| %>
          <% colors = ExamCurriculum.colors(subject[:color]) %>
          <div class="bg-white rounded-2xl shadow-[0_2px_12px_rgba(18,28,40,0.06)] border-l-4 <%= colors[:accent_border] %> hover:shadow-[0_6px_24px_rgba(18,28,40,0.10)] transition-all overflow-hidden">
            <!-- 북 커버 영역 -->
            <div class="aspect-[3/4] <%= colors[:bg] %> flex flex-col items-center justify-center p-4 relative overflow-hidden">
              <!-- 고스트 아이콘 -->
              <div class="absolute inset-0 flex items-center justify-center opacity-10">
                <span class="material-symbols-outlined text-8xl <%= colors[:text] %>"><%= subject[:icon] %></span>
              </div>
              <span class="relative z-10 <%= colors[:badge] %> text-[10px] font-bold px-2.5 py-1 rounded-full mb-3"><%= subject[:number] %></span>
              <p class="relative z-10 text-center text-xs font-semibold text-slate-600 leading-snug">
                <%= subject[:chapters].size %>개 챕터
              </p>
            </div>
            <!-- 권 정보 -->
            <div class="p-4">
              <h4 class="font-extrabold text-slate-900 text-sm truncate mb-1"><%= subject[:title] %></h4>
              <p class="text-xs text-slate-400 mb-3"><%= subject[:subtitle] %></p>
              <!-- 챕터 드롭다운 목록 -->
              <details class="group">
                <summary class="list-none cursor-pointer text-xs font-bold <%= colors[:text_dark] %> flex items-center gap-1">
                  챕터 선택
                  <span class="material-symbols-outlined text-xs group-open:rotate-90 transition-transform">chevron_right</span>
                </summary>
                <ul class="mt-2 space-y-1">
                  <% subject[:chapters].each do |chapter| %>
                    <% ch_count = ExamQuestions.by_chapter(subject[:id], chapter[:number]).size %>
                    <% next if ch_count == 0 %>
                    <li>
                      <a href="<%= exam_quiz_chapter_path(subject_id: subject[:id], chapter_num: chapter[:number]) %>"
                         class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:<%= colors[:bg] %> transition-colors group/ch">
                        <span class="w-5 h-5 rounded-md <%= colors[:bg_dark] %> text-white flex items-center justify-center text-[10px] font-bold flex-shrink-0"><%= chapter[:number] %></span>
                        <span class="text-xs text-slate-600 flex-1 truncate group-hover/ch:<%= colors[:text_dark] %> transition-colors"><%= chapter[:title] %></span>
                        <span class="text-[10px] text-slate-400"><%= ch_count %>문</span>
                      </a>
                    </li>
                  <% end %>
                </ul>
              </details>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- ③ 특별 학습 모드 (Stitch 4-button) -->
    <section>
      <h2 class="text-xl font-extrabold text-slate-900 tracking-tight mb-6">특별 학습 모드</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

        <!-- 미니 퀴즈 (tonal) -->
        <a href="<%= exam_quiz_mini_path %>"
           class="group flex items-center gap-4 p-5 bg-white rounded-2xl hover:bg-slate-50 transition-colors shadow-[0_2px_12px_rgba(18,28,40,0.05)]">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-100 shadow-sm group-hover:scale-110 transition-transform flex-shrink-0">
            <span class="material-symbols-outlined text-slate-700">bolt</span>
          </div>
          <div>
            <span class="block text-sm font-bold text-slate-900">미니 퀴즈</span>
            <span class="block text-[11px] text-slate-400 mt-0.5">랜덤 10문제</span>
          </div>
        </a>

        <!-- 실전 시험 (featured 그래디언트) -->
        <a href="<%= exam_quiz_simulation_path %>"
           class="group flex items-center gap-4 p-5 bg-gradient-to-br from-slate-800 to-slate-700 rounded-2xl hover:opacity-90 transition-all shadow-lg shadow-slate-800/20">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-white/10 backdrop-blur group-hover:scale-110 transition-transform flex-shrink-0">
            <span class="material-symbols-outlined text-white">timer</span>
          </div>
          <div>
            <span class="block text-sm font-bold text-white">실전 시험</span>
            <span class="block text-[11px] text-white/60 mt-0.5">80문제 · 120분</span>
          </div>
        </a>

        <!-- 북마크 (tonal) -->
        <div id="bookmark-card-area">
          <a href="<%= exam_quiz_bookmarks_path %>"
             class="group flex items-center gap-4 p-5 bg-white rounded-2xl hover:bg-slate-50 transition-colors shadow-[0_2px_12px_rgba(18,28,40,0.05)]">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-100 shadow-sm group-hover:scale-110 transition-transform flex-shrink-0">
              <span class="material-symbols-outlined text-slate-700">star</span>
            </div>
            <div>
              <span class="block text-sm font-bold text-slate-900">북마크 문제</span>
              <span class="block text-[11px] text-slate-400 mt-0.5">모아보기</span>
            </div>
          </a>
        </div>

        <!-- 오답 노트 (tonal) -->
        <a href="<%= exam_quiz_wrong_path %>"
           class="group flex items-center gap-4 p-5 bg-white rounded-2xl hover:bg-slate-50 transition-colors shadow-[0_2px_12px_rgba(18,28,40,0.05)]">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-100 shadow-sm group-hover:scale-110 transition-transform flex-shrink-0">
            <span class="material-symbols-outlined text-slate-700">edit_note</span>
          </div>
          <div>
            <span class="block text-sm font-bold text-slate-900">오답 노트</span>
            <span class="block text-[11px] text-slate-400 mt-0.5">오답 정복</span>
          </div>
        </a>
      </div>
    </section>

    <!-- ④ 학습 분석 + 스트릭 행 -->
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-controller="exam-progress">
      <!-- 스트릭 -->
      <div data-exam-progress-target="streakArea">
        <div class="flex items-center gap-4 bg-white rounded-2xl px-5 py-4 shadow-[0_2px_12px_rgba(18,28,40,0.05)]">
          <div class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-slate-300 text-2xl">local_fire_department</span>
          </div>
          <div>
            <div class="text-slate-700 font-bold text-sm">학습 스트릭</div>
            <div class="text-slate-400 text-xs">모의고사 완료 후 기록</div>
          </div>
          <span class="text-slate-300 text-xs ml-auto">0일</span>
        </div>
      </div>

      <!-- 학습 분석 -->
      <a href="<%= exam_quiz_analysis_path %>"
         class="group flex items-center justify-between bg-white rounded-2xl px-5 py-4 shadow-[0_2px_12px_rgba(18,28,40,0.05)] hover:shadow-md transition-all">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-teal-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-teal-500">analytics</span>
          </div>
          <div>
            <div class="text-slate-800 font-bold text-sm">학습 분석 대시보드</div>
            <div class="text-slate-400 text-xs">과목별 진도 · 점수 추이 · 취약 분야</div>
          </div>
        </div>
        <span class="flex items-center gap-1 text-teal-600 font-bold text-sm group-hover:gap-2 transition-all">
          보기 <span class="material-symbols-outlined text-base">arrow_forward</span>
        </span>
      </a>
    </section>

    <!-- ⑤ 나의 풀이 기록 -->
    <section class="bg-white rounded-2xl shadow-[0_2px_12px_rgba(18,28,40,0.05)] p-7"
             data-controller="exam-progress">
      <h2 class="text-lg font-extrabold text-slate-900 mb-5 flex items-center gap-2">
        <span class="material-symbols-outlined text-amber-500">emoji_events</span>
        나의 풀이 기록
      </h2>
      <div data-exam-progress-target="scoreArea">
        <p class="text-slate-400 text-sm text-center py-6 flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-slate-300">quiz</span>
          아직 풀이 기록이 없습니다. 모의고사를 풀어보세요!
        </p>
      </div>
      <div data-exam-progress-target="wrongCountArea" class="mt-3"></div>
    </section>

    <!-- 광고 -->
    <div class="flex justify-center">
      <%= render 'shared/ad_slot', position: 'quiz-index-bottom' %>
    </div>

    <!-- ⑥ 모의고사 안내 (벤토 3카드) -->
    <section>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="bg-white rounded-2xl p-6 shadow-[0_2px_12px_rgba(18,28,40,0.05)] flex items-start gap-3">
          <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-blue-500">touch_app</span>
          </div>
          <div>
            <div class="font-bold text-slate-800 text-sm mb-1">즉시 채점</div>
            <div class="text-slate-400 text-xs leading-relaxed">선택 즉시 정답/오답 확인 및 해설 제공</div>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-[0_2px_12px_rgba(18,28,40,0.05)] flex items-start gap-3">
          <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-amber-500">lightbulb</span>
          </div>
          <div>
            <div class="font-bold text-slate-800 text-sm mb-1">상세 해설</div>
            <div class="text-slate-400 text-xs leading-relaxed">모든 문제에 해설 + AI 추가 해설 제공</div>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-[0_2px_12px_rgba(18,28,40,0.05)] flex items-start gap-3">
          <div class="w-10 h-10 bg-emerald-50 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-emerald-500">emoji_events</span>
          </div>
          <div>
            <div class="font-bold text-slate-800 text-sm mb-1">결과 분석</div>
            <div class="text-slate-400 text-xs leading-relaxed">점수·등급·오답 리뷰·취약 챕터 분석</div>
          </div>
        </div>
      </div>
    </section>

  </div>
</div>

<!-- 북마크 JS (기존 유지) -->
<script>
  (function() {
    try {
      var ids = JSON.parse(localStorage.getItem('exam_bookmarks')) || []
      var count = ids.length
      var area = document.getElementById('bookmark-card-area')
      if (!area || count === 0) return
      area.innerHTML = '<a href="/quiz/bookmarks" class="group flex items-center gap-4 p-5 bg-gradient-to-br from-indigo-600 to-violet-600 rounded-2xl hover:opacity-90 transition-all shadow-lg"><div class="w-12 h-12 flex items-center justify-center rounded-xl bg-white/10 group-hover:scale-110 transition-transform flex-shrink-0"><span class="material-symbols-outlined text-white">star</span></div><div><span class="block text-sm font-bold text-white">북마크 문제</span><span class="block text-[11px] text-white/70 mt-0.5">저장된 ' + count + '개 · 지금 복습</span></div><span class="bg-white text-indigo-500 text-xs font-extrabold px-2.5 py-1 rounded-full ml-auto">' + count + '</span></a>'
    } catch(e) {}
  })()
</script>
