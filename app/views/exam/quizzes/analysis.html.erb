<%# 학습 분석 대시보드 — Stitch 'Editorial Intelligence' 디자인 적용 %>

<!-- 페이지 헤더 — 에디토리얼 화이트 -->
<section class="bg-white border-b border-[#f3f3f6] py-10 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-1.5 text-slate-400 text-xs mb-6">
      <a href="https://exam.silmu.kr" class="hover:text-slate-600 transition-colors">홈</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <a href="<%= exam_quiz_index_path %>" class="hover:text-slate-600 transition-colors">모의고사</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <span class="text-slate-600 font-medium">학습 분석</span>
    </div>
    <div class="flex items-end justify-between gap-6">
      <div>
        <span class="text-[#0040a1] font-bold tracking-widest uppercase text-xs mb-2 block">Editorial Intelligence</span>
        <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight leading-tight">학습 분석 대시보드</h1>
        <p class="text-slate-400 text-sm mt-2">챕터 진도 · 과목별 오답 분석 · 학습 패턴</p>
      </div>
      <div class="hidden md:flex items-center gap-2 bg-[#f3f3f6] px-4 py-2 rounded-full flex-shrink-0">
        <span class="material-symbols-outlined text-[#0040a1] text-sm">insights</span>
        <span class="text-xs font-bold text-[#424654] uppercase tracking-widest">Data Curator</span>
      </div>
    </div>
  </div>
</section>

<!-- 대시보드 본문 -->
<section class="py-8 px-4 bg-[#f9f9fc] min-h-[60vh]"
         data-controller="exam-analysis">
  <div class="max-w-5xl mx-auto">

    <!-- 데이터 없음 상태 -->
    <div data-exam-analysis-target="emptyState">
      <div class="bg-white rounded-xl shadow-[0_40px_40px_-40px_rgba(26,28,30,0.04)] p-12 text-center max-w-lg mx-auto">
        <div class="w-20 h-20 bg-[#f3f3f6] rounded-2xl flex items-center justify-center mx-auto mb-5">
          <span class="material-symbols-outlined text-[#0040a1] text-4xl">insights</span>
        </div>
        <span class="text-[#424654] text-xs font-bold tracking-widest uppercase block mb-3">No Data Yet</span>
        <h2 class="text-xl font-extrabold text-slate-900 tracking-tight mb-2">학습 데이터가 없습니다</h2>
        <p class="text-slate-400 text-sm mb-8 leading-relaxed">챕터를 학습하거나 모의고사를 풀면<br>분석 데이터가 쌓입니다.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/subjects/1"
             class="inline-flex items-center justify-center gap-2 bg-[#0040a1] hover:bg-[#0056d2] text-white font-bold px-6 py-3 rounded-full transition-colors shadow-[0_4px_16px_rgba(0,64,161,0.25)]">
            <span class="material-symbols-outlined text-base">school</span>
            커리큘럼 학습 시작
          </a>
          <a href="<%= exam_quiz_path('all') %>"
             class="inline-flex items-center justify-center gap-2 bg-[#f3f3f6] hover:bg-[#e8e8ea] text-slate-700 font-bold px-6 py-3 rounded-full transition-colors">
            <span class="material-symbols-outlined text-base">quiz</span>
            모의고사 풀기
          </a>
        </div>
      </div>
    </div>

    <!-- 분석 내용 (JS에서 표시) -->
    <div data-exam-analysis-target="dashContent" class="hidden space-y-8">

      <!-- 종합 요약 카드 -->
      <div data-exam-analysis-target="summaryCards"
           class="grid grid-cols-2 md:grid-cols-4 gap-4">
      </div>

      <!-- 챕터 진도 + 모의고사 기록 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- 챕터 진도 -->
        <div class="bg-white rounded-xl shadow-[0_40px_40px_-40px_rgba(26,28,30,0.04)] p-6">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="font-extrabold text-slate-900 tracking-tight">과목별 챕터 진도</h3>
              <p class="text-xs text-[#424654] mt-0.5">Subject Mastery</p>
            </div>
            <div class="p-2 rounded-lg bg-[#f3f3f6] text-[#0040a1]">
              <span class="material-symbols-outlined text-base">school</span>
            </div>
          </div>
          <div data-exam-analysis-target="chapterProgress" class="space-y-5">
          </div>
        </div>

        <!-- 모의고사 기록 -->
        <div class="bg-white rounded-xl shadow-[0_40px_40px_-40px_rgba(26,28,30,0.04)] p-6">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="font-extrabold text-slate-900 tracking-tight">모의고사 기록</h3>
              <p class="text-xs text-[#424654] mt-0.5">Mock Exam Performance</p>
            </div>
            <div class="p-2 rounded-lg bg-[#f3f3f6] text-[#006e2c]">
              <span class="material-symbols-outlined text-base">emoji_events</span>
            </div>
          </div>
          <div data-exam-analysis-target="quizHistory" class="space-y-3">
          </div>
        </div>
      </div>

      <!-- 권별 학습 현황 비교 -->
      <div class="bg-white rounded-xl shadow-[0_40px_40px_-40px_rgba(26,28,30,0.04)] p-6">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h3 class="font-extrabold text-slate-900 tracking-tight">4권별 학습 현황</h3>
            <p class="text-xs text-[#424654] mt-0.5">각 권의 챕터 진도와 모의고사 성취도를 비교합니다.</p>
          </div>
          <div class="p-2 rounded-lg bg-[#f3f3f6] text-[#5c4300]">
            <span class="material-symbols-outlined text-base">donut_large</span>
          </div>
        </div>
        <div data-exam-analysis-target="subjectComparison" class="grid grid-cols-2 md:grid-cols-4 gap-4">
        </div>
      </div>

      <!-- 오답 분석 + 학습 추천 (비대칭 레이아웃) -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- 오답 분석 (large) -->
        <div class="lg:col-span-2 bg-white rounded-xl shadow-[0_40px_40px_-40px_rgba(26,28,30,0.04)] p-6">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="font-extrabold text-slate-900 tracking-tight">오답 현황 및 취약 분야</h3>
              <p class="text-xs text-[#424654] mt-0.5">Weakness Analysis</p>
            </div>
            <div class="p-2 rounded-lg bg-[#ffdad6]/50 text-[#ba1a1a]">
              <span class="material-symbols-outlined text-base">error_outline</span>
            </div>
          </div>
          <div data-exam-analysis-target="wrongAnalysis">
          </div>
        </div>

        <!-- 학습 추천 -->
        <div class="bg-white rounded-xl shadow-[0_40px_40px_-40px_rgba(26,28,30,0.04)] p-6">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="font-extrabold text-slate-900 tracking-tight">학습 추천</h3>
              <p class="text-xs text-[#424654] mt-0.5">Curated Focus</p>
            </div>
            <div class="p-2 rounded-lg bg-[#ffdfa0]/50 text-[#5c4300]">
              <span class="material-symbols-outlined text-base">lightbulb</span>
            </div>
          </div>
          <div data-exam-analysis-target="recommendations" class="space-y-3">
          </div>
        </div>
      </div>

      <!-- 푸터 추천 배너 — Stitch 시그니처 다크 카드 -->
      <div class="bg-[#0040a1] rounded-xl p-7 flex flex-col sm:flex-row items-center justify-between gap-5">
        <div class="flex items-center gap-5">
          <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0 backdrop-blur-md">
            <span class="material-symbols-outlined text-white text-2xl">psychology</span>
          </div>
          <div>
            <h3 class="text-white font-extrabold text-lg tracking-tight">실전 시험 모드 도전</h3>
            <p class="text-[#b2c5ff] text-sm mt-0.5">충분히 학습했다면 120분 실전 시뮬레이션으로 최종 점검하세요.</p>
          </div>
        </div>
        <a href="<%= exam_quiz_simulation_path %>"
           class="flex-shrink-0 bg-white text-[#0040a1] hover:bg-[#f3f3f6] px-6 py-3 rounded-full font-black text-xs uppercase tracking-widest shadow-xl transition-colors whitespace-nowrap">
          실전 시험 시작
        </a>
      </div>

    </div>
  </div>
</section>
