<%# 모의고사 문제풀이 페이지 — Stitch 'The Academic Atelier' 디자인 적용 %>
<% subject_colors = @subject ? ExamCurriculum.colors(@color) : ExamCurriculum.colors("blue") %>

<!-- 배경 장식 블롭 -->
<div class="fixed top-0 left-0 w-full h-screen pointer-events-none -z-10 overflow-hidden opacity-60">
  <div class="absolute top-[20%] -left-[10%] w-[40%] h-[40%] bg-[#a6eff3]/20 blur-[120px] rounded-full"></div>
  <div class="absolute bottom-[10%] -right-[5%] w-[30%] h-[30%] bg-[#ffdbc7]/15 blur-[100px] rounded-full"></div>
</div>

<!-- 히어로 — compact navy gradient -->
<section class="bg-gradient-to-br from-[#465f88] to-[#3a537c] text-white py-10 px-4 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-48 h-48 bg-white/5 rounded-full -mr-24 -mt-24 pointer-events-none"></div>
  <div class="max-w-3xl mx-auto relative z-10">
    <div class="flex items-center gap-1.5 text-white/50 text-xs mb-4 flex-wrap">
      <a href="https://exam.silmu.kr" class="hover:text-white/80 transition-colors">홈</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <a href="<%= exam_quiz_index_path %>" class="hover:text-white/80 transition-colors">모의고사</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <span class="text-white/80 font-medium"><%= @quiz_title %></span>
    </div>
    <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-3 py-1 mb-4">
      <span class="material-symbols-outlined text-[#ffd166] text-sm">quiz</span>
      <span class="text-white/80 text-xs font-semibold">Practice Assessment</span>
    </div>
    <h1 class="text-2xl md:text-3xl font-extrabold text-[#f6f7ff] tracking-tight mb-2"><%= @quiz_title %></h1>
    <p class="text-[#c8d6f5] text-sm"><%= @quiz_subtitle %> · <%= @questions.size %>문제 · 약 <%= @estimated_minutes %>분</p>
  </div>
</section>

<!-- 퀴즈 메인 (Stimulus) -->
<section class="py-8 px-4 bg-[#f7faf9] min-h-[60vh]">
  <div class="max-w-3xl mx-auto"
       data-controller="exam-quiz"
       data-exam-quiz-questions-value="<%= @questions.to_json %>"
       data-exam-quiz-subject-id-value="<%= @subject_id %>"
       data-exam-quiz-back-path-value="<%= @back_path %>"
       data-exam-quiz-chapter-map-value="<%= (@chapter_map || {}).to_json %>"
       data-exam-quiz-chapter-num-value="<%= @chapter_num || 0 %>"
       data-exam-quiz-topic-map-value="<%= (@topic_map || {}).to_json %>"
       data-exam-quiz-signed-in-value="<%= @signed_in ? 'true' : 'false' %>">

    <!-- 진행 상태 바 -->
    <div data-exam-quiz-target="progressArea" class="mb-8">
      <div class="flex items-end justify-between mb-3">
        <div class="flex flex-col">
          <span class="text-[0.65rem] font-bold tracking-widest uppercase text-slate-400 mb-1">Progress</span>
          <span class="text-sm text-slate-600">문제 <strong data-exam-quiz-target="currentNum" class="text-slate-800">1</strong> / <strong><%= @questions.size %></strong></span>
        </div>
        <div class="text-right">
          <span class="text-[0.65rem] font-bold tracking-widest uppercase text-[#00464a] block mb-1">Score</span>
          <span class="text-sm font-bold text-slate-800">점수: <strong data-exam-quiz-target="scoreDisplay" class="text-[#00464a]">0</strong>점</span>
        </div>
      </div>
      <div class="w-full bg-[#e0e3e3] rounded-full h-2">
        <div data-exam-quiz-target="progressBar"
             class="bg-gradient-to-r from-[#00464a] to-[#006064] h-2 rounded-full transition-all duration-500 ease-out"
             style="width: 0%"></div>
      </div>
    </div>

    <!-- 문제 영역 -->
    <div data-exam-quiz-target="questionArea" class="bg-white rounded-2xl shadow-[0_2px_16px_rgba(18,28,40,0.05)] p-6 md:p-8">
      <!-- 문제 번호 배지 -->
      <div class="flex items-center gap-2 mb-5 flex-wrap">
        <span data-exam-quiz-target="questionBadge"
              class="inline-flex items-center gap-1 bg-[#d9f4f5] text-[#00464a] text-xs font-bold px-3 py-1 rounded-full">
          문제 1
        </span>
      </div>

      <!-- 문제 텍스트 -->
      <p data-exam-quiz-target="questionText"
         class="text-slate-800 text-lg font-semibold leading-relaxed mb-6">
        <span class="block bg-[#eceeee] rounded animate-pulse h-5 w-full mb-2"></span>
        <span class="block bg-[#eceeee] rounded animate-pulse h-5 w-4/5"></span>
      </p>

      <!-- 선택지 -->
      <div data-exam-quiz-target="optionsArea" class="space-y-3">
        <% 4.times do %>
          <div class="bg-[#f2f4f4] rounded-xl h-14 animate-pulse"></div>
        <% end %>
      </div>

      <!-- 피드백 (정답/오답 해설) -->
      <div data-exam-quiz-target="feedbackArea" class="hidden mt-6">
      </div>

      <!-- 다음 버튼 — 전체 너비로 모바일 엄지 도달 최적화 -->
      <div data-exam-quiz-target="nextArea" class="hidden mt-6">
        <button data-action="click->exam-quiz#nextQuestion"
                data-exam-quiz-target="nextBtn"
                class="w-full inline-flex items-center justify-center gap-2 bg-[#00464a] hover:bg-[#005558] active:bg-[#003a3d] text-white font-bold px-6 py-4 rounded-xl transition-colors text-base shadow-[0_4px_16px_rgba(0,70,74,0.20)]">
          다음 문제
          <span class="material-symbols-outlined">arrow_forward</span>
        </button>
      </div>
    </div>

    <!-- 결과 화면 (hidden → Stimulus에서 표시) -->
    <div data-exam-quiz-target="resultArea" class="hidden">
    </div>
  </div>
</section>
