<%# exam.silmu.kr — 미니 퀴즈 (랜덤 10문제) — Stitch 'The Quick Sprint' 디자인 적용 %>

<!-- 히어로 — emerald gradient -->
<section class="bg-gradient-to-br from-[#1a4d38] to-[#166534] text-white py-14 px-4 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-72 h-72 bg-white/5 rounded-full -mr-36 -mt-36 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full -ml-24 -mb-24 pointer-events-none"></div>
  <div class="max-w-3xl mx-auto relative z-10">
    <div class="flex items-center gap-1.5 text-white/50 text-xs mb-5 flex-wrap">
      <a href="https://exam.silmu.kr" class="hover:text-white/80 transition-colors">홈</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <a href="<%= exam_quiz_index_path %>" class="hover:text-white/80 transition-colors">모의고사</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <span class="text-white/80 font-medium">미니 퀴즈</span>
    </div>
    <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 mb-5">
      <span class="material-symbols-outlined text-[#ffd166] text-base">bolt</span>
      <span class="text-white/90 text-xs font-semibold">빠른 실력 체크</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-extrabold leading-snug mb-3 tracking-tight text-[#f6f7ff]">미니 퀴즈</h1>
    <p class="text-white/70 text-base max-w-2xl">랜덤 10문제 · 즉시 채점 · 약 15분</p>
  </div>
</section>

<!-- 퀴즈 메인 (Stimulus) -->
<section class="py-8 px-4 bg-[#f5faf8] min-h-[60vh]">
  <div class="max-w-3xl mx-auto"
       data-controller="exam-quiz"
       data-exam-quiz-questions-value="<%= @questions.to_json %>"
       data-exam-quiz-subject-id-value="mini"
       data-exam-quiz-back-path-value="<%= exam_quiz_index_path %>"
       data-exam-quiz-chapter-map-value="<%= @chapter_map.to_json.html_safe %>"
       data-exam-quiz-chapter-num-value="0">

    <!-- 진행 상태 바 -->
    <div data-exam-quiz-target="progressArea" class="mb-6">
      <div class="flex items-center justify-between text-sm text-[#595c5e] mb-2">
        <span>문제 <strong data-exam-quiz-target="currentNum" class="text-[#2c2f31]">1</strong> / <strong><%= @questions.size %></strong></span>
        <span>점수: <strong data-exam-quiz-target="scoreDisplay" class="text-[#006e5a]">0</strong>점</span>
      </div>
      <div class="w-full bg-[#b8e0d8] rounded-full h-2">
        <div data-exam-quiz-target="progressBar"
             class="bg-[#006e5a] h-2 rounded-full transition-all duration-500 ease-out"
             style="width: 0%"></div>
      </div>
    </div>

    <!-- 문제 영역 -->
    <div data-exam-quiz-target="questionArea" class="bg-white rounded-2xl shadow-[0_12px_40px_rgba(0,110,90,0.06)] p-6 md:p-8">
      <!-- 문제 번호 배지 -->
      <div class="flex items-center gap-2 mb-5">
        <span data-exam-quiz-target="questionBadge"
              class="inline-flex items-center gap-1 bg-[#d0ede7] text-[#006e5a] text-xs font-bold px-3 py-1 rounded-full">
          문제 1
        </span>
      </div>

      <!-- 문제 텍스트 -->
      <p data-exam-quiz-target="questionText"
         class="text-[#2c2f31] text-lg font-semibold leading-relaxed mb-6">
        <span class="block bg-[#eef1f3] rounded animate-pulse h-5 w-full mb-2"></span>
        <span class="block bg-[#eef1f3] rounded animate-pulse h-5 w-4/5"></span>
      </p>

      <!-- 선택지 -->
      <div data-exam-quiz-target="optionsArea" class="space-y-3">
        <% 4.times do %>
          <div class="bg-[#eef1f3] rounded-xl h-14 animate-pulse"></div>
        <% end %>
      </div>

      <!-- 피드백 (정답/오답 해설) -->
      <div data-exam-quiz-target="feedbackArea" class="hidden mt-6">
      </div>

      <!-- 다음 버튼 -->
      <div data-exam-quiz-target="nextArea" class="hidden mt-6">
        <div class="flex justify-end">
          <button data-action="click->exam-quiz#nextQuestion"
                  data-exam-quiz-target="nextBtn"
                  class="inline-flex items-center gap-2 bg-[#006e5a] hover:bg-[#005e4d] text-white font-bold px-6 py-3 rounded-full transition-colors">
            다음 문제
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
        </div>
      </div>
    </div>

    <!-- 결과 화면 (hidden → Stimulus에서 표시) -->
    <div data-exam-quiz-target="resultArea" class="hidden">
    </div>
  </div>
</section>
