<%# 챕터 학습 페이지 — Stitch 'Editorial Learning Experience' 디자인 적용 %>
<% colors = @colors %>
<% chapter_id = "#{@subject[:id]}-#{@chapter[:number]}" %>

<% content_for :head do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LearningResource",
      "@id": "https://exam.silmu.kr/subjects/<%= @subject[:id] %>/chapters/<%= @chapter[:number] %>#resource",
      "name": "<%= @subject[:number] %> 제<%= @chapter[:number] %>장: <%= @chapter[:title] %>",
      "description": "공공조달관리사 <%= @subject[:number] %> <%= @subject[:title] %> — 제<%= @chapter[:number] %>장 <%= @chapter[:title] %>. 학습목표·핵심키워드·시험 출제 포인트 완벽 정리.",
      "url": "https://exam.silmu.kr/subjects/<%= @subject[:id] %>/chapters/<%= @chapter[:number] %>",
      "inLanguage": "ko",
      "isAccessibleForFree": true,
      "educationalLevel": "전문",
      "teaches": <%= @chapter[:keywords].first(5).to_json %>,
      "isPartOf": {
        "@type": "Course",
        "name": "공공조달관리사 시험 대비 완전 커리큘럼",
        "url": "https://exam.silmu.kr"
      },
      "provider": {
        "@type": "Organization",
        "name": "실무.kr",
        "url": "https://silmu.kr"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "공공조달관리사 시험 대비", "item": "https://exam.silmu.kr" },
        { "@type": "ListItem", "position": 2, "name": "<%= @subject[:number] %>: <%= @subject[:title] %>", "item": "https://exam.silmu.kr/subjects/<%= @subject[:id] %>" },
        { "@type": "ListItem", "position": 3, "name": "제<%= @chapter[:number] %>장: <%= @chapter[:title] %>", "item": "https://exam.silmu.kr/subjects/<%= @subject[:id] %>/chapters/<%= @chapter[:number] %>" }
      ]
    }
  ]
}
</script>
<% end %>

<div data-controller="exam-progress"
     data-exam-progress-subject-id-value="<%= @subject[:id] %>"
     data-exam-progress-chapter-num-value="<%= @chapter[:number] %>">

<!-- 챕터 히어로 — subject gradient -->
<% hero_from, hero_to = {
  "emerald" => ["#1a4d38", "#166534"],
  "blue"    => ["#1e3a6e", "#1e3a8a"],
  "violet"  => ["#3b1f6e", "#4c1d95"],
  "rose"    => ["#6e1e2a", "#881337"]
}[@subject[:color]] || ["#465f88", "#3a537c"] %>
<section class="text-white py-12 px-4 relative overflow-hidden"
         style="background: linear-gradient(135deg, <%= hero_from %>, <%= hero_to %>);">
  <div class="absolute top-0 right-0 w-72 h-72 bg-white/5 rounded-full -mr-36 -mt-36 pointer-events-none"></div>
  <!-- 고스트 아이콘 장식 -->
  <div class="hidden lg:block absolute -bottom-6 -right-6 opacity-[0.06] pointer-events-none">
    <span class="material-symbols-outlined text-white" style="font-size: 16rem; line-height:1;"><%= @subject[:icon] %></span>
  </div>

  <div class="max-w-5xl mx-auto relative z-10">
    <!-- 브레드크럼 -->
    <div class="flex items-center gap-1.5 text-white/50 text-xs mb-5 flex-wrap">
      <a href="https://exam.silmu.kr" class="hover:text-white/80 transition-colors">홈</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <a href="<%= exam_subjects_path %>" class="hover:text-white/80 transition-colors">커리큘럼</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <a href="<%= exam_subject_path(@subject[:id]) %>" class="hover:text-white/80 transition-colors"><%= @subject[:number] %></a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <span class="text-white/80 font-medium">제<%= @chapter[:number] %>장</span>
    </div>

    <!-- 뱃지 -->
    <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 mb-4">
      <span class="material-symbols-outlined text-[#ffd166] text-sm"><%= @subject[:icon] %></span>
      <span class="text-white/90 text-xs font-semibold"><%= @subject[:number] %> · <%= @subject[:title] %></span>
    </div>

    <!-- 챕터 번호 + 제목 -->
    <div class="text-white/60 text-sm font-bold tracking-wide mb-2">제<%= @chapter[:number] %>장</div>
    <h1 class="text-3xl md:text-4xl font-extrabold text-[#f6f7ff] tracking-tight leading-tight max-w-3xl mb-6">
      <%= @chapter[:title] %>
    </h1>

    <!-- 학습 정보 칩 -->
    <div class="flex flex-wrap gap-2">
      <span class="flex items-center gap-1 bg-white/15 text-white/80 text-xs font-semibold px-3 py-1.5 rounded-full">
        <span class="material-symbols-outlined text-xs">list</span><%= @chapter[:sections].size %>개 절
      </span>
      <span class="flex items-center gap-1 bg-white/15 text-white/80 text-xs font-semibold px-3 py-1.5 rounded-full">
        <span class="material-symbols-outlined text-xs">key</span>키워드 <%= @chapter[:keywords].size %>개
      </span>
      <span class="flex items-center gap-1 bg-[#ffd166]/20 text-[#ffd166] text-xs font-semibold px-3 py-1.5 rounded-full">
        <span class="material-symbols-outlined text-xs">bolt</span>출제포인트 <%= @chapter[:exam_points].size %>개
      </span>
      <div data-exam-progress-target="badge"></div>
    </div>
  </div>
</section>

<!-- 3단계 탭 구조 -->
<div data-controller="exam-tabs"
     data-exam-tabs-chapter-id-value="<%= chapter_id %>"
     id="chapter-study-tabs">

  <!-- 탭 바 (sticky) — 에디토리얼 스타일 -->
  <div class="sticky top-0 z-20 bg-white/90 backdrop-blur-md border-b border-slate-100 shadow-[0_2px_12px_rgba(18,28,40,0.06)]">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex">
        <button data-action="click->exam-tabs#switch"
                data-tab="theory"
                data-exam-tabs-target="tab"
                class="tab-inactive flex-1 flex items-center justify-center gap-2 py-4 text-sm font-bold border-b-2 transition-all">
          <span class="material-symbols-outlined text-base">menu_book</span>
          <span class="hidden sm:inline">이론 요약</span>
          <span class="sm:hidden">이론</span>
        </button>
        <button data-action="click->exam-tabs#switch"
                data-tab="memory"
                data-exam-tabs-target="tab"
                class="tab-inactive flex-1 flex items-center justify-center gap-2 py-4 text-sm font-bold border-b-2 transition-all">
          <span class="material-symbols-outlined text-base">psychology</span>
          <span class="hidden sm:inline">핵심 암기</span>
          <span class="sm:hidden">암기</span>
        </button>
        <button data-action="click->exam-tabs#switch"
                data-tab="practice"
                data-exam-tabs-target="tab"
                class="tab-inactive flex-1 flex items-center justify-center gap-2 py-4 text-sm font-bold border-b-2 transition-all">
          <span class="material-symbols-outlined text-base">quiz</span>
          <span class="hidden sm:inline">문제 풀기</span>
          <span class="sm:hidden">문제</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 탭 1: 이론 요약                             -->
  <!-- ═══════════════════════════════════════════ -->
  <div data-exam-tabs-target="panel" data-panel="theory" class="bg-slate-50 py-10 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

        <!-- 사이드바: 학습목표 + 핵심 키워드 -->
        <div class="lg:col-span-4 space-y-6">

          <!-- 학습목표 카드 -->
          <div class="bg-white rounded-2xl p-7 shadow-[0_2px_16px_rgba(18,28,40,0.05)]">
            <h3 class="text-lg font-extrabold text-slate-900 mb-5 flex items-center gap-2">
              <span class="material-symbols-outlined <%= colors[:text_dark] %>">lightbulb</span>
              학습목표
            </h3>
            <ul class="space-y-4">
              <% @chapter[:learning_objectives].each do |obj| %>
                <li class="flex gap-3 items-start">
                  <span class="material-symbols-outlined <%= colors[:text_dark] %> text-base mt-0.5 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span class="text-slate-500 text-sm leading-relaxed"><%= obj %></span>
                </li>
              <% end %>
            </ul>
          </div>

          <!-- 핵심 키워드 카드 -->
          <div class="bg-white rounded-2xl p-7 shadow-[0_2px_16px_rgba(18,28,40,0.05)]">
            <h3 class="text-lg font-extrabold text-slate-900 mb-5 flex items-center gap-2">
              <span class="material-symbols-outlined <%= colors[:text_dark] %>">key</span>
              핵심 키워드
            </h3>
            <div class="flex flex-wrap gap-2">
              <% @chapter[:keywords].each do |kw| %>
                <span class="px-3 py-1.5 bg-slate-100 text-slate-600 rounded-lg text-xs font-semibold"><%= kw.split('(').first.strip %></span>
              <% end %>
            </div>
          </div>

          <!-- 관련 법령 가이드 -->
          <% if @chapter[:related_topic_slugs].any? %>
            <div class="bg-white rounded-2xl p-7 shadow-[0_2px_16px_rgba(18,28,40,0.05)]">
              <h3 class="text-lg font-extrabold text-slate-900 mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-blue-500">menu_book</span>
                관련 법령 가이드
              </h3>
              <div class="flex flex-col gap-2">
                <% @chapter[:related_topic_slugs].each do |slug| %>
                  <a href="https://silmu.kr/topics/<%= slug %>"
                     target="_blank"
                     class="flex items-center gap-2 bg-blue-50 hover:bg-blue-100 text-blue-700 text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors">
                    <span class="material-symbols-outlined text-sm">open_in_new</span>
                    <%= topic_slug_label(slug) %>
                  </a>
                <% end %>
              </div>
              <p class="text-xs text-slate-400 mt-3">실무.kr에서 법령 조문·실무 해설 확인</p>
            </div>
          <% end %>
        </div>

        <!-- 메인: 이론 내용 -->
        <div class="lg:col-span-8 space-y-6">

          <!-- 학습 안내 배너 -->
          <div class="<%= colors[:bg] %> rounded-2xl px-5 py-4 flex items-start gap-3">
            <span class="material-symbols-outlined <%= colors[:text_dark] %> flex-shrink-0 mt-0.5">lightbulb</span>
            <div>
              <p class="font-bold <%= colors[:text_dark] %> text-sm">학습 방법</p>
              <p class="text-slate-600 text-sm mt-0.5">절 구성을 파악한 뒤, 학습목표를 체크하며 읽으세요. 이해가 끝나면 <strong>핵심 암기</strong> 탭으로 이동하세요.</p>
            </div>
          </div>

          <!-- 절 구성 -->
          <div class="bg-white rounded-2xl overflow-hidden shadow-[0_2px_16px_rgba(18,28,40,0.05)]">
            <div class="bg-slate-800 px-6 py-4 flex items-center gap-3">
              <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
                <span class="material-symbols-outlined text-white text-base">format_list_numbered</span>
              </div>
              <h2 class="font-bold text-white">이 장의 구성 (<%= @chapter[:sections].size %>개 절)</h2>
            </div>
            <div class="divide-y divide-slate-50">
              <% @chapter[:sections].each_with_index do |section, i| %>
                <div class="flex items-center gap-4 px-6 py-4">
                  <div class="w-9 h-9 <%= colors[:bg] %> <%= colors[:text_dark] %> rounded-xl flex items-center justify-center font-bold text-sm flex-shrink-0">
                    <%= i + 1 %>
                  </div>
                  <p class="text-slate-700 font-medium text-sm leading-relaxed flex-1">제<%= i + 1 %>절 <%= section %></p>
                  <span class="material-symbols-outlined text-slate-300 flex-shrink-0">arrow_forward_ios</span>
                </div>
              <% end %>
            </div>
          </div>

          <!-- 절별 이론 내용 -->
          <% if @chapter[:theory_content].present? %>
            <% @chapter[:theory_content].each_with_index do |sec, sec_idx| %>
              <div class="bg-white rounded-2xl overflow-hidden shadow-[0_2px_16px_rgba(18,28,40,0.05)]">
                <div class="bg-slate-800 px-6 py-4 flex items-center gap-3">
                  <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center font-bold text-white text-sm flex-shrink-0">
                    <%= sec_idx + 1 %>
                  </div>
                  <h2 class="font-bold text-white text-sm">제<%= sec_idx + 1 %>절 <%= sec[:section] %></h2>
                </div>
                <div class="divide-y divide-slate-50">
                  <% sec[:subsections].each do |sub| %>
                    <div class="px-6 py-5">
                      <h3 class="font-bold text-slate-800 text-sm mb-2"><%= sub[:title] %></h3>
                      <% if sub[:content].present? %>
                        <p class="text-slate-600 text-sm leading-relaxed mb-3"><%= format_theory_text(sub[:content]) %></p>
                      <% end %>
                      <% if sub[:highlight].present? %>
                        <div class="border-l-4 <%= colors[:accent_border] %> pl-4 py-1 mb-3">
                          <p class="<%= colors[:text_dark] %> text-sm font-semibold"><%= format_theory_text(sub[:highlight]) %></p>
                        </div>
                      <% end %>
                      <% if sub[:points].present? %>
                        <ul class="space-y-1.5">
                          <% sub[:points].each do |pt| %>
                            <li class="flex items-start gap-2 text-sm text-slate-700">
                              <span class="<%= colors[:text_dark] %> font-bold flex-shrink-0 mt-0.5">▸</span>
                              <span><%= format_theory_text(pt) %></span>
                            </li>
                          <% end %>
                        </ul>
                      <% end %>
                      <% if sub[:table].present? %>
                        <p class="text-xs font-semibold text-slate-500 mt-4 mb-1.5"><%= sub[:table][:caption] %></p>
                        <div class="overflow-x-auto rounded-xl border border-slate-100">
                          <table class="w-full text-xs">
                            <thead class="bg-slate-50">
                              <tr>
                                <% sub[:table][:headers].each do |h| %>
                                  <th class="px-3 py-2 text-left font-semibold text-slate-600 whitespace-nowrap"><%= h %></th>
                                <% end %>
                              </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-50">
                              <% sub[:table][:rows].each do |row| %>
                                <tr class="hover:bg-slate-50">
                                  <% row.each_with_index do |cell, ci| %>
                                    <td class="px-3 py-2 <%= ci == 0 ? 'font-semibold text-slate-800' : 'text-slate-600' %>"><%= format_theory_text(cell) %></td>
                                  <% end %>
                                </tr>
                              <% end %>
                            </tbody>
                          </table>
                        </div>
                      <% end %>
                      <% if sub[:mnemonic].present? %>
                        <div class="mt-3 bg-amber-50 rounded-xl px-4 py-3 border-l-4 border-amber-400">
                          <div class="flex items-center gap-2 mb-1.5">
                            <span class="text-amber-700 text-xs font-bold uppercase tracking-wide">암기법</span>
                            <span class="text-amber-800 text-xs font-semibold"><%= sub[:mnemonic][:title] %></span>
                          </div>
                          <p class="text-amber-900 text-sm font-medium leading-relaxed"><%= format_theory_text(sub[:mnemonic][:content]) %></p>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>

          <!-- 국가/지방계약법 조문 비교표 -->
          <% if @chapter[:law_comparison].present? %>
            <div class="bg-white rounded-2xl overflow-hidden shadow-[0_2px_16px_rgba(18,28,40,0.05)] border-l-4 border-violet-500">
              <div class="bg-violet-50 px-6 py-4 flex items-center gap-3">
                <div class="w-8 h-8 bg-violet-600 rounded-lg flex items-center justify-center">
                  <span class="material-symbols-outlined text-white text-base">compare</span>
                </div>
                <h2 class="font-bold text-slate-900">국가계약법 vs 지방계약법 조문 비교</h2>
                <span class="text-xs bg-violet-100 text-violet-700 font-bold px-2 py-0.5 rounded-full ml-auto">빈출</span>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                      <th class="px-4 py-3 text-left text-slate-600 font-semibold">주제</th>
                      <th class="px-4 py-3 text-center text-blue-700 font-semibold">국가계약법</th>
                      <th class="px-4 py-3 text-center text-emerald-700 font-semibold">지방계약법</th>
                      <th class="px-4 py-3 text-left text-slate-500 font-semibold hidden md:table-cell">비고</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-50">
                    <% @chapter[:law_comparison].each do |row| %>
                      <tr class="hover:bg-slate-50">
                        <td class="px-4 py-3 font-medium text-slate-800"><%= row[:topic] %></td>
                        <td class="px-4 py-3 text-center">
                          <span class="inline-block bg-blue-50 text-blue-700 text-xs font-semibold px-2.5 py-1 rounded-lg"><%= row[:national] %></span>
                        </td>
                        <td class="px-4 py-3 text-center">
                          <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-semibold px-2.5 py-1 rounded-lg"><%= row[:local] %></span>
                        </td>
                        <% if row[:note].present? %>
                          <td class="px-4 py-3 text-slate-400 text-xs hidden md:table-cell"><%= row[:note] %></td>
                        <% else %>
                          <td class="px-4 py-3 hidden md:table-cell"></td>
                        <% end %>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
              <div class="px-6 py-3 bg-violet-50 border-t border-violet-100">
                <p class="text-xs text-violet-600">💡 국가계약법과 지방계약법은 같은 주제라도 조문 번호가 다릅니다. 반드시 암기하세요.</p>
              </div>
            </div>
          <% end %>

          <!-- 다음 탭으로 -->
          <button data-action="click->exam-tabs#switch"
                  data-tab="memory"
                  class="w-full flex items-center justify-between gap-4 bg-gradient-to-br <%= colors[:btn_gradient] %> hover:opacity-90 text-white rounded-2xl px-6 py-5 transition-all group">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-xl">psychology</span>
              </div>
              <div class="text-left">
                <div class="text-xs text-white/70">이론 이해 완료?</div>
                <div class="font-bold">핵심 암기 탭으로 →</div>
              </div>
            </div>
            <span class="material-symbols-outlined text-2xl text-white/70 group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </button>

        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 탭 2: 핵심 암기                             -->
  <!-- ═══════════════════════════════════════════ -->
  <div data-exam-tabs-target="panel" data-panel="memory" class="hidden bg-slate-50 py-10 px-4">
    <div class="max-w-5xl mx-auto space-y-5">

      <!-- 시험 출제 포인트 — Stitch 퀴즈 카드 스타일 -->
      <h3 class="text-2xl font-extrabold text-slate-900 tracking-tight mb-1 flex items-center gap-2">
        <span class="material-symbols-outlined text-amber-500">bolt</span>
        시험 출제 포인트
        <span class="text-sm font-normal text-slate-400 ml-1"><%= @chapter[:exam_points].size %>개</span>
      </h3>

      <% @chapter[:exam_points].each_with_index do |point, i| %>
        <div class="bg-white rounded-2xl p-7 shadow-[0_1px_8px_rgba(18,28,40,0.04)] border-l-4 border-amber-400">
          <div class="flex items-start gap-4">
            <span class="w-8 h-8 bg-amber-400 text-white rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5"><%= i + 1 %></span>
            <p class="text-slate-800 text-base leading-relaxed font-medium"><%= point %></p>
          </div>
        </div>
      <% end %>

      <!-- 핵심 키워드 정의 — Stitch 퀴즈 카드 스타일 -->
      <h3 class="text-2xl font-extrabold text-slate-900 tracking-tight mt-10 mb-1 flex items-center gap-2">
        <span class="material-symbols-outlined <%= colors[:text_dark] %>">key</span>
        핵심 키워드 정의
        <span class="text-sm font-normal text-slate-400 ml-1"><%= @chapter[:keywords].size %>개 용어</span>
      </h3>

      <% @chapter[:keywords].each do |kw| %>
        <% detail = ExamKeywordDetails::DETAILS[kw] %>
        <div class="bg-white rounded-2xl p-7 shadow-[0_1px_8px_rgba(18,28,40,0.04)] border-l-4 <%= colors[:accent_border] %>">
          <div class="flex items-start gap-4">
            <span class="<%= colors[:badge] %> text-xs font-bold px-2.5 py-1 rounded-lg flex-shrink-0 mt-0.5">용어</span>
            <div class="flex-1 min-w-0">
              <p class="font-extrabold text-slate-900 text-base mb-2"><%= kw %></p>
              <% if detail %>
                <p class="text-slate-500 text-sm leading-relaxed"><%= detail[:definition] %></p>
                <% if detail[:example].present? %>
                  <details class="mt-3 group">
                    <summary class="list-none cursor-pointer inline-flex items-center gap-2 <%= colors[:text_dark] %> text-sm font-bold hover:underline">
                      <span class="material-symbols-outlined text-sm">visibility</span>
                      예시 보기
                    </summary>
                    <div class="mt-3 pl-4 border-l-2 border-slate-200">
                      <p class="text-xs text-slate-500 font-semibold mb-1">예시</p>
                      <p class="text-sm text-slate-600 leading-relaxed"><%= detail[:example] %></p>
                    </div>
                  </details>
                <% end %>
              <% else %>
                <p class="text-slate-400 text-xs italic">정의 준비 중</p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- 광고 슬롯 -->
      <div class="py-2 flex justify-center">
        <%= render 'shared/ad_slot', position: 'chapter-memory' %>
      </div>

      <!-- 다음 탭으로 -->
      <button data-action="click->exam-tabs#switch"
              data-tab="practice"
              class="w-full flex items-center justify-between gap-4 bg-indigo-600 hover:bg-indigo-700 text-white rounded-2xl px-6 py-5 transition-all group">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-xl">quiz</span>
          </div>
          <div class="text-left">
            <div class="text-xs text-white/70">암기 완료?</div>
            <div class="font-bold">문제 풀기 탭으로 →</div>
          </div>
        </div>
        <span class="material-symbols-outlined text-2xl text-white/70 group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </button>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 탭 3: 문제 풀기                             -->
  <!-- ═══════════════════════════════════════════ -->
  <div data-exam-tabs-target="panel" data-panel="practice" class="hidden bg-slate-50 py-10 px-4">
    <div class="max-w-5xl mx-auto space-y-6">

      <!-- 섹션 헤더 -->
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-2xl font-extrabold text-slate-900 tracking-tight">미니 퀴즈</h3>
        <div class="text-slate-400 text-sm"><%= @mini_questions.size %>문제 · 빠른 자가진단</div>
      </div>

      <!-- 미니 퀴즈 컴포넌트 -->
      <% if @mini_questions.any? %>
        <div class="bg-white rounded-2xl overflow-hidden shadow-[0_2px_16px_rgba(18,28,40,0.05)] border-l-4 border-indigo-500"
             data-controller="exam-quiz"
             data-exam-quiz-questions-value="<%= @mini_questions.to_json %>"
             data-exam-quiz-chapter-map-value="<%= @chapter_map.to_json %>"
             data-exam-quiz-back-path-value="<%= exam_subject_chapter_path(@subject[:id], @chapter[:number]) %>">

          <!-- 헤더 -->
          <div class="bg-indigo-50 px-6 py-4 flex items-center gap-3">
            <span class="material-symbols-outlined text-indigo-600">quiz</span>
            <div>
              <h2 class="font-bold text-slate-900">이 챕터 핵심 문제</h2>
              <p class="text-xs text-slate-500">배운 내용을 바로 확인해보세요</p>
            </div>
          </div>

          <!-- 진행바 -->
          <div class="px-6 pt-5" data-exam-quiz-target="progressArea">
            <div class="flex items-center justify-between text-xs text-slate-500 mb-2">
              <span>문제 <strong data-exam-quiz-target="currentNum">1</strong> / <strong><%= @mini_questions.size %></strong></span>
              <span>점수: <strong data-exam-quiz-target="scoreDisplay">0</strong></span>
            </div>
            <div class="w-full bg-slate-100 rounded-full h-2">
              <div class="bg-indigo-500 h-2 rounded-full transition-all duration-500 ease-out" style="width:0%" data-exam-quiz-target="progressBar"></div>
            </div>
          </div>

          <!-- 문제 영역 -->
          <div class="px-6 py-5" data-exam-quiz-target="questionArea">
            <div class="flex items-center gap-2 flex-wrap mb-3" data-exam-quiz-target="questionBadge"></div>
            <p class="text-slate-800 font-semibold text-base leading-relaxed mb-5" data-exam-quiz-target="questionText"></p>
            <div class="space-y-2" data-exam-quiz-target="optionsArea"></div>
            <div class="mt-4 hidden" data-exam-quiz-target="feedbackArea"></div>
            <div class="mt-4 hidden" data-exam-quiz-target="nextArea">
              <button data-action="click->exam-quiz#nextQuestion" data-exam-quiz-target="nextBtn"
                      class="w-full inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-3 rounded-xl transition-colors">
                다음 문제 <span class="material-symbols-outlined">arrow_forward</span>
              </button>
            </div>
          </div>

          <!-- 빈 상태 -->
          <div class="hidden px-6 py-10 text-center" data-exam-quiz-target="emptyArea">
            <span class="material-symbols-outlined text-slate-300 text-4xl">quiz</span>
            <p class="text-slate-500 mt-2">문제가 없습니다</p>
          </div>

          <!-- 결과 화면 -->
          <div class="hidden px-6 pb-6" data-exam-quiz-target="resultArea"></div>
        </div>
      <% else %>
        <div class="bg-white rounded-2xl p-10 text-center shadow-[0_2px_16px_rgba(18,28,40,0.05)]">
          <span class="material-symbols-outlined text-slate-300 text-5xl">quiz</span>
          <p class="text-slate-500 mt-3 font-bold">미니 퀴즈가 준비 중입니다</p>
          <p class="text-slate-400 text-sm mt-1">아래 전체 문제 풀기를 이용해주세요.</p>
        </div>
      <% end %>

      <!-- 챕터 전체 문제 풀기 CTA -->
      <% chapter_q_count = ExamQuestions.by_chapter(@subject[:id], @chapter[:number]).size %>
      <a href="<%= exam_quiz_chapter_path(subject_id: @subject[:id], chapter_num: @chapter[:number]) %>"
         class="flex items-center justify-between gap-4 bg-gradient-to-br <%= colors[:btn_gradient] %> hover:opacity-90 text-white rounded-2xl px-6 py-5 transition-all group">
        <div class="flex items-center gap-3">
          <div class="w-11 h-11 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-xl">format_list_numbered</span>
          </div>
          <div>
            <div class="text-xs text-white/70 mb-0.5">챕터 전체 문제 모아보기</div>
            <div class="font-bold text-base">제<%= @chapter[:number] %>장 전체 문제 풀기 (<%= chapter_q_count %>문제)</div>
          </div>
        </div>
        <span class="material-symbols-outlined text-2xl text-white/70 group-hover:translate-x-1 transition-transform flex-shrink-0">arrow_forward</span>
      </a>

      <!-- 광고 슬롯 -->
      <div class="py-2 flex justify-center">
        <%= render 'shared/ad_slot', position: 'chapter-bottom' %>
      </div>

    </div>
  </div>

</div><%# /exam-tabs %>

<!-- 챕터 네비게이션 — Stitch 대형 화살표 스타일 -->
<section class="bg-white border-t border-slate-100 py-10 px-4">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-6">

    <!-- 이전 챕터 -->
    <% if @prev_chapter %>
      <a href="<%= exam_subject_chapter_path(@subject[:id], @prev_chapter[:number]) %>"
         class="flex items-center gap-4 group w-full sm:w-auto">
        <div class="p-4 rounded-full bg-slate-100 group-hover:<%= colors[:bg] %> transition-all flex-shrink-0">
          <span class="material-symbols-outlined <%= colors[:text_dark] %>">arrow_back</span>
        </div>
        <div>
          <p class="text-slate-400 text-xs font-bold uppercase tracking-widest">이전 챕터</p>
          <p class="text-lg font-extrabold text-slate-800 leading-snug">제<%= @prev_chapter[:number] %>장 <%= @prev_chapter[:title] %></p>
        </div>
      </a>
    <% else %>
      <a href="<%= exam_subject_path(@subject[:id]) %>"
         class="flex items-center gap-4 group w-full sm:w-auto">
        <div class="p-4 rounded-full bg-slate-100 group-hover:<%= colors[:bg] %> transition-all flex-shrink-0">
          <span class="material-symbols-outlined <%= colors[:text_dark] %>">arrow_back</span>
        </div>
        <div>
          <p class="text-slate-400 text-xs font-bold uppercase tracking-widest">과목 목록으로</p>
          <p class="text-lg font-extrabold text-slate-800 leading-snug"><%= @subject[:number] %> <%= @subject[:title] %></p>
        </div>
      </a>
    <% end %>

    <!-- 다음 챕터 -->
    <% if @next_chapter %>
      <a href="<%= exam_subject_chapter_path(@subject[:id], @next_chapter[:number]) %>"
         class="flex flex-row-reverse items-center gap-4 group w-full sm:w-auto text-right">
        <div class="p-4 rounded-full bg-gradient-to-br <%= colors[:btn_gradient] %> text-white group-hover:scale-110 transition-all shadow-lg flex-shrink-0">
          <span class="material-symbols-outlined">arrow_forward</span>
        </div>
        <div>
          <p class="text-slate-400 text-xs font-bold uppercase tracking-widest">다음 챕터</p>
          <p class="text-lg font-extrabold text-slate-800 leading-snug">제<%= @next_chapter[:number] %>장 <%= @next_chapter[:title] %></p>
        </div>
      </a>
    <% else %>
      <% next_subject = ExamCurriculum.find_subject(@subject[:id] + 1) %>
      <% if next_subject %>
        <a href="<%= exam_subject_path(next_subject[:id]) %>"
           class="flex flex-row-reverse items-center gap-4 group w-full sm:w-auto text-right">
          <div class="p-4 rounded-full bg-gradient-to-br <%= colors[:btn_gradient] %> text-white group-hover:scale-110 transition-all shadow-lg flex-shrink-0">
            <span class="material-symbols-outlined">arrow_forward</span>
          </div>
          <div>
            <p class="text-slate-400 text-xs font-bold uppercase tracking-widest">다음 과목으로</p>
            <p class="text-lg font-extrabold text-slate-800 leading-snug"><%= next_subject[:number] %> <%= next_subject[:title] %></p>
          </div>
        </a>
      <% end %>
    <% end %>

  </div>
</section>

</div><%# /data-controller="exam-progress" %>
