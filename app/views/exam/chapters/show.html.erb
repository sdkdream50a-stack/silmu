<%# 챕터 학습 페이지 — 이론요약·핵심암기·문제풀기 3단계 구조 %>
<% colors = @colors %>
<% chapter_id = "#{@subject[:id]}-#{@chapter[:number]}" %>

<div data-controller="exam-progress"
     data-exam-progress-subject-id-value="<%= @subject[:id] %>"
     data-exam-progress-chapter-num-value="<%= @chapter[:number] %>">

<!-- 챕터 헤더 -->
<section class="<%= colors[:bg_dark] %> text-white py-10 px-4">
  <div class="max-w-4xl mx-auto">
    <!-- 브레드크럼 -->
    <div class="flex items-center gap-1 text-white/60 text-sm mb-5 flex-wrap">
      <a href="https://exam.silmu.kr" class="hover:text-white transition-colors">홈</a>
      <span class="material-symbols-outlined text-xs">chevron_right</span>
      <a href="<%= exam_subjects_path %>" class="hover:text-white transition-colors">커리큘럼</a>
      <span class="material-symbols-outlined text-xs">chevron_right</span>
      <a href="<%= exam_subject_path(@subject[:id]) %>" class="hover:text-white transition-colors"><%= @subject[:number] %> <%= @subject[:title] %></a>
      <span class="material-symbols-outlined text-xs">chevron_right</span>
      <span class="text-white">제<%= @chapter[:number] %>장</span>
    </div>

    <div class="flex items-center justify-between gap-2 mb-3">
      <div class="flex items-center gap-2">
        <span class="text-xs font-bold bg-white/20 px-3 py-1 rounded-full"><%= @subject[:number] %></span>
        <span class="text-white/60 text-sm">제<%= @chapter[:number] %>장</span>
      </div>
      <div data-exam-progress-target="badge"></div>
    </div>
    <h1 class="text-2xl md:text-3xl font-bold leading-tight"><%= @chapter[:title] %></h1>

    <!-- 학습 정보 칩 -->
    <div class="flex flex-wrap gap-2 mt-4">
      <span class="flex items-center gap-1 bg-white/15 text-xs px-3 py-1.5 rounded-full">
        <span class="material-symbols-outlined text-xs">list</span><%= @chapter[:sections].size %>개 절
      </span>
      <span class="flex items-center gap-1 bg-white/15 text-xs px-3 py-1.5 rounded-full">
        <span class="material-symbols-outlined text-xs">key</span>키워드 <%= @chapter[:keywords].size %>개
      </span>
      <span class="flex items-center gap-1 bg-white/15 text-xs px-3 py-1.5 rounded-full">
        <span class="material-symbols-outlined text-xs">star</span>출제포인트 <%= @chapter[:exam_points].size %>개
      </span>
    </div>
  </div>
</section>

<!-- 3단계 탭 네비게이션 -->
<div data-controller="exam-tabs"
     data-exam-tabs-chapter-id-value="<%= chapter_id %>"
     id="chapter-study-tabs">

  <!-- 탭 바 (sticky) -->
  <div class="sticky top-0 z-20 bg-white border-b border-slate-200 shadow-sm">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex">
        <!-- 이론 요약 -->
        <button data-action="click->exam-tabs#switch"
                data-tab="theory"
                data-exam-tabs-target="tab"
                class="tab-inactive flex-1 flex items-center justify-center gap-1.5 py-3.5 text-sm font-semibold border-b-2 transition-all">
          <span class="material-symbols-outlined text-base">menu_book</span>
          <span class="hidden sm:inline">이론 요약</span>
          <span class="sm:hidden">이론</span>
        </button>
        <!-- 핵심 암기 -->
        <button data-action="click->exam-tabs#switch"
                data-tab="memory"
                data-exam-tabs-target="tab"
                class="tab-inactive flex-1 flex items-center justify-center gap-1.5 py-3.5 text-sm font-semibold border-b-2 transition-all">
          <span class="material-symbols-outlined text-base">psychology</span>
          <span class="hidden sm:inline">핵심 암기</span>
          <span class="sm:hidden">암기</span>
        </button>
        <!-- 문제 풀기 -->
        <button data-action="click->exam-tabs#switch"
                data-tab="practice"
                data-exam-tabs-target="tab"
                class="tab-inactive flex-1 flex items-center justify-center gap-1.5 py-3.5 text-sm font-semibold border-b-2 transition-all">
          <span class="material-symbols-outlined text-base">quiz</span>
          <span class="hidden sm:inline">문제 풀기</span>
          <span class="sm:hidden">문제</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ─────────────────────────────────────── -->
  <!-- 탭 1: 이론 요약                         -->
  <!-- ─────────────────────────────────────── -->
  <div data-exam-tabs-target="panel" data-panel="theory" class="bg-slate-50 py-8 px-4">
    <div class="max-w-4xl mx-auto space-y-6">

      <!-- 학습 안내 배너 -->
      <div class="<%= colors[:bg] %> border <%= colors[:border] %> rounded-2xl px-5 py-4 flex items-start gap-3">
        <span class="material-symbols-outlined <%= colors[:text_dark] %> text-xl flex-shrink-0 mt-0.5">lightbulb</span>
        <div>
          <p class="font-semibold <%= colors[:text_dark] %> text-sm">학습 방법</p>
          <p class="text-slate-600 text-sm mt-0.5">절 구성을 파악한 뒤, 학습목표를 체크하며 읽으세요. 이해가 끝나면 <strong>핵심 암기</strong> 탭으로 이동하세요.</p>
        </div>
      </div>

      <!-- 절 구성 -->
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 flex items-center gap-3 border-b border-slate-200">
          <div class="w-8 h-8 bg-slate-700 rounded-lg flex items-center justify-center">
            <span class="material-symbols-outlined text-white text-base">format_list_numbered</span>
          </div>
          <h2 class="font-bold text-slate-900">이 장의 구성 (<%= @chapter[:sections].size %>개 절)</h2>
        </div>
        <div class="divide-y divide-slate-100">
          <% @chapter[:sections].each_with_index do |section, i| %>
            <div class="flex items-center gap-4 px-6 py-4">
              <div class="w-9 h-9 <%= colors[:bg] %> <%= colors[:text_dark] %> rounded-xl flex items-center justify-center font-bold text-sm flex-shrink-0">
                <%= i + 1 %>
              </div>
              <div class="flex-1">
                <p class="text-slate-800 font-medium text-sm leading-relaxed">제<%= i + 1 %>절 <%= section %></p>
              </div>
              <span class="material-symbols-outlined text-slate-300 flex-shrink-0">arrow_forward_ios</span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- 학습목표 체크리스트 -->
      <div class="bg-white rounded-2xl border <%= colors[:border] %> overflow-hidden">
        <div class="<%= colors[:bg] %> px-6 py-4 flex items-center gap-3 border-b <%= colors[:border] %>">
          <div class="w-8 h-8 <%= colors[:bg_dark] %> rounded-lg flex items-center justify-center">
            <span class="material-symbols-outlined text-white text-base">school</span>
          </div>
          <h2 class="font-bold text-slate-900">학습목표</h2>
          <span class="text-xs text-slate-500 ml-auto">이 장을 마치면 이해·설명할 수 있습니다</span>
        </div>
        <div class="px-6 py-5">
          <ul class="space-y-3">
            <% @chapter[:learning_objectives].each_with_index do |obj, i| %>
              <li class="flex items-start gap-3 group">
                <div class="w-6 h-6 rounded-full border-2 <%= colors[:border] %> flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="material-symbols-outlined text-xs <%= colors[:text_dark] %>">check</span>
                </div>
                <span class="text-slate-700 text-sm leading-relaxed"><%= obj %></span>
              </li>
            <% end %>
          </ul>
        </div>
      </div>

      <!-- 관련 법령 가이드 (있을 경우) -->
      <% if @chapter[:related_topic_slugs].any? %>
        <div class="bg-white rounded-2xl border border-blue-200 overflow-hidden">
          <div class="bg-blue-50 px-6 py-4 flex items-center gap-3 border-b border-blue-200">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
              <span class="material-symbols-outlined text-white text-base">menu_book</span>
            </div>
            <h2 class="font-bold text-slate-900">관련 법령 가이드</h2>
            <span class="text-xs text-blue-500 ml-auto">실무.kr 연계</span>
          </div>
          <div class="px-6 py-5">
            <div class="flex flex-wrap gap-3">
              <% @chapter[:related_topic_slugs].each do |slug| %>
                <a href="https://silmu.kr/topics/<%= slug %>"
                   target="_blank"
                   class="flex items-center gap-2 bg-blue-50 hover:bg-blue-100 border border-blue-200 text-blue-700 text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors">
                  <span class="material-symbols-outlined text-base">open_in_new</span>
                  <%= topic_slug_label(slug) %>
                </a>
              <% end %>
            </div>
            <p class="text-xs text-slate-400 mt-3">실무.kr에서 법령 조문·실무 해설을 확인하세요.</p>
          </div>
        </div>
      <% end %>

      <!-- 다음 탭으로 이동 버튼 -->
      <button data-action="click->exam-tabs#switch"
              data-tab="memory"
              class="w-full flex items-center justify-between gap-4 <%= colors[:bg_dark] %> hover:opacity-90 text-white rounded-2xl px-6 py-4 transition-all group">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-xl">psychology</span>
          </div>
          <div class="text-left">
            <div class="text-xs text-white/70">이론 이해 완료?</div>
            <div class="font-bold">핵심 암기 탭으로 →</div>
          </div>
        </div>
        <span class="material-symbols-outlined text-2xl text-white/70 group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </button>

    </div>
  </div>

  <!-- ─────────────────────────────────────── -->
  <!-- 탭 2: 핵심 암기                         -->
  <!-- ─────────────────────────────────────── -->
  <div data-exam-tabs-target="panel" data-panel="memory" class="hidden bg-slate-50 py-8 px-4">
    <div class="max-w-4xl mx-auto space-y-6">

      <!-- 시험 출제 포인트 — 강조 카드 -->
      <div class="bg-white rounded-2xl border border-amber-200 overflow-hidden">
        <div class="bg-amber-50 px-6 py-4 flex items-center gap-3 border-b border-amber-200">
          <div class="w-8 h-8 bg-amber-500 rounded-lg flex items-center justify-center">
            <span class="material-symbols-outlined text-white text-base">bolt</span>
          </div>
          <h2 class="font-bold text-slate-900">시험 출제 포인트</h2>
          <span class="text-xs bg-amber-100 text-amber-700 font-bold px-2 py-0.5 rounded-full ml-auto"><%= @chapter[:exam_points].size %>개</span>
        </div>
        <div class="p-5 grid gap-3">
          <% @chapter[:exam_points].each_with_index do |point, i| %>
            <div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3.5 flex items-start gap-3">
              <span class="w-6 h-6 bg-amber-400 text-white rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5"><%= i + 1 %></span>
              <p class="text-slate-800 text-sm leading-relaxed font-medium"><%= point %></p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- 핵심 키워드 정의 카드 -->
      <div class="bg-white rounded-2xl border <%= colors[:border] %> overflow-hidden">
        <div class="<%= colors[:bg] %> px-6 py-4 flex items-center gap-3 border-b <%= colors[:border] %>">
          <div class="w-8 h-8 <%= colors[:bg_dark] %> rounded-lg flex items-center justify-center">
            <span class="material-symbols-outlined text-white text-base">key</span>
          </div>
          <h2 class="font-bold text-slate-900">핵심 키워드 정의</h2>
          <span class="text-xs <%= colors[:text_dark] %> ml-auto font-semibold"><%= @chapter[:keywords].size %>개 용어</span>
        </div>
        <div class="divide-y divide-slate-100">
          <% @chapter[:keywords].each do |kw| %>
            <% detail = ExamKeywordDetails::DETAILS[kw] %>
            <div class="px-5 py-4">
              <div class="flex items-start gap-3">
                <span class="<%= colors[:badge] %> text-xs font-bold px-2.5 py-1 rounded-lg flex-shrink-0 mt-0.5">용어</span>
                <div class="flex-1 min-w-0">
                  <p class="font-bold text-slate-800 text-sm mb-1"><%= kw %></p>
                  <% if detail %>
                    <p class="text-slate-600 text-sm leading-relaxed"><%= detail[:definition] %></p>
                    <% if detail[:example].present? %>
                      <div class="mt-2 bg-slate-50 rounded-lg px-3 py-2 border-l-2 border-slate-300">
                        <p class="text-xs text-slate-500 font-semibold mb-0.5">예시</p>
                        <p class="text-xs text-slate-600 leading-relaxed"><%= detail[:example] %></p>
                      </div>
                    <% end %>
                  <% else %>
                    <p class="text-slate-400 text-xs italic">정의 준비 중</p>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- 광고 슬롯 -->
      <div class="py-2 flex justify-center">
        <%= render 'shared/ad_slot', position: 'chapter-memory' %>
      </div>

      <!-- 다음 탭으로 이동 버튼 -->
      <button data-action="click->exam-tabs#switch"
              data-tab="practice"
              class="w-full flex items-center justify-between gap-4 bg-indigo-600 hover:bg-indigo-700 text-white rounded-2xl px-6 py-4 transition-all group">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-xl">quiz</span>
          </div>
          <div class="text-left">
            <div class="text-xs text-white/70">암기 완료?</div>
            <div class="font-bold">문제 풀기 탭으로 →</div>
          </div>
        </div>
        <span class="material-symbols-outlined text-2xl text-white/70 group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </button>

    </div>
  </div>

  <!-- ─────────────────────────────────────── -->
  <!-- 탭 3: 문제 풀기                         -->
  <!-- ─────────────────────────────────────── -->
  <div data-exam-tabs-target="panel" data-panel="practice" class="hidden bg-slate-50 py-8 px-4">
    <div class="max-w-4xl mx-auto space-y-6">

      <!-- 미니 퀴즈 -->
      <% if @mini_questions.any? %>
        <div class="bg-white rounded-2xl border border-indigo-200 overflow-hidden"
             data-controller="exam-quiz"
             data-exam-quiz-questions-value="<%= @mini_questions.to_json %>"
             data-exam-quiz-chapter-map-value="<%= @chapter_map.to_json %>"
             data-exam-quiz-back-path-value="<%= exam_subject_chapter_path(@subject[:id], @chapter[:number]) %>">
          <!-- 헤더 -->
          <div class="bg-indigo-50 px-6 py-4 flex items-center gap-3 border-b border-indigo-200">
            <span class="material-symbols-outlined text-indigo-600">quiz</span>
            <div>
              <h2 class="font-bold text-slate-900">이 챕터 핵심 문제</h2>
              <p class="text-xs text-slate-500">배운 내용을 바로 확인해보세요 · <%= @mini_questions.size %>문항</p>
            </div>
            <span class="text-xs text-indigo-500 ml-auto">빠른 자가진단</span>
          </div>
          <!-- 진행바 -->
          <div class="px-6 pt-4" data-exam-quiz-target="progressArea">
            <div class="flex items-center justify-between text-xs text-slate-500 mb-2">
              <span>문제 <strong data-exam-quiz-target="currentNum">1</strong> / <strong><%= @mini_questions.size %></strong></span>
              <span>점수: <strong data-exam-quiz-target="scoreDisplay">0</strong></span>
            </div>
            <div class="w-full bg-slate-100 rounded-full h-1.5">
              <div class="bg-indigo-500 h-1.5 rounded-full transition-all duration-500 ease-out" style="width:0%" data-exam-quiz-target="progressBar"></div>
            </div>
          </div>
          <!-- 문제 영역 -->
          <div class="px-6 py-4" data-exam-quiz-target="questionArea">
            <div class="flex items-center gap-2 flex-wrap mb-3" data-exam-quiz-target="questionBadge"></div>
            <p class="text-slate-800 font-medium text-base leading-relaxed mb-4" data-exam-quiz-target="questionText"></p>
            <div class="space-y-2" data-exam-quiz-target="optionsArea"></div>
            <div class="mt-4 hidden" data-exam-quiz-target="feedbackArea"></div>
            <div class="mt-4 hidden" data-exam-quiz-target="nextArea">
              <button data-action="click->exam-quiz#nextQuestion" data-exam-quiz-target="nextBtn"
                      class="w-full inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-3 rounded-xl transition-colors">
                다음 문제 <span class="material-symbols-outlined">arrow_forward</span>
              </button>
            </div>
          </div>
          <!-- 빈 상태 -->
          <div class="hidden px-6 py-10 text-center" data-exam-quiz-target="emptyArea">
            <span class="material-symbols-outlined text-slate-300 text-4xl">quiz</span>
            <p class="text-slate-500 mt-2">문제가 없습니다</p>
          </div>
          <!-- 결과 화면 -->
          <div class="hidden px-6 pb-6" data-exam-quiz-target="resultArea"></div>
        </div>
      <% else %>
        <div class="bg-white rounded-2xl border border-slate-200 px-6 py-10 text-center">
          <span class="material-symbols-outlined text-slate-300 text-5xl">quiz</span>
          <p class="text-slate-500 mt-3 font-medium">미니 퀴즈가 준비 중입니다</p>
          <p class="text-slate-400 text-sm mt-1">아래 전체 문제 풀기를 이용해주세요.</p>
        </div>
      <% end %>

      <!-- 챕터 전체 문제 풀기 CTA -->
      <% chapter_q_count = ExamQuestions.by_chapter(@subject[:id], @chapter[:number]).size %>
      <a href="<%= exam_quiz_chapter_path(subject_id: @subject[:id], chapter_num: @chapter[:number]) %>"
         class="flex items-center justify-between gap-4 <%= colors[:bg_dark] %> hover:opacity-90 text-white rounded-2xl px-6 py-5 transition-all group">
        <div class="flex items-center gap-3">
          <div class="w-11 h-11 bg-white/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-xl">format_list_numbered</span>
          </div>
          <div>
            <div class="text-xs text-white/70 mb-0.5">챕터 전체 문제 모아보기</div>
            <div class="font-bold text-base">제<%= @chapter[:number] %>장 전체 문제 풀기 (<%= chapter_q_count %>문제)</div>
          </div>
        </div>
        <span class="material-symbols-outlined text-2xl text-white/70 group-hover:translate-x-1 transition-transform flex-shrink-0">arrow_forward</span>
      </a>

      <!-- 광고 슬롯 -->
      <div class="py-2 flex justify-center">
        <%= render 'shared/ad_slot', position: 'chapter-bottom' %>
      </div>

    </div>
  </div>

</div><%# /exam-tabs %>

<!-- 이전/다음 챕터 네비게이션 -->
<section class="bg-white border-t border-slate-200 py-4 px-4">
  <div class="max-w-4xl mx-auto grid grid-cols-2 gap-4">
    <div>
      <% if @prev_chapter %>
        <a href="<%= exam_subject_chapter_path(@subject[:id], @prev_chapter[:number]) %>"
           class="flex items-center gap-3 bg-slate-50 hover:bg-slate-100 rounded-xl border border-slate-200 px-4 py-3 transition-all h-full">
          <span class="material-symbols-outlined text-slate-400 flex-shrink-0">arrow_back</span>
          <div class="min-w-0">
            <div class="text-xs text-slate-400">이전 챕터</div>
            <div class="text-sm font-semibold text-slate-700 truncate">제<%= @prev_chapter[:number] %>장 <%= @prev_chapter[:title] %></div>
          </div>
        </a>
      <% else %>
        <a href="<%= exam_subject_path(@subject[:id]) %>"
           class="flex items-center gap-3 bg-slate-50 hover:bg-slate-100 rounded-xl border border-slate-200 px-4 py-3 transition-all">
          <span class="material-symbols-outlined text-slate-400 flex-shrink-0">arrow_back</span>
          <div>
            <div class="text-xs text-slate-400">과목 목록으로</div>
            <div class="text-sm font-semibold text-slate-700"><%= @subject[:number] %> <%= @subject[:title] %></div>
          </div>
        </a>
      <% end %>
    </div>
    <div class="flex justify-end">
      <% if @next_chapter %>
        <a href="<%= exam_subject_chapter_path(@subject[:id], @next_chapter[:number]) %>"
           class="flex items-center gap-3 bg-slate-50 hover:bg-slate-100 rounded-xl border border-slate-200 px-4 py-3 transition-all w-full">
          <div class="min-w-0 text-right flex-1">
            <div class="text-xs text-slate-400">다음 챕터</div>
            <div class="text-sm font-semibold text-slate-700 truncate">제<%= @next_chapter[:number] %>장 <%= @next_chapter[:title] %></div>
          </div>
          <span class="material-symbols-outlined text-slate-400 flex-shrink-0">arrow_forward</span>
        </a>
      <% else %>
        <% next_subject = ExamCurriculum.find_subject(@subject[:id] + 1) %>
        <% if next_subject %>
          <a href="<%= exam_subject_path(next_subject[:id]) %>"
             class="flex items-center gap-3 bg-slate-50 hover:bg-slate-100 rounded-xl border border-slate-200 px-4 py-3 transition-all w-full">
            <div class="min-w-0 text-right flex-1">
              <div class="text-xs text-slate-400">다음 과목으로</div>
              <div class="text-sm font-semibold text-slate-700"><%= next_subject[:number] %> <%= next_subject[:title] %></div>
            </div>
            <span class="material-symbols-outlined text-slate-400 flex-shrink-0">arrow_forward</span>
          </a>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

</div><%# /data-controller="exam-progress" %>
