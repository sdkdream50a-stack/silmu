<!-- Editorial Stats Bar -->
<section class="py-14 px-6" style="background:#f3f4f5">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
      <div class="space-y-2">
        <div class="text-5xl font-extrabold tracking-tighter" style="font-family:'Manrope',sans-serif;color:#002b57">1,500+</div>
        <div class="text-xs font-bold uppercase tracking-widest text-slate-400">예상 문제</div>
      </div>
      <div class="space-y-2">
        <div class="text-5xl font-extrabold tracking-tighter" style="font-family:'Manrope',sans-serif;color:#002b57">28장</div>
        <div class="text-xs font-bold uppercase tracking-widest text-slate-400">4권 전체 챕터</div>
      </div>
      <div class="space-y-2">
        <div class="text-5xl font-extrabold tracking-tighter" style="font-family:'Manrope',sans-serif;color:#002b57">무료</div>
        <div class="text-xs font-bold uppercase tracking-widest text-slate-400">커리큘럼 · 모의고사 · 용어집</div>
      </div>
    </div>
  </div>
</section>

<%# 광고 — 히어로 섹션 하단 %>
<div class="py-4 px-4 bg-white flex justify-center">
  <%= render 'shared/ad_slot', position: 'home-top' %>
</div>

<!-- 표준교재 PDF 다운로드 배너 -->
<section class="px-4 py-3 bg-white" style="border-bottom:1px solid #e7e8e9">
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
    <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-sm flex-shrink-0" style="color:#002b57">menu_book</span>
      <div>
        <div class="font-bold text-sm" style="color:#002b57">표준교재 4권 무료 PDF</div>
        <div class="text-xs text-slate-500">공공조달역량개발원 공식 발간 — 지금 바로 다운로드</div>
      </div>
    </div>
    <a href="https://www.pps.go.kr/kor/bbs/list.do?bbsSn=1044"
       target="_blank" rel="noopener"
       class="inline-flex items-center gap-2 text-white font-bold px-5 py-2 rounded-lg text-sm transition-all hover:opacity-90 whitespace-nowrap flex-shrink-0" style="background:linear-gradient(135deg,#002b57,#174174)">
      <span class="material-symbols-outlined text-base">download</span>
      무료 PDF 받기
    </a>
  </div>
</section>
