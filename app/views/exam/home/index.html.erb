<%# exam.silmu.kr 랜딩 페이지 — 공공조달관리사 시험 대비 %>

<!-- 1. Hero Section -->
<section class="bg-gradient-to-br from-blue-700 via-blue-600 to-indigo-700 text-white py-20 px-4"
         data-controller="exam-progress"
         data-exam-progress-signed-in-value="<%= user_signed_in? %>">
  <div class="max-w-4xl mx-auto text-center">
    <!-- 배지 -->
    <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white text-sm font-semibold px-4 py-2 rounded-full mb-6">
      <span class="material-symbols-outlined text-yellow-300 text-base">star</span>
      2026년 신설 국가기술자격 — 첫 시험 준비 중
    </div>

    <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
      공공조달관리사<br>
      <span class="text-yellow-300">2026 첫 시험</span> 대비
    </h1>
    <p class="text-xl text-blue-100 mb-4 max-w-2xl mx-auto">
      공공조달 분야 최초 국가기술자격 시험.<br>
      법령 가이드·감사사례로 지금 바로 준비하세요.
    </p>
    <p class="text-blue-200 text-sm mb-10">
      주관: 조달청·기재부 | 시행: 한국산업인력공단(Q-NET) | 자격 종류: 국가기술자격
    </p>

    <!-- 권장 학습 경로 — 첫 방문자 온보딩 -->
    <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-5 py-5 mb-6 max-w-2xl mx-auto text-left">
      <p class="text-blue-200 text-xs font-semibold uppercase tracking-wider mb-3 text-center">처음 오셨나요? 이 순서로 시작하세요</p>
      <div class="grid grid-cols-3 gap-3">
        <a href="<%= exam_subjects_path %>" class="group flex flex-col items-center gap-2 bg-white/10 hover:bg-white/20 rounded-xl px-3 py-3 transition-colors text-center">
          <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white font-black text-sm flex-shrink-0">1</div>
          <div>
            <div class="text-white font-bold text-sm">커리큘럼</div>
            <div class="text-blue-200 text-xs mt-0.5">4권 구조 파악</div>
          </div>
        </a>
        <a href="<%= exam_keywords_path %>" class="group flex flex-col items-center gap-2 bg-white/10 hover:bg-white/20 rounded-xl px-3 py-3 transition-colors text-center">
          <div class="w-8 h-8 bg-yellow-400 rounded-full flex items-center justify-center text-slate-900 font-black text-sm flex-shrink-0">2</div>
          <div>
            <div class="text-white font-bold text-sm">용어집</div>
            <div class="text-blue-200 text-xs mt-0.5">핵심 키워드 암기</div>
          </div>
        </a>
        <a href="<%= exam_quiz_index_path %>" class="group flex flex-col items-center gap-2 bg-white/10 hover:bg-white/20 rounded-xl px-3 py-3 transition-colors text-center">
          <div class="w-8 h-8 bg-emerald-400 rounded-full flex items-center justify-center text-slate-900 font-black text-sm flex-shrink-0">3</div>
          <div>
            <div class="text-white font-bold text-sm">모의고사</div>
            <div class="text-blue-200 text-xs mt-0.5">실전 점수 확인</div>
          </div>
        </a>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="<%= exam_subjects_path %>" class="inline-flex items-center gap-2 bg-white text-blue-700 font-bold px-8 py-4 rounded-xl hover:bg-blue-50 transition-colors shadow-lg text-lg">
        <span class="material-symbols-outlined">school</span>
        1단계: 커리큘럼 시작 →
      </a>
      <a href="<%= exam_quiz_index_path %>" class="inline-flex items-center gap-2 bg-yellow-400 text-slate-900 font-bold px-8 py-4 rounded-xl hover:bg-yellow-300 transition-colors shadow-lg text-lg">
        <span class="material-symbols-outlined">quiz</span>
        바로 모의고사 풀기
      </a>
    </div>

    <!-- 나의 학습 현황 (Stimulus가 진도 있을 때만 표시) -->
    <div data-exam-progress-target="statsArea" class="hidden mt-8"></div>

    <!-- 스트릭 (항상 표시 — JS가 내용 채움) -->
    <div data-exam-progress-target="streakArea" class="mt-4 max-w-sm mx-auto"></div>

    <!-- 일일 학습 목표 -->
    <div data-exam-progress-target="goalArea" class="max-w-sm mx-auto"></div>

    <!-- 통계 -->
    <div class="grid grid-cols-4 gap-6 mt-8 pt-8 border-t border-white/20 max-w-2xl mx-auto">
      <div class="text-center">
        <div class="text-3xl font-bold text-yellow-300">4권</div>
        <div class="text-blue-200 text-sm mt-1">표준교재</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-yellow-300">28장</div>
        <div class="text-blue-200 text-sm mt-1">전체 챕터</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-yellow-300">68개</div>
        <div class="text-blue-200 text-sm mt-1">법령 가이드</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-yellow-300">100건</div>
        <div class="text-blue-200 text-sm mt-1">감사사례</div>
      </div>
    </div>

    <!-- D-day 카운터 -->
    <div class="mt-8 pt-6 border-t border-white/20">
      <div id="dday-wrapper" class="inline-flex items-center gap-4 bg-white/15 backdrop-blur-sm rounded-2xl px-6 py-4">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-yellow-300 text-2xl">calendar_month</span>
          <div class="text-left">
            <div class="text-blue-200 text-xs">첫 시험 예상일 (2026.10.17 예정)</div>
            <div class="text-white font-bold text-sm">공공조달관리사 1회 시험</div>
          </div>
        </div>
        <div class="flex items-baseline gap-1">
          <span class="text-yellow-300 font-black text-4xl" id="dday-count">D-</span>
          <span id="dday-num" class="text-yellow-300 font-black text-4xl">...</span>
        </div>
      </div>
    </div>

    <script>
    (function() {
      var target = new Date('2026-10-17T09:00:00+09:00')
      var now = new Date()
      var diff = Math.ceil((target - now) / (1000 * 60 * 60 * 24))
      var countEl = document.getElementById('dday-count')
      var numEl = document.getElementById('dday-num')
      if (countEl && numEl) {
        if (diff > 0) {
          countEl.textContent = 'D-'
          numEl.textContent = diff
        } else if (diff === 0) {
          countEl.textContent = 'D-Day'
          numEl.textContent = ''
        } else {
          countEl.textContent = 'D+'
          numEl.textContent = Math.abs(diff)
        }
      }
    })()
    </script>
  </div>
</section>

<%# 광고 — 히어로 섹션 하단 %>
<div class="py-4 px-4 bg-white flex justify-center">
  <%= render 'shared/ad_slot', position: 'home-top' %>
</div>

<!-- 2. 시험 정보 -->
