        { vol: "1과목", title: "법제도의 이해", pct: 37, color_bar: "bg-emerald-500", color_text: "text-emerald-600", color_bg: "bg-emerald-50", color_border: "border-emerald-200", questions: "30문항", focus: "계약법·조달사업법·나라장터" },
        { vol: "2과목", title: "조달계획 수립 및 분석", pct: 25, color_bar: "bg-blue-500", color_text: "text-blue-600", color_bg: "bg-blue-50", color_border: "border-blue-200", questions: "20문항", focus: "수요·공급 분석·예정가격 산정" },
