<%# 실기 대비 — Stitch 'The Intellectual Sanctuary' 디자인 적용 %>

<!-- 히어로 — deep blue gradient -->
<section class="bg-gradient-to-br from-[#0c2340] to-[#0d3b6e] text-white py-14 px-4 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-72 h-72 bg-white/5 rounded-full -mr-36 -mt-36 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full -ml-24 -mb-24 pointer-events-none"></div>
  <div class="max-w-3xl mx-auto relative z-10">
    <div class="flex items-center gap-1.5 text-white/50 text-xs mb-5 flex-wrap">
      <a href="https://exam.silmu.kr" class="hover:text-white/80 transition-colors">홈</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <span class="text-white/80 font-medium">실기 대비</span>
    </div>
    <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 mb-5">
      <span class="material-symbols-outlined text-[#ffd166] text-base">edit_note</span>
      <span class="text-white/90 text-xs font-semibold">실기 필답형 예상문제</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-extrabold leading-snug mb-3 tracking-tight text-[#f6f7ff]">실기 대비 — 필답형 예상문제</h1>
    <p class="text-[#c8d6f5] text-base max-w-2xl">PBT 필답형 150분 · 총 5문제 · 모범 답안 제공</p>
  </div>
</section>

<!-- 본문 -->
<section class="py-8 px-4 bg-[#f8f9ff] min-h-[60vh]">
  <div class="max-w-3xl mx-auto">

    <!-- 실기 시험 안내 -->
    <div class="bg-[#eff4ff] rounded-2xl p-5 mb-6">
      <p class="font-bold text-[#05345c] mb-2 flex items-center gap-2 text-sm">
        <span class="material-symbols-outlined text-[#006499] text-base">info</span>
        실기 시험 안내
      </p>
      <ul class="space-y-1 text-[#3d618c] text-xs">
        <li>• 시험 형식: 필답형(PBT) — 서술식 답안 작성</li>
        <li>• 시험 시간: 150분</li>
        <li>• 합격 기준: 총점의 60% 이상 (과락 없음)</li>
        <li>• 학습 방법: 키워드 힌트로 답안 구조를 파악한 후 모범 답안과 비교하세요.</li>
      </ul>
    </div>

    <!-- 총점 안내 -->
    <div class="flex items-center justify-between mb-6 bg-white rounded-xl shadow-[0_12px_40px_rgba(5,52,92,0.06)] px-5 py-4">
      <span class="text-sm text-[#3d618c] font-medium">총 5문제</span>
      <span class="text-sm font-bold text-[#05345c]">
        총 배점: <span class="text-[#006499]"><%= @questions.sum { |q| q[:point] } %>점</span>
      </span>
    </div>

    <!-- 문제 목록 -->
    <div class="space-y-6">
      <% @questions.each do |q| %>
        <div class="bg-white rounded-2xl shadow-[0_12px_40px_rgba(5,52,92,0.06)] overflow-hidden hover:shadow-[0_16px_48px_rgba(5,52,92,0.1)] transition-shadow"
             data-practical-id="<%= q[:id] %>">
          <!-- 문제 헤더 -->
          <div class="flex items-start gap-4 p-6">
            <div class="flex-shrink-0">
              <div class="w-10 h-10 bg-[#006499] rounded-xl flex items-center justify-center">
                <span class="text-white font-extrabold text-sm"><%= q[:id] %></span>
              </div>
            </div>
            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="bg-[#d4e4f6] text-[#445362] text-[11px] font-bold tracking-widest uppercase px-3 py-1 rounded-full"><%= q[:category] %></span>
                <span class="bg-[#eff4ff] text-[#3d618c] text-xs font-bold px-2.5 py-1 rounded-full"><%= q[:point] %>점</span>
                <!-- 자기 채점 체크박스 -->
                <label class="flex items-center gap-1.5 cursor-pointer ml-auto">
                  <input type="checkbox"
                         class="practical-done-check w-4 h-4 accent-[#006499] cursor-pointer"
                         data-question-id="<%= q[:id] %>"
                         onchange="savePracticalDone(this)">
                  <span class="text-xs text-[#3d618c] font-medium">학습 완료</span>
                </label>
              </div>
              <p class="text-[#05345c] font-semibold leading-relaxed"><%= q[:question] %></p>
            </div>
          </div>

          <!-- 키워드 힌트 -->
          <div class="border-t border-[#eff4ff]">
            <button class="w-full flex items-center justify-between px-6 py-3.5 text-left hover:bg-[#f8f9ff] transition-colors"
                    onclick="toggleSection(this, 'hint-<%= q[:id] %>')">
              <span class="flex items-center gap-2 text-sm font-semibold text-amber-700">
                <span class="material-symbols-outlined text-base">tips_and_updates</span>
                핵심 키워드 힌트
              </span>
              <span class="material-symbols-outlined text-[#3d618c] expand-icon">expand_more</span>
            </button>
            <div id="hint-<%= q[:id] %>" class="hidden px-6 pb-4">
              <div class="flex flex-wrap gap-2">
                <% q[:keywords].each do |kw| %>
                  <span class="bg-amber-50 text-amber-800 text-xs font-semibold px-3 py-1.5 rounded-full"><%= kw %></span>
                <% end %>
              </div>
              <p class="text-xs text-[#3d618c] mt-2"><%= q[:answer_hint] %></p>
            </div>
          </div>

          <!-- 모범 답안 -->
          <div class="border-t border-[#eff4ff]">
            <button class="w-full flex items-center justify-between px-6 py-3.5 text-left hover:bg-[#f8f9ff] transition-colors"
                    onclick="toggleSection(this, 'answer-<%= q[:id] %>')">
              <span class="flex items-center gap-2 text-sm font-bold text-[#006499]">
                <span class="material-symbols-outlined text-base">assignment_turned_in</span>
                모범 답안 보기
              </span>
              <span class="material-symbols-outlined text-[#3d618c] expand-icon">expand_more</span>
            </button>
            <div id="answer-<%= q[:id] %>" class="hidden px-6 pb-5">
              <div class="bg-[#eff4ff] rounded-xl p-4">
                <pre class="text-sm text-[#05345c] leading-relaxed whitespace-pre-wrap font-sans"><%= q[:model_answer] %></pre>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 이동 버튼 -->
    <div class="mt-8 flex gap-3">
      <a href="<%= exam_quiz_simulation_path %>" class="flex-1 inline-flex items-center justify-center gap-2 bg-gradient-to-br from-[#006499] to-[#005886] hover:opacity-90 text-white font-bold px-4 py-3 rounded-full transition-all text-sm shadow-[0_4px_16px_rgba(0,100,153,0.25)]">
        <span class="material-symbols-outlined text-base">timer</span>
        실전 모의고사
      </a>
      <a href="<%= exam_subjects_path %>" class="flex-1 inline-flex items-center justify-center gap-2 bg-[#eff4ff] hover:bg-[#dce9ff] text-[#006499] font-bold px-4 py-3 rounded-full transition-colors text-sm">
        <span class="material-symbols-outlined text-base">school</span>
        이론 학습
      </a>
    </div>

  </div>
</section>

<script>
// 섹션 토글 (힌트/모범 답안)
function toggleSection(btn, sectionId) {
  const section = document.getElementById(sectionId)
  const icon = btn.querySelector('.expand-icon')
  if (!section) return
  const isHidden = section.classList.contains('hidden')
  section.classList.toggle('hidden', !isHidden)
  if (icon) icon.textContent = isHidden ? 'expand_less' : 'expand_more'
}

// 자기 채점 체크박스 저장 (localStorage)
function savePracticalDone(checkbox) {
  const qId = checkbox.dataset.questionId
  const done = JSON.parse(localStorage.getItem('exam_practical_done') || '[]')
  if (checkbox.checked) {
    if (!done.includes(qId)) done.push(qId)
  } else {
    const idx = done.indexOf(qId)
    if (idx > -1) done.splice(idx, 1)
  }
  localStorage.setItem('exam_practical_done', JSON.stringify(done))
}

// 페이지 로드 시 체크박스 상태 복원
document.addEventListener('DOMContentLoaded', function() {
  const done = JSON.parse(localStorage.getItem('exam_practical_done') || '[]')
  document.querySelectorAll('.practical-done-check').forEach(function(cb) {
    if (done.includes(cb.dataset.questionId)) {
      cb.checked = true
      const card = cb.closest('[data-practical-id]')
      if (card) card.classList.add('ring-2', 'ring-[#51b0f6]')
    }
    cb.addEventListener('change', function() {
      const card = cb.closest('[data-practical-id]')
      if (card) card.classList.toggle('ring-2', cb.checked)
      if (card) card.classList.toggle('ring-[#51b0f6]', cb.checked)
    })
  })
})
</script>
