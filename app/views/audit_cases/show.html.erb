<%# 감사사례 상세 페이지 %>

<%= content_for :head do %>
  <%# 인포그래픽 이미지 preload — LCP 요소 조기 로드 %>
  <% if @audit_case.infographic_url.present? %>
    <link rel="preload" href="<%= @audit_case.infographic_url %>" as="image" fetchpriority="high">
  <% end %>
  <%= json_ld({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": @audit_case.title,
    "description": @audit_case.issue.truncate(200),
    "author": { "@type": "Organization", "name": "실무.kr" },
    "publisher": { "@type": "Organization", "name": "실무.kr", "logo": { "@type": "ImageObject", "url": "https://silmu.kr/icon.png" } },
    "datePublished": @audit_case.created_at.iso8601,
    "dateModified": @audit_case.updated_at.iso8601,
    "mainEntityOfPage": canonical_url,
    "url": canonical_url,
    "image": "https://silmu.kr/og-image.webp",
    "inLanguage": "ko",
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [ "h1", "#section-finding", "#section-lesson" ]
    }
  }) %>
  <%= json_ld({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "홈", "item": "https://silmu.kr" },
      { "@type": "ListItem", "position": 2, "name": "감사사례", "item": "https://silmu.kr/audit-cases" },
      { "@type": "ListItem", "position": 3, "name": @audit_case.title, "item": canonical_url }
    ]
  }) %>
<% end %>

<!-- 브레드크럼 -->
<div class="bg-surface-50 border-b border-gray-100">
  <div class="container-wide py-3">
    <nav class="flex items-center gap-2 text-sm text-slate-500">
      <%= link_to "홈", root_path, class: "hover:text-slate-800 transition-colors" %>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <%= link_to "감사사례", audit_cases_path, class: "hover:text-slate-800 transition-colors" %>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <span class="text-slate-800 font-medium truncate"><%= @audit_case.title %></span>
    </nav>
  </div>
</div>

<section class="section py-10">
  <div class="container-wide">
    <div class="lg:flex lg:gap-10">
      <!-- 메인 콘텐츠 -->
      <div class="lg:w-[70%]">
        <!-- 헤더 -->
        <div class="mb-8">
          <div class="flex items-center gap-2 mb-4 flex-wrap">
            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-gray-100 text-slate-600"><%= @audit_case.category %></span>
            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-gray-100 text-slate-600"><%= @audit_case.severity %></span>
            <% if @audit_case.repeated_issue? %>
              <span class="inline-flex items-center gap-0.5 px-2.5 py-1 rounded-md text-xs font-bold bg-red-600 text-white">
                <span class="material-symbols-outlined text-xs leading-none">loop</span>반복 지적 사례
              </span>
            <% end %>
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-xs font-medium text-slate-500" title="누적 열람 횟수">
              <span class="material-symbols-outlined text-xs leading-none">visibility</span>
              <%= number_with_delimiter(@audit_case.view_count) %>회
            </span>
          </div>
          <h1 class="text-xl lg:text-2xl font-bold text-slate-900 mb-2"><%= @audit_case.title %></h1>
          <div class="flex items-center gap-3 flex-wrap">
            <%= render 'shared/social_share',
                  title: @audit_case.title,
                  url: audit_case_url(@audit_case.slug),
                  description: @audit_case.issue.truncate(100) %>
            <%= bookmark_button(@audit_case) %>
            <%= link_to audit_case_hwp_path(slug: @audit_case.slug),
                  class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold bg-teal-50 text-teal-700 hover:bg-teal-100 border border-teal-200 transition-colors",
                  title: "한글(HWP) 파일로 다운로드" do %>
              <span class="material-symbols-outlined text-sm">download</span>
              HWP 다운로드
            <% end %>
          </div>
        </div>

        <!-- 핵심 요약 인포그래픽 (LCP 후보 — eager 로딩 + fetchpriority) -->
        <% if @audit_case.infographic_url.present? %>
          <% webp_url = @audit_case.infographic_url.sub(/\.png$/, '.webp') %>
          <div class="mb-6">
            <picture>
              <source srcset="<%= webp_url %>" type="image/webp">
              <img src="<%= @audit_case.infographic_url %>"
                   alt="<%= @audit_case.title %> 핵심 요약 인포그래픽"
                   width="800" height="600"
                   loading="eager"
                   fetchpriority="high"
                   decoding="async"
                   class="w-full rounded-2xl shadow-md border border-slate-100">
            </picture>
          </div>
        <% end %>

        <!-- 핵심 정보 카드 (fragment cache — 콘텐츠 변경 시 updated_at으로 자동 무효화) -->
        <% cache ["audit_case/content/v1", @audit_case.id, @audit_case.updated_at, @related_topic&.id], expires_in: 1.hour do %>
        <div class="space-y-4 mb-8">
          <!-- 지적사항 -->
          <div id="section-finding" class="bg-white border border-gray-200 rounded-xl p-5 lg:p-6">
            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide flex items-center gap-1.5 mb-3">
              <span class="w-1.5 h-1.5 rounded-full bg-red-400 shrink-0"></span>
              지적사항
            </h2>
            <div class="text-sm text-slate-700 leading-relaxed"><%= simple_format(@audit_case.issue) %></div>
            <div class="mt-3 flex items-center gap-3 text-xs text-slate-500">
              <span>심각도: <strong class="text-slate-700"><%= @audit_case.severity %></strong></span>
              <span class="text-gray-300">|</span>
              <span>분야: <strong class="text-slate-700"><%= @audit_case.category %></strong></span>
            </div>
          </div>

          <!-- 관련근거 -->
          <div id="section-law" class="bg-white border border-gray-200 rounded-xl p-5 lg:p-6">
            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide flex items-center gap-1.5 mb-3">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-400 shrink-0"></span>
              관련근거
            </h2>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-slate-400 mt-0.5 flex-shrink-0 text-base">gavel</span>
              <div>
                <p class="text-sm text-slate-700 leading-relaxed"><%= @audit_case.legal_basis %></p>
                <% if @audit_case.topic_slug.present? && @related_topic %>
                  <%= link_to topic_path(@related_topic.slug), class: "inline-flex items-center gap-1.5 mt-3 px-3 py-1.5 bg-slate-900 hover:bg-slate-700 text-white text-xs font-semibold rounded-lg transition-colors" do %>
                    <span class="material-symbols-outlined text-xs">menu_book</span>
                    해당 법령 가이드 보기
                    <span class="material-symbols-outlined text-xs">arrow_forward</span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>

          <!-- 조치내용 -->
          <div id="section-improvement" class="bg-white border border-gray-200 rounded-xl p-5 lg:p-6">
            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide flex items-center gap-1.5 mb-3">
              <span class="w-1.5 h-1.5 rounded-full bg-slate-400 shrink-0"></span>
              조치내용
            </h2>
            <div class="text-sm text-slate-700 leading-relaxed space-y-2">
              <% @audit_case.action_taken.to_s.split(',').map(&:strip).reject(&:blank?).each do |action| %>
                <div class="flex items-start gap-2">
                  <span class="material-symbols-outlined text-slate-400 text-sm mt-0.5 flex-shrink-0">check_circle</span>
                  <span><%= action %></span>
                </div>
              <% end %>
            </div>
          </div>

          <!-- 교훈/시사점 -->
          <div id="section-lesson" class="bg-white border border-gray-200 rounded-xl p-5 lg:p-6">
            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide flex items-center gap-1.5 mb-3">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400 shrink-0"></span>
              교훈 및 시사점
            </h2>
            <div class="text-sm text-slate-700 leading-relaxed audit-content"><%= simple_markdown(@audit_case.lesson) %></div>
          </div>

          <!-- 실무 체크포인트 -->
          <% checkpoints = @audit_case.checkpoint_list %>
          <% if checkpoints.any? %>
            <div id="section-checkpoint" class="bg-white border border-gray-200 rounded-xl p-5 lg:p-6">
              <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide flex items-center gap-1.5 mb-4">
                <span class="w-1.5 h-1.5 rounded-full bg-slate-400 shrink-0"></span>
                실무 체크포인트
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                <% checkpoints.each do |cp| %>
                  <% if cp.is_a?(Hash) %>
                    <div class="flex items-start gap-2 p-3 bg-gray-50 rounded-lg text-sm">
                      <span class="material-symbols-outlined text-slate-400 text-base flex-shrink-0"><%= cp["icon"] %></span>
                      <div>
                        <span class="font-semibold text-slate-800"><%= cp["title"] %></span>
                        <p class="text-xs text-slate-500 mt-0.5"><%= cp["desc"] %></p>
                      </div>
                    </div>
                  <% else %>
                    <div class="flex items-start gap-2 p-3 bg-gray-50 rounded-lg text-sm">
                      <span class="material-symbols-outlined text-slate-400 text-base flex-shrink-0">check_circle</span>
                      <span class="text-slate-700"><%= cp %></span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>

          <!-- 상세 내용 (있을 경우) -->
          <% if @audit_case.detail.present? %>
            <div id="section-detail" class="bg-white border border-gray-200 rounded-xl p-5 lg:p-6">
              <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide flex items-center gap-1.5 mb-4">
                <span class="w-1.5 h-1.5 rounded-full bg-slate-400 shrink-0"></span>
                상세 분석
              </h2>
              <div class="text-sm text-slate-700 leading-relaxed audit-content">
                <%= simple_markdown(@audit_case.detail) %>
              </div>
            </div>
          <% end %>
        </div>
        <% end %>

        <!-- 관련 토픽 -->
        <% if @related_topic %>
          <%= link_to topic_path(@related_topic.slug), class: "flex items-center gap-4 bg-white border border-gray-200 hover:border-slate-400 rounded-xl p-5 mb-8 group transition-colors" do %>
            <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-slate-200 transition-colors">
              <span class="material-symbols-outlined text-slate-600 text-base">menu_book</span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs text-slate-400 mb-0.5">관련 법령 가이드</p>
              <span class="font-semibold text-slate-900 group-hover:text-slate-700 transition-colors"><%= @related_topic.name %></span>
              <p class="text-xs text-slate-500 mt-0.5 truncate"><%= @related_topic.summary.truncate(60) %></p>
            </div>
            <span class="material-symbols-outlined text-slate-300 shrink-0 group-hover:translate-x-1 transition-transform">arrow_forward</span>
          <% end %>
        <% end %>

        <!-- 유사 감사사례 추천 -->
        <% if @related_cases.present? && @related_cases.length > 0 %>
          <div class="mt-10 pt-8 border-t border-gray-200">
            <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-editorial-navy">auto_awesome</span>
              유사 감사사례
            </h2>
            <div class="grid gap-4 sm:grid-cols-2">
              <% @related_cases.first(4).each do |ac| %>
                <%= link_to audit_case_path(slug: ac.slug), class: "group block p-4 bg-white rounded-xl border border-gray-200 hover:border-editorial-navy-light hover:shadow-md transition-all" do %>
                  <div class="flex items-start gap-3">
                    <div class="shrink-0 w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center">
                      <span class="material-symbols-outlined text-sm text-red-500">gavel</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-semibold text-slate-800 text-sm leading-snug group-hover:text-editorial-navy-dark transition-colors line-clamp-2"><%= ac.title %></p>
                      <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                        <span class="text-xs text-slate-400"><%= ac.category %></span>
                        <% if ac.severity.present? %>
                          <span class="text-xs px-1.5 py-0.5 bg-red-50 text-red-600 rounded"><%= ac.severity %></span>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>

            <%= link_to audit_cases_path(category: @audit_case.category), class: "mt-4 inline-flex items-center gap-1.5 text-sm text-editorial-navy hover:text-editorial-navy-dark font-medium transition-colors" do %>
              <%= @audit_case.category %> 카테고리 전체 보기
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- 사이드바 -->
      <div class="lg:w-[30%] mt-10 lg:mt-0">
        <div class="sticky top-24 space-y-6">
          <!-- 목차 (TOC) -->
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="font-bold text-gray-900 mb-3 text-sm flex items-center gap-1.5">
              <span class="material-symbols-outlined text-sm text-editorial-navy">list</span>
              목차
            </h3>
            <nav class="space-y-0.5 text-sm" id="toc-nav">
              <a href="#section-finding" class="toc-link block py-1.5 px-2 rounded-lg text-gray-600 hover:bg-editorial-navy-bg hover:text-editorial-navy-dark transition-colors">지적사항</a>
              <a href="#section-law" class="toc-link block py-1.5 px-2 rounded-lg text-gray-600 hover:bg-editorial-navy-bg hover:text-editorial-navy-dark transition-colors">관련근거</a>
              <a href="#section-improvement" class="toc-link block py-1.5 px-2 rounded-lg text-gray-600 hover:bg-editorial-navy-bg hover:text-editorial-navy-dark transition-colors">조치내용</a>
              <a href="#section-lesson" class="toc-link block py-1.5 px-2 rounded-lg text-gray-600 hover:bg-editorial-navy-bg hover:text-editorial-navy-dark transition-colors">교훈 및 시사점</a>
              <% if @audit_case.checkpoint_list.any? %>
                <a href="#section-checkpoint" class="toc-link block py-1.5 px-2 rounded-lg text-gray-600 hover:bg-editorial-navy-bg hover:text-editorial-navy-dark transition-colors">실무 체크포인트</a>
              <% end %>
              <% if @audit_case.detail.present? %>
                <a href="#section-detail" class="toc-link block py-1.5 px-2 rounded-lg text-gray-600 hover:bg-editorial-navy-bg hover:text-editorial-navy-dark transition-colors">상세 분석</a>
              <% end %>
            </nav>
          </div>

          <!-- 돌아가기 -->
          <%= link_to audit_cases_path, class: "flex items-center gap-2 text-slate-600 hover:text-slate-900 font-medium transition-colors" do %>
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            감사사례 목록으로
          <% end %>

          <!-- 이 사례 요약 -->
          <div class="card p-6">
            <h3 class="font-bold text-slate-900 mb-4">사례 요약</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-slate-500">분야</dt>
                <dd class="font-semibold text-slate-800"><%= @audit_case.category %></dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-slate-500">심각도</dt>
                <dd class="font-semibold text-<%= @audit_case.severity_color %>-700"><%= @audit_case.severity %></dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-slate-500">관련근거</dt>
                <dd class="font-semibold text-slate-800 text-right max-w-[60%]"><%= @audit_case.legal_basis %></dd>
              </div>
            </dl>
          </div>

          <!-- AI 상담 -->
          <div class="bg-slate-900 rounded-xl p-5 text-white">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center">
                <span class="material-symbols-outlined text-lg">support_agent</span>
              </div>
              <div>
                <h3 class="font-semibold text-sm">감사 대비 상담</h3>
                <p class="text-slate-400 text-xs">AI에게 물어보세요</p>
              </div>
            </div>
            <%= link_to silmu_search_path, class: "block w-full py-2.5 bg-white text-slate-900 rounded-lg text-sm font-semibold text-center hover:bg-slate-100 transition-colors" do %>
              실무 검색으로 찾기
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%= render 'shared/recent_items',
      title: @audit_case.title,
      url: audit_case_path(@audit_case.slug),
      type: 'audit_case' %>

<script>
  (function() {
    // 스크롤 위치에 따른 TOC 활성 항목 하이라이트
    const sections = document.querySelectorAll('[id^="section-"]');
    const tocLinks = document.querySelectorAll('.toc-link');

    if (!sections.length || !tocLinks.length) return;

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          tocLinks.forEach(function(link) {
            link.classList.remove('bg-editorial-navy-bg', 'text-editorial-navy-dark', 'font-medium');
          });
          const activeLink = document.querySelector('.toc-link[href="#' + entry.target.id + '"]');
          if (activeLink) {
            activeLink.classList.add('bg-editorial-navy-bg', 'text-editorial-navy-dark', 'font-medium');
          }
        }
      });
    }, { rootMargin: '-20% 0px -60% 0px' });

    sections.forEach(function(s) { observer.observe(s); });
  })();
</script>
