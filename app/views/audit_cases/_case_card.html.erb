<% _above_fold = local_assigns[:above_fold] %>
<%= link_to audit_case_path(slug: audit_case.slug), class: "block card card-hover p-6 group case-item", style: (_above_fold ? nil : "content-visibility:auto; contain-intrinsic-size:auto 180px"), data: { title: audit_case.title.downcase, issue: audit_case.issue.truncate(100).downcase, severity: audit_case.severity } do %>
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-1.5 flex-wrap">
      <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-red-50 text-red-700"><%= audit_case.category %></span>
      <% if (year = audit_case.publication_year) %>
        <% recent = year >= 2024 %>
        <span class="inline-flex items-center gap-0.5 px-2 py-1 rounded-lg text-[11px] font-semibold <%= recent ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-slate-100 text-slate-500' %>" title="감사 발간 연도">
          <%= year %><% if recent %><span class="ml-0.5 text-[9px] font-bold tracking-wide">최신</span><% end %>
        </span>
      <% end %>
    </div>
    <div class="flex items-center gap-1.5">
      <% if audit_case.repeated_issue? %>
        <span class="inline-flex items-center gap-0.5 px-2 py-1 rounded-lg text-xs font-bold bg-red-600 text-white">
          <span class="material-symbols-outlined text-xs leading-none">loop</span>반복지적
        </span>
      <% end %>
      <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium
        <%= case audit_case.severity
            when '경미' then 'bg-amber-50 text-amber-700'
            when '보통' then 'bg-orange-50 text-orange-700'
            when '중대' then 'bg-red-100 text-red-800'
            else 'bg-gray-50 text-gray-600'
            end %>">
        <%= audit_case.severity %>
      </span>
    </div>
  </div>
  <h3 class="text-base font-semibold text-slate-900 mb-2 group-hover:text-red-600 transition-colors"><%= audit_case.title %></h3>
  <p class="text-slate-600 text-sm mb-3 leading-relaxed line-clamp-2"><%= audit_case.issue.truncate(120) %></p>
  <div class="flex items-center gap-4 text-xs text-slate-400">
    <span class="flex items-center gap-1">
      <span class="material-symbols-outlined text-sm">menu_book</span>
      <cite class="legal-cite"><%= audit_case.legal_basis %></cite>
    </span>
    <% if audit_case.topic_slug.present? %>
      <span class="flex items-center gap-1">
        <span class="material-symbols-outlined text-sm">link</span>
        관련 토픽
      </span>
    <% end %>
  </div>
<% end %>
