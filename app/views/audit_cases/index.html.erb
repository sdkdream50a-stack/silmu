<%# 감사사례 목록 페이지 %>

<%= content_for :head do %>
  <%= json_ld({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "감사사례 모음",
    "description": "공공계약 감사에서 자주 지적되는 사례를 카테고리별로 정리",
    "url": request.original_url,
    "publisher": { "@type": "Organization", "name": "실무.kr" }
  }) %>
<% end %>

<!-- 페이지 헤더 — Editorial Deep Burgundy (로우키 경고 톤) -->
<section class="text-white py-12 lg:py-16 relative overflow-hidden"
         style="background-image: linear-gradient(180deg, #4A1F1F 0%, #6B2A2A 100%);">
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/4"></div>
  <div class="container-wide relative z-10">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div class="flex items-start gap-5">
        <div class="w-16 h-16 bg-white/10 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/20 shadow-lg">
          <span class="material-symbols-outlined text-4xl text-white">gavel</span>
        </div>
        <div>
          <h1 class="text-2xl font-bold tracking-tight mb-2">감사사례</h1>
          <p class="text-white/85 text-lg">계약 실무에서 자주 지적되는 감사 사례와 대응 방법</p>
        </div>
      </div>
      <div class="flex gap-4 lg:gap-6">
        <div class="text-center px-4 py-2 bg-white/10 rounded-xl border border-white/15">
          <div class="text-2xl font-bold"><%= @total_count %></div>
          <div class="text-xs text-white/80 mt-0.5">전체 사례</div>
        </div>
        <div class="text-center px-4 py-2 bg-white/10 rounded-xl border border-white/15">
          <div class="text-2xl font-bold"><%= @categories.size %></div>
          <div class="text-xs text-white/80 mt-0.5">분야</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 카테고리 필터 및 검색 -->
<%# backdrop-blur 제거 — GPU 부하 경감 + LCP 개선 %>
<section class="bg-white/95 border-b border-gray-100 sticky top-16 z-40 shadow-soft">
  <div class="container-wide py-4">
    <!-- 검색창 (서버사이드 처리, 400ms debounce) -->
    <div class="mb-4">
      <%= form_with url: audit_cases_path, method: :get, data: { turbo_action: "replace" }, id: "search-form" do |f| %>
        <%= f.hidden_field :category, value: @category %>
        <%= f.hidden_field :severity, value: @severity %>
        <div class="relative max-w-md">
          <%= f.text_field :q,
              value: @search,
              placeholder: "사례 제목 또는 내용 검색...",
              aria: { label: "감사사례 검색" },
              class: "w-full px-5 py-3 pl-12 pr-4 bg-white border-2 border-gray-200 rounded-xl text-sm focus:border-[#7A3333] focus:ring-0 transition-colors",
              autocomplete: "off",
              oninput: "clearTimeout(window._st);window._st=setTimeout(()=>document.getElementById('search-form').requestSubmit(),400)" %>
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">search</span>
        </div>
      <% end %>
    </div>

    <!-- 카테고리 탭 & 심각도 필터 -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3">
      <div class="flex flex-wrap gap-2" id="category-tabs">
        <%= link_to "전체", audit_cases_path(severity: @severity, q: @search),
            class: "tab-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all #{@category.blank? ? 'bg-[#6B2A2A] text-white shadow-md' : 'bg-surface-100 text-slate-600 hover:bg-surface-200'}" %>
        <% @categories.each do |cat| %>
          <%= link_to cat, audit_cases_path(category: cat, severity: @severity, q: @search),
              class: "tab-btn px-5 py-2.5 rounded-xl text-sm font-medium transition-all #{@category == cat ? 'bg-[#6B2A2A] text-white shadow-md' : 'bg-surface-100 text-slate-600 hover:bg-surface-200'}" %>
        <% end %>
      </div>

      <!-- 심각도 필터 — 모바일에서만 표시 (데스크탑은 사이드바 필터 사용) -->
      <div class="flex gap-2 lg:hidden">
        <%= link_to "전체", audit_cases_path(category: @category, q: @search),
            class: "px-4 py-2 rounded-lg text-xs font-semibold transition-all #{@severity.blank? ? 'bg-gray-200 text-gray-800' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
        <%= link_to "중대", audit_cases_path(category: @category, severity: "중대", q: @search),
            class: "px-4 py-2 rounded-lg text-xs font-semibold transition-all #{@severity == '중대' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-700 hover:bg-red-100'}" %>
        <%= link_to "보통", audit_cases_path(category: @category, severity: "보통", q: @search),
            class: "px-4 py-2 rounded-lg text-xs font-semibold transition-all #{@severity == '보통' ? 'bg-orange-500 text-white' : 'bg-orange-50 text-orange-700 hover:bg-orange-100'}" %>
        <%= link_to "경미", audit_cases_path(category: @category, severity: "경미", q: @search),
            class: "px-4 py-2 rounded-lg text-xs font-semibold transition-all #{@severity == '경미' ? 'bg-amber-500 text-white' : 'bg-amber-50 text-amber-700 hover:bg-amber-100'}" %>
      </div>
    </div>
  </div>
</section>

<section class="section py-10">
  <div class="container-wide">
    <div class="lg:flex lg:gap-10">
      <!-- 메인 콘텐츠 -->
      <div class="lg:w-[70%]">
        <div class="flex items-center justify-between mb-6">
          <p class="text-slate-600">
            <% if @category.present? %>
              <span class="font-bold text-slate-900"><%= @category %></span> 분야
            <% end %>
            <% if @search.present? %>
              "<span class="font-bold text-slate-900"><%= @search %></span>" 검색
            <% end %>
            총 <span class="font-bold text-slate-900"><%= @filtered_count %></span>개 사례
          </p>
        </div>

        <% if @audit_cases.any? %>
          <%# 초기 로드 시 PER_PAGE개만 렌더링 + Turbo Frame lazy loading으로 나머지 로드 %>
          <div class="space-y-4" id="cases-container">
            <% @audit_cases.each_with_index do |audit_case, idx| %>
              <%= render "case_card", audit_case: audit_case, above_fold: idx < 4 %>
            <% end %>
          </div>

          <%# 다음 페이지 Turbo Frame — 뷰포트 진입 시 자동 로드 (lazy) %>
          <% if @has_more %>
            <%= turbo_frame_tag "audit-cases-page",
                src: audit_cases_path(page: @next_page, category: @category, severity: @severity, q: @search),
                loading: :lazy do %>
              <%= render "next_page_loader" %>
            <% end %>
          <% end %>
        <% else %>
          <div class="text-center py-16">
            <span class="material-symbols-outlined text-6xl text-slate-200 mb-4">search_off</span>
            <% if @search.present? %>
              <p class="text-slate-500 text-lg font-semibold mb-2">"<%= @search %>" 검색 결과가 없습니다</p>
              <p class="text-slate-400 text-sm">다른 검색어나 필터를 시도해보세요</p>
            <% elsif @category.present? || @severity.present? %>
              <p class="text-slate-500 text-lg font-semibold mb-2">선택한 분야·심각도 조합의 사례가 없습니다</p>
              <p class="text-slate-400 text-sm">다른 분야나 심각도를 선택해보세요</p>
            <% else %>
              <p class="text-slate-500 text-lg">감사사례가 없습니다.</p>
            <% end %>
            <%= link_to "전체 보기", audit_cases_path, class: "inline-block mt-4 px-5 py-2.5 bg-[#6B2A2A] text-white rounded-lg hover:bg-[#4A1F1F] transition-colors font-semibold" %>
          </div>
        <% end %>
      </div>

      <!-- 사이드바 -->
      <div class="lg:w-[30%] mt-10 lg:mt-0">
        <div class="sticky top-36 space-y-6">
          <!-- 심각도 필터 (서버사이드 링크) -->
          <div class="card p-6">
            <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-red-500">warning</span>
              심각도별 보기
            </h3>
            <div class="space-y-2">
              <% [
                [nil,   "전체 보기",  "모든 심각도",       "hover:bg-slate-50",  "bg-slate-400", "group-hover:text-slate-600"],
                ["중대", "중대",       "해임·파면·계약취소 등", "hover:bg-red-50",    "bg-red-500",   "group-hover:text-red-700"],
                ["보통", "보통",       "경고·주의·시정 등",   "hover:bg-orange-50", "bg-orange-500","group-hover:text-orange-700"],
                ["경미", "경미",       "주의·개선권고 등",    "hover:bg-amber-50",  "bg-amber-500", "group-hover:text-amber-700"]
              ].each do |sev_val, label, desc, hover_bg, dot_bg, hover_text| %>
                <% active = sev_val.nil? ? @severity.blank? : @severity == sev_val %>
                <% path = sev_val ? audit_cases_path(category: @category, severity: sev_val, q: @search) : audit_cases_path(category: @category, q: @search) %>
                <%= link_to path, class: "w-full flex items-center gap-3 p-3 rounded-xl #{active ? 'bg-slate-100' : hover_bg} transition-colors group text-left" do %>
                  <span class="w-3 h-3 rounded-full <%= dot_bg %>"></span>
                  <div>
                    <span class="text-sm font-semibold <%= active ? 'text-slate-900' : "text-slate-800 #{hover_text}" %>"><%= label %></span>
                    <p class="text-xs text-slate-400"><%= desc %></p>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>

          <!-- 감사 대비 팁 -->
          <div class="card p-6 bg-red-50 border-red-100">
            <h3 class="font-bold text-red-900 mb-3 flex items-center gap-2">
              <span class="material-symbols-outlined">shield</span>
              감사 대비 핵심
            </h3>
            <ul class="text-sm text-red-800 space-y-2">
              <li class="flex items-start gap-2">
                <span class="material-symbols-outlined text-sm mt-0.5 text-red-500">check_circle</span>
                <span>근거 법령과 조항 번호를 정확히 기재</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="material-symbols-outlined text-sm mt-0.5 text-red-500">check_circle</span>
                <span>결재 과정에서 검토 의견 반드시 첨부</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="material-symbols-outlined text-sm mt-0.5 text-red-500">check_circle</span>
                <span>금액 기준은 부가세 포함/미포함 구분</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="material-symbols-outlined text-sm mt-0.5 text-red-500">check_circle</span>
                <span>기한 준수 여부 사전 점검</span>
              </li>
            </ul>
          </div>

          <!-- 관련 도구 -->
          <div class="card p-6">
            <h3 class="font-bold text-slate-900 mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-emerald-500">build</span>
              관련 실무 도구
            </h3>
            <ul class="space-y-3">
              <li>
                <%= link_to contract_method_path, class: "text-sm text-slate-700 hover:text-emerald-600 transition-colors flex items-center gap-2" do %>
                  <span class="material-symbols-outlined text-base text-slate-400">chevron_right</span>
                  계약방식 결정 도우미
                <% end %>
              </li>
              <li>
                <%= link_to contract_guarantee_path, class: "text-sm text-slate-700 hover:text-emerald-600 transition-colors flex items-center gap-2" do %>
                  <span class="material-symbols-outlined text-base text-slate-400">chevron_right</span>
                  계약보증금 계산기
                <% end %>
              </li>
              <li>
                <%= link_to estimated_price_path, class: "text-sm text-slate-700 hover:text-emerald-600 transition-colors flex items-center gap-2" do %>
                  <span class="material-symbols-outlined text-base text-slate-400">chevron_right</span>
                  추정가격 계산기
                <% end %>
              </li>
              <li>
                <%= link_to legal_period_path, class: "text-sm text-slate-700 hover:text-emerald-600 transition-colors flex items-center gap-2" do %>
                  <span class="material-symbols-outlined text-base text-slate-400">chevron_right</span>
                  법정기간 계산기
                <% end %>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# [INP 최적화] Iconify.scan() 전체 DOM 스캔 제거 — 레이아웃의 turbo:render + DOMContentLoaded에서 이미 처리됨 %>
