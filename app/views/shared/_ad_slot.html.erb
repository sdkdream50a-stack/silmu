<%# 광고 단위 (운영 환경 한정)
  - guides / topics / audit_cases: 페이지 맨 하단 (position: 'bottom')
  - tools: 결과 영역 근처 (position: 'tool-result')
  - exam: 각 섹션 하단 (position: 'chapter-bottom' / 'subject-bottom' / 'quiz-index-bottom') %>
<%
  show_ad = Rails.env.production? && (
    (position.to_s == 'bottom'      && %w[guides topics audit_cases].include?(params[:controller])) ||
    (position.to_s == 'tool-result' && params[:controller] == 'tools') ||
    (%w[chapter-bottom subject-bottom quiz-index-bottom].include?(position.to_s) && params[:controller].start_with?('exam/'))
  )
%>
<% if show_ad %>
<div class="max-w-4xl mx-auto px-4 pt-4 pb-1">
  <p class="text-xs text-gray-400 text-center">AI 응답 API 비용 충당을 위해 광고가 표시됩니다.</p>
</div>
<div class="max-w-4xl mx-auto px-4 pb-6">
  <ins class="adsbygoogle"
       style="display:block"
       data-ad-client="ca-pub-6241798439911569"
       data-ad-slot="2611873628"
       data-ad-format="auto"
       data-full-width-responsive="true"></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>
<% end %>
