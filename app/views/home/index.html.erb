<%# Claude Editorial v4 — Deep Civic Navy / Pretendard 800 / Flat Authority
   재구축: 2026-04-21 (phase 1-B) — 498줄 → 약 330줄, 7섹션 → 6섹션 %>

<!-- 공지사항 배너 (2주 경과 시 자동 숨김) -->
<% notice_date = Date.new(2026, 3, 27) %>
<% if (Time.zone.today - notice_date) <= 14 %>
  <div class="bg-amber-50 border-b border-amber-200">
    <div class="container-editorial py-2.5">
      <div class="flex items-center justify-center gap-3 text-sm flex-wrap">
        <span class="material-symbols-outlined text-[18px] text-amber-700 shrink-0">auto_stories</span>
        <span class="text-amber-900">
          <strong class="font-bold">완전정복 시리즈 7개·70편 완성</strong>
          <span class="hidden sm:inline text-amber-700"> — 공사계약·수의계약·예산집행·출장여비·인사복무·예산편성·지방보조금</span>
        </span>
        <%= link_to "가이드 보기 →", guides_path,
              class: "shrink-0 font-semibold text-amber-900 underline underline-offset-2 decoration-amber-400 hover:decoration-amber-700" %>
      </div>
    </div>
  </div>
<% end %>

<!-- ============================================================
     1. HERO (First Screen) — Navy 배경, Pretendard 800 헤드라인
     ============================================================ -->
<div class="flex flex-col min-h-[calc(100vh-4rem)] lg:min-h-[calc(100vh-4.5rem)]">

<section class="relative flex-1 flex items-center bg-editorial-navy overflow-hidden"
         style="background-image: linear-gradient(180deg, #174B8E 0%, #1E5AA8 100%);">
  <div class="container-editorial section-editorial w-full">
    <div class="max-w-4xl mx-auto text-center">

      <!-- Kicker -->
      <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-300"></span>
        <span class="text-xs font-semibold text-white/90 tracking-wide">공무원 계약·예산 실무 가이드</span>
      </div>

      <!-- Headline -->
      <h1 class="heading-editorial-hero !text-amber-200 mb-6">
        복잡한 실무,<br class="sm:hidden"/> 여기서 풀어가세요
      </h1>

      <!-- Lede -->
      <p class="lede-editorial !text-white max-w-2xl mx-auto mb-10">
        현직 공무원이 가장 많이 찾는<br class="hidden sm:block"/>
        <strong class="font-bold !text-white">실무 가이드 <%= @topic_count + @guide_count %>개, 감사 지적 사례 <%= @audit_case_count %>건</strong>이 여기 있습니다.
      </p>

      <!-- Search -->
      <form action="<%= silmu_search_path %>" method="get" data-turbo="false"
            data-controller="home-search" data-action="submit->home-search#submit"
            class="max-w-2xl mx-auto mb-8">
        <div class="flex items-center gap-2 p-2 bg-white rounded-xl shadow-lg">
          <span class="material-symbols-outlined text-slate-400 pl-3">search</span>
          <input name="q" data-home-search-target="input"
                 data-action="input->home-search#inputChanged blur->home-search#blurred"
                 aria-label="실무 가이드 검색"
                 placeholder="예: 수의계약 한도, 물품구매 절차"
                 autocomplete="off" type="text"
                 class="flex-1 h-12 px-2 border-0 bg-transparent text-slate-900 placeholder:text-slate-400 focus:ring-0 focus:outline-none text-base"/>
          <button type="submit" class="btn-editorial h-12 px-5 shrink-0">검색</button>
        </div>
      </form>

      <!-- 단계별 빠른 진입 (4칩 + 전체 흐름도) -->
      <div class="mb-8">
        <p class="text-xs font-semibold text-white/80 uppercase tracking-wider mb-3">지금 어느 단계에 있으세요?</p>
        <div class="flex flex-wrap justify-center gap-2">
          <% [
            [contract_method_path,                                        "lightbulb",   "1. 계약방식 결정"],
            [topics_category_path(key: "contract") + "?subgroup=수의계약", "gavel",       "2. 견적·입찰"],
            [topic_path("contract-execution"),                            "handshake",   "3. 계약체결"],
            [topic_path("inspection"),                                    "fact_check",  "4. 검수·대금지급"]
          ].each do |path, icon, label| %>
            <%= link_to path, class: "touch-target inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg bg-white/10 hover:bg-white/20 border border-white/15 text-white text-sm font-semibold backdrop-blur-sm transition-colors" do %>
              <span class="material-symbols-outlined text-[16px] text-white/75"><%= icon %></span><%= label %>
            <% end %>
          <% end %>
          <%= link_to contract_flow_path, class: "touch-target inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg border border-dashed border-white/25 text-white/75 hover:text-white hover:border-white/50 text-sm font-semibold transition-colors" do %>
            <span class="material-symbols-outlined text-[16px]">account_tree</span>전체 흐름도
          <% end %>
        </div>
      </div>

      <!-- Sector 탭 -->
      <div id="sector-tabs" class="flex items-center justify-center gap-2 flex-wrap scroll-mt-16">
        <span class="text-xs font-semibold text-white/85">내 직종:</span>
        <% [["common", "공통"], ["local_gov", "지자체"], ["edu", "교육행정"]].each do |key, label| %>
          <% is_active = @sector == key %>
          <%= link_to label, root_path(sector: key, anchor: "sector-tabs"),
                class: "touch-target inline-flex items-center px-4 py-1.5 rounded-full text-xs font-semibold transition-colors #{is_active ? 'bg-white text-editorial-navy' : 'bg-white/15 text-white hover:bg-white/25 border border-white/30'}" %>
        <% end %>
      </div>

    </div>
  </div>
</section>

<!-- 업무달력 strip (Hero 하단 inline) -->
<div class="bg-editorial-navy-bg border-y border-slate-200">
  <div class="container-editorial py-3">
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <span class="material-symbols-outlined text-editorial-navy shrink-0">calendar_month</span>
        <div class="min-w-0">
          <p class="text-sm font-bold text-editorial-ink truncate"><%= Time.zone.now.month %>월 업무달력 — 이달 마감일정 놓치지 마세요</p>
          <p class="text-xs text-editorial-muted hidden sm:block">급여·보험료·세무신고 등 반복업무 일정을 한눈에</p>
        </div>
      </div>
      <%= link_to task_calendar_path, class: "btn-editorial-quiet shrink-0" do %>
        일정 확인 <span class="material-symbols-outlined text-base">arrow_forward</span>
      <% end %>
    </div>
  </div>
</div>

</div><%# /First Screen Wrapper %>

<%# 최근 본 항목 (로컬스토리지 기반 — 기본 숨김) %>
<section data-controller="recent-items" style="display:none"
         data-recent-items-container-target="container"
         class="bg-editorial-cream border-b border-slate-200">
  <div class="container-editorial py-4">
    <div class="flex items-center gap-2 mb-3">
      <span class="material-symbols-outlined text-editorial-muted text-base">history</span>
      <h2 class="text-sm font-semibold text-editorial-muted">최근 본 항목</h2>
    </div>
    <div data-recent-items-list-target="list"
         class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2"></div>
  </div>
</section>

<!-- ============================================================
     2. CORE TOOLS — 3 main + 4 minor
     ============================================================ -->
<% cache "home/core_tools/editorial_v1", expires_in: 24.hours do %>
<section class="section-editorial bg-editorial-cream">
  <div class="container-editorial">
    <div class="flex items-end justify-between mb-8 flex-wrap gap-4">
      <div>
        <h2 class="heading-editorial-section mb-2">핵심 실무 도구</h2>
        <p class="lede-editorial">복잡한 계산과 서류 작성을 <strong class="text-editorial-navy">클릭 몇 번</strong>으로 처리하세요</p>
      </div>
      <%= link_to tools_path, class: "btn-editorial" do %>
        전체 도구 보기
        <span class="material-symbols-outlined text-lg">arrow_forward</span>
      <% end %>
    </div>

    <!-- 주요 3 도구 -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-5">
      <% [
        [contract_method_path,      "account_tree", "계약방식 결정",    "예산과 품목만 입력하면 법령에 맞는 최적의 계약 방식을 <strong class='text-editorial-navy'>인공지능이 추천</strong>해 드립니다."],
        [contract_guarantee_path,   "percent",      "계약보증금 계산",  "계약금액만 입력하면 <strong class='text-editorial-navy'>계약·이행·하자·선금 보증금</strong>을 법령 기준에 맞게 자동 계산합니다."],
        [estimated_price_path,      "payments",     "예정가격 산정",    "시장조사 가격을 입력하면 <strong class='text-editorial-navy'>복수예비가격 85~100%</strong> 범위의 적정 예정가격을 즉시 산출합니다."]
      ].each do |path, icon, title, desc| %>
        <%= link_to path, class: "card-editorial card-editorial-interactive group" do %>
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-editorial-navy-bg text-editorial-navy group-hover:bg-editorial-navy group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-[22px]"><%= icon %></span>
          </div>
          <h3 class="heading-editorial-card mb-2"><%= title %></h3>
          <p class="text-sm text-editorial-muted leading-relaxed mb-5"><%= raw desc %></p>
          <div class="flex items-center gap-1 text-sm font-bold text-editorial-navy group-hover:gap-2 transition-all">
            지금 확인하기 <span class="material-symbols-outlined text-base">arrow_forward</span>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- 부가 4 도구 -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <%= link_to task_calendar_path, class: "card-editorial card-editorial-interactive flex flex-col items-center gap-2 py-5 border-editorial-navy-light/30" do %>
        <span class="material-symbols-outlined text-[22px] text-editorial-navy">calendar_today</span>
        <span class="text-sm font-bold text-editorial-ink">업무 할일 달력</span>
      <% end %>
      <% [
        [legal_period_path,          "calendar_month",   "계약기간 산정"],
        [pre_contract_checklist_path,"checklist_rtl",    "사전 체크리스트"],
        [contract_flow_path,         "account_tree",     "계약 흐름도"]
      ].each do |path, icon, label| %>
        <%= link_to path, class: "card-editorial-quiet card-editorial-interactive flex flex-col items-center gap-2 py-5" do %>
          <span class="material-symbols-outlined text-[22px] text-editorial-muted"><%= icon %></span>
          <span class="text-sm font-semibold text-editorial-ink"><%= label %></span>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
<% end %><%# cache %>

<!-- ============================================================
     3. TOPIC GUIDES — Featured + Grid
     ============================================================ -->
<% if @sector != "common" %>
  <% banner_label = @sector == "local_gov" ? "지방자치단체" : "교육행정기관" %>
  <div class="bg-editorial-navy-bg border-y border-slate-200">
    <div class="container-editorial py-2.5 flex items-center gap-3 flex-wrap">
      <span class="badge-editorial"><%= banner_label %> 맞춤</span>
      <p class="text-sm text-editorial-muted">법령 가이드·감사사례가 소속 기관에 맞게 조정되었습니다.</p>
      <%= link_to "전체 보기 →", root_path(sector: "common", anchor: "sector-tabs"),
            class: "ml-auto shrink-0 text-xs font-semibold text-editorial-navy hover:underline underline-offset-2" %>
    </div>
  </div>
<% end %>

<section class="section-editorial bg-white">
  <div class="container-editorial">
    <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
      <div>
        <h2 class="heading-editorial-section mb-2 flex items-center gap-2">
          <span class="material-symbols-outlined text-editorial-navy">library_books</span>
          <% if @sector == "common" %>주요 법령 가이드<% else %><%= @sector == "local_gov" ? "지자체" : "교육행정" %> 맞춤 가이드<% end %>
        </h2>
        <p class="meta-editorial"><%= Time.zone.now.month %>월 큐레이션 · 총 <%= @topic_count %>개 주제</p>
      </div>
      <%= link_to topics_path, class: "btn-editorial-ghost" do %>
        전체 가이드 보기
        <span class="material-symbols-outlined text-base">arrow_forward</span>
      <% end %>
    </div>

    <% topic_icons = {
      "private-contract" => "handshake", "bidding" => "gavel", "contract-execution" => "description",
      "inspection" => "fact_check", "payment" => "payments", "travel-expense" => "flight_takeoff",
      "estimated-price" => "calculate", "contract-guarantee-deposit" => "security",
      "advance-payment" => "wallet", "late-penalty" => "timer_off", "design-change" => "edit_note",
      "budget-compilation" => "account_balance", "budget-carryover" => "undo",
      "year-end-settlement" => "receipt_long", "completion-payment-checklist" => "checklist_rtl",
      "goods-selection-committee" => "group_work"
    } %>

    <% if @curated_topics.present? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @curated_topics.each_with_index do |topic, idx| %>
          <% icon = topic_icons[topic.slug] || "library_books" %>
          <% if idx == 0 %>
            <%# Featured — 첫 카드 강조 %>
            <%= link_to topic_path(topic.slug),
                  class: "card-editorial card-editorial-interactive group sm:col-span-2 lg:col-span-3 flex items-start gap-5 relative" do %>
              <div class="absolute top-4 right-4">
                <span class="badge-editorial"><span class="material-symbols-outlined text-sm mr-1">star</span>이달의 필수</span>
              </div>
              <div class="shrink-0 flex h-14 w-14 items-center justify-center rounded-lg bg-editorial-navy text-white">
                <span class="material-symbols-outlined text-2xl"><%= icon %></span>
              </div>
              <div class="min-w-0 pr-28 sm:pr-32">
                <h3 class="heading-editorial-card mb-1.5 group-hover:text-editorial-navy transition-colors"><%= topic.name %></h3>
                <p class="text-sm text-editorial-muted leading-relaxed mb-3"><%= topic.summary.to_s.truncate(80) %></p>
                <% keywords = topic.keyword_list.first(3) %>
                <% if keywords.any? %>
                  <div class="flex flex-wrap gap-1.5">
                    <% keywords.each do |kw| %>
                      <span class="badge-editorial"><%= kw %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <%= link_to topic_path(topic.slug),
                  class: "card-editorial card-editorial-interactive group flex items-start gap-4" do %>
              <div class="shrink-0 flex h-11 w-11 items-center justify-center rounded-lg bg-editorial-navy-bg text-editorial-navy group-hover:bg-editorial-navy group-hover:text-white transition-colors">
                <span class="material-symbols-outlined text-[22px]"><%= icon %></span>
              </div>
              <div class="min-w-0">
                <h3 class="font-bold text-base text-editorial-ink group-hover:text-editorial-navy transition-colors leading-snug mb-1"><%= topic.name %></h3>
                <p class="text-xs text-editorial-muted line-clamp-2 leading-relaxed"><%= topic.summary.to_s.truncate(70) %></p>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- ============================================================
     4. AUDIT CASES + POPULAR GUIDES (좌우 2칼럼 on lg)
     ============================================================ -->
<section class="section-editorial bg-editorial-cream">
  <div class="container-editorial">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

      <!-- 감사사례 -->
      <% if @recent_audit_cases.present? %>
        <div>
          <div class="flex items-center justify-between mb-6">
            <h2 class="heading-editorial-section flex items-center gap-2">
              <span class="material-symbols-outlined text-red-600">policy</span>주요 감사 지적
            </h2>
            <%= link_to audit_cases_path, class: "btn-editorial-quiet" do %>
              전체 <%= @audit_case_count %>건 <span class="material-symbols-outlined text-base">arrow_forward</span>
            <% end %>
          </div>
          <div class="space-y-3">
            <% @recent_audit_cases.each do |ac| %>
              <% is_critical = ac.severity == "중대" %>
              <%= link_to audit_case_path(ac.slug),
                    class: "card-editorial card-editorial-interactive group block" do %>
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <span class="badge-editorial <%= is_critical ? 'signal-critical' : 'signal-warn' %>"><%= ac.severity %></span>
                  <span class="meta-editorial"><%= ac.category %></span>
                  <% if ac.repeated_issue? %>
                    <span class="badge-editorial signal-critical"><span class="material-symbols-outlined text-[11px] mr-0.5">loop</span>반복</span>
                  <% end %>
                </div>
                <h3 class="font-bold text-base text-editorial-ink group-hover:text-editorial-navy transition-colors leading-snug line-clamp-2 mb-1"><%= ac.title %></h3>
                <p class="text-xs text-editorial-muted line-clamp-2"><%= ac.issue.truncate(90) %></p>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- 인기 가이드 -->
      <% if @popular_guides.present? %>
        <div>
          <div class="flex items-center justify-between mb-6">
            <h2 class="heading-editorial-section flex items-center gap-2">
              <span class="material-symbols-outlined text-editorial-navy">trending_up</span>많이 읽는 가이드
            </h2>
            <%= link_to guides_path, class: "btn-editorial-quiet" do %>
              전체 보기 <span class="material-symbols-outlined text-base">arrow_forward</span>
            <% end %>
          </div>
          <div class="space-y-3">
            <% @popular_guides.first(5).each_with_index do |guide, idx| %>
              <%= link_to guide_path(guide.slug),
                    class: "card-editorial card-editorial-interactive group flex items-start gap-3" do %>
                <span class="shrink-0 flex h-8 w-8 items-center justify-center rounded-md bg-editorial-navy-bg text-editorial-navy font-bold text-sm"><%= idx + 1 %></span>
                <div class="min-w-0">
                  <h3 class="font-bold text-sm text-editorial-ink group-hover:text-editorial-navy transition-colors leading-snug line-clamp-2"><%= guide.title %></h3>
                  <% if guide.series.present? %>
                    <p class="meta-editorial mt-1 flex items-center gap-1">
                      <span class="material-symbols-outlined text-[12px]">collections_bookmark</span><%= guide.series %>
                    </p>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</section>

<!-- ============================================================
     5. FINAL CTA — 가입 + 시험 통합
     ============================================================ -->
<% cache "home/final_cta/editorial_v1", expires_in: 24.hours do %>
<section class="bg-editorial-navy"
         style="background-image: linear-gradient(180deg, #1E5AA8 0%, #174B8E 100%);">
  <div class="container-editorial section-editorial text-center">
    <h2 class="heading-editorial-section text-white mb-3">실무, 이제 더 쉽고 완벽하게</h2>
    <p class="lede-editorial !text-white/95 mb-8 max-w-2xl mx-auto">
      법령 가이드 · 자동화 도구 · 감사사례 — 공무원이 선택한 무료 실무 플랫폼
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-3">
      <%= link_to "지금 바로 시작하기", new_user_registration_path,
            class: "touch-target btn-editorial bg-white !text-editorial-navy hover:bg-slate-50 hover:!text-editorial-navy-dark px-6 py-3" %>
      <%= link_to tools_path,
            class: "touch-target btn-editorial-ghost !border-white !text-white hover:!bg-white/10 px-6 py-3" do %>
        실무 도구 둘러보기
      <% end %>
    </div>

    <!-- 시험 CTA (subtle) -->
    <div class="mt-10 pt-8 border-t border-white/20">
      <p class="meta-editorial !text-white/80 mb-3">2026년 신설 자격시험</p>
      <a href="https://exam.silmu.kr"
         class="inline-flex items-center gap-2 text-sm font-bold text-white/90 hover:text-white underline underline-offset-4 decoration-white/30 hover:decoration-white/70 transition-colors">
        <span class="material-symbols-outlined text-base">school</span>
        공공조달관리사 시험 대비 시작하기
        <span class="material-symbols-outlined text-base">arrow_forward</span>
      </a>
    </div>
  </div>
</section>
<% end %>
