<%# Stitch 디자인 v2 — Indigo/Violet 프리미엄 테마 (컴파일 CSS 사용) %>

<div class="font-sans text-slate-800 antialiased selection:bg-indigo-500/30 selection:text-indigo-600">

<!-- 공지사항 배너 -->
<div class="bg-gradient-to-r from-indigo-600 to-violet-600 text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3">
    <div class="flex items-center justify-center gap-3 text-sm">
      <span class="material-symbols-outlined text-lg animate-pulse">campaign</span>
      <span class="font-medium">
        <span class="hidden sm:inline">📢 새로운 소식:</span>
        <strong class="ml-1">인사·복무 가이드 8개 신설 + FAQ 40개</strong> 달성 (2026-03-01)
        <span class="hidden md:inline ml-2 opacity-90">| 감사사례 <%= @audit_case_count %>건 · 모의고사 400문제</span>
      </span>
      <%= link_to updates_path, class: "ml-3 px-3 py-1 bg-white/20 hover:bg-white/30 rounded-lg text-white font-semibold transition-colors whitespace-nowrap" do %>
        자세히 보기 →
      <% end %>
    </div>
  </div>
</div>

<!-- Hero Section -->
<div class="relative w-full hero-gradient overflow-hidden pb-12 pt-4 lg:pt-6">
  <%# blur-3xl 제거 → 단순 그라디언트로 대체 (모바일 GPU 병목 해소, LCP 개선) %>
  <div class="absolute top-0 left-1/4 h-96 w-96 rounded-full bg-indigo-500/15 opacity-60"></div>
  <div class="absolute bottom-0 right-1/4 h-96 w-96 rounded-full bg-violet-500/10 opacity-40"></div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center text-center">
      <div class="mb-8 inline-flex items-center rounded-full border border-indigo-400/30 bg-indigo-900/30 px-4 py-1.5 backdrop-blur-md shadow-glow">
        <span class="mr-2 flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        <span class="text-xs font-semibold text-indigo-100 tracking-wide uppercase">Premium Government Solution</span>
      </div>
      <h1 class="mb-10 max-w-5xl text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl leading-[1.1]">
        계약 실무,<br class="hidden sm:block"/>
        <span class="text-gradient">이제 혼자 고민하지 마세요</span>
      </h1>
      <p class="mb-14 max-w-2xl text-xl text-slate-200 leading-relaxed font-normal">
        헷갈리는 절차, 복잡한 법령도<br class="hidden sm:block"/>
        <strong class="font-bold text-white">단계별로 쉽게</strong> 안내해 드립니다.
      </p>

      <!-- Search -->
      <div class="w-full max-w-3xl mb-16 relative z-10">
        <form action="<%= chatbot_path %>" method="get" data-turbo="false"
              data-controller="home-search" data-action="submit->home-search#submit">
          <div class="search-glass relative flex items-center rounded-2xl overflow-hidden p-2 transition-all duration-300">
            <div class="flex h-14 w-14 items-center justify-center text-indigo-300 pl-2">
              <span class="material-symbols-outlined text-3xl">search</span>
            </div>
            <input name="q" data-home-search-target="input"
                   data-action="input->home-search#inputChanged blur->home-search#blurred"
                   class="h-14 w-full border-0 bg-transparent px-4 text-white placeholder:text-slate-400 focus:ring-0 text-lg" placeholder="무엇을 도와드릴까요? (예: 수의계약 한도, 물품구매 절차)" type="text" autocomplete="off"/>
            <button type="submit" class="hidden sm:flex h-12 items-center justify-center rounded-xl bg-indigo-600 px-8 text-base font-bold text-white transition-all hover:bg-indigo-500 shadow-lg shadow-indigo-600/30">
              검색
            </button>
          </div>
          <!-- 자동완성 힌트 -->
          <div data-home-search-target="hint" class="hidden mt-2 text-center text-sm text-indigo-300 animate-pulse">
            <span class="material-symbols-outlined text-base align-middle">keyboard_return</span>
            <span class="ml-1">Enter로 검색</span>
          </div>
        </form>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <% [
            [topic_path("private-contract"), "gavel", "수의계약", "indigo"],
            [topic_path("bidding"), "shopping_bag", "입찰", "emerald"],
            [topic_path("contract-execution"), "engineering", "계약체결", "amber"],
            [topic_path("inspection"), "design_services", "검수·검사", "pink"]
          ].each do |path, icon, keyword, color| %>
            <%= link_to path, class: "group inline-flex min-h-[44px] items-center gap-2 rounded-full bg-slate-800/50 px-4 py-2 text-sm font-medium text-slate-300 hover:bg-indigo-600/20 hover:text-white hover:border-indigo-500/50 transition-all backdrop-blur-sm border border-slate-700/50" do %>
              <span class="material-symbols-outlined text-[16px] <%= tc(color, :hero) %>"><%= icon %></span> <%= keyword %>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Sector 선택 인디케이터 (common 제외) -->
      <% if @sector != "common" %>
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/15 border border-white/20 backdrop-blur-sm">
        <span class="material-symbols-outlined text-sm text-emerald-400">check_circle</span>
        <span class="text-sm font-semibold text-white">
          <%= @sector == "local_gov" ? "🏢 지자체" : "🏫 교육행정" %> 맞춤 콘텐츠로 보는 중
        </span>
        <%= link_to root_path(sector: "common", anchor: "sector-tabs"),
              class: "ml-1 text-xs text-slate-300 hover:text-white transition-colors underline" do %>
          초기화
        <% end %>
      </div>
      <% end %>

      <!-- Stats -->
      <div class="grid w-full max-w-5xl grid-cols-2 gap-5 sm:grid-cols-4">
        <div class="group flex flex-col rounded-3xl bg-white/10 p-7 text-center backdrop-blur-md border-2 border-white/10 hover:bg-white/15 hover:border-white/25 transition-all duration-300 cursor-default shadow-lg hover:shadow-2xl">
          <span class="text-5xl font-bold text-white mb-2 group-hover:scale-110 transition-transform duration-300"><%= tool_count %></span>
          <span class="text-sm font-bold text-indigo-100 uppercase tracking-wider">업무 자동화 도구</span>
        </div>
        <div class="group flex flex-col rounded-3xl bg-white/10 p-7 text-center backdrop-blur-md border-2 border-white/10 hover:bg-white/15 hover:border-white/25 transition-all duration-300 cursor-default shadow-lg hover:shadow-2xl">
          <span class="text-5xl font-bold text-white mb-2 group-hover:scale-110 transition-transform duration-300"><%= @topic_count + @guide_count %></span>
          <span class="text-sm font-bold text-indigo-100 uppercase tracking-wider">법령·업무 가이드</span>
        </div>
        <div class="group flex flex-col rounded-3xl bg-white/10 p-7 text-center backdrop-blur-md border-2 border-white/10 hover:bg-white/15 hover:border-white/25 transition-all duration-300 cursor-default shadow-lg hover:shadow-2xl">
          <span class="text-5xl font-bold text-white mb-2 group-hover:scale-110 transition-transform duration-300"><%= @audit_case_count %></span>
          <span class="text-sm font-bold text-indigo-100 uppercase tracking-wider">감사사례</span>
        </div>
        <div class="group flex flex-col rounded-3xl bg-white/10 p-7 text-center backdrop-blur-md border-2 border-white/10 hover:bg-white/15 hover:border-white/25 transition-all duration-300 cursor-default shadow-lg hover:shadow-2xl">
          <span class="text-5xl font-bold text-white mb-2 group-hover:scale-110 transition-transform duration-300"><%= @template_count %></span>
          <span class="text-sm font-bold text-indigo-100 uppercase tracking-wider">실무 서식 템플릿</span>
        </div>
      </div>

      <!-- 북마크 유도 배너 -->
      <div class="w-full max-w-4xl mt-12">
        <div class="group relative rounded-2xl bg-gradient-to-r from-amber-500/20 to-orange-500/20 p-6 backdrop-blur-md border-2 border-amber-400/30 hover:border-amber-400/50 transition-all duration-300 shadow-xl hover:shadow-2xl">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-4 text-center sm:text-left">
              <div class="flex-shrink-0 w-14 h-14 bg-amber-400/20 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <span class="material-symbols-outlined text-3xl text-amber-300">bookmark</span>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white mb-1">자주 찾는 법령 가이드를 북마크하세요 📌</h3>
                <p class="text-sm text-amber-100">다음 방문 시 빠르게 찾아볼 수 있습니다</p>
              </div>
            </div>
            <button data-controller="home-bookmark" data-action="click->home-bookmark#bookmark" class="flex-shrink-0 inline-flex items-center gap-2 px-6 py-3 bg-amber-500 hover:bg-amber-400 text-white font-bold rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105 whitespace-nowrap">
              <span class="material-symbols-outlined text-xl">star</span>
              <span>북마크 추가</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


<!-- Sector Tab Bar — 직종별 콘텐츠 스위처 -->
<div id="sector-tabs" class="bg-white border-b border-slate-200 shadow-sm scroll-mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="hidden md:block text-xs text-slate-400 pt-2.5">소속 기관에 맞는 법령 가이드와 감사사례를 맞춤 제공합니다</p>
    <div class="flex items-center overflow-x-auto">
      <span class="text-xs font-semibold text-slate-500 mr-3 whitespace-nowrap hidden sm:block shrink-0">내 직종</span>
      <% [
        ["common",    "🏛️", "전체/공통"],
        ["local_gov", "🏢", "지자체"],
        ["edu",       "🏫", "교육행정"]
      ].each do |sector_key, emoji, label| %>
        <% is_active = @sector == sector_key %>
        <%= link_to root_path(sector: sector_key, anchor: "sector-tabs"),
              class: "flex items-center gap-1.5 px-5 py-3.5 text-sm font-semibold whitespace-nowrap border-b-2 transition-colors #{is_active ? 'border-indigo-600 text-indigo-600' : 'border-transparent text-slate-500 hover:text-slate-800 hover:border-slate-300'}" do %>
          <%= emoji %> <%= label %>
          <% if is_active %>
            <span class="ml-1 px-1.5 py-0.5 text-xs bg-indigo-100 text-indigo-700 rounded-md font-bold">ON</span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- Core Tools Section -->
<% cache "home/core_tools/v1", expires_in: 24.hours do %>
<section class="bg-background-light py-16 relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-14 flex items-end justify-between">
      <div>
        <h2 class="text-4xl font-bold text-slate-900 sm:text-5xl tracking-tight mb-4">핵심 실무 도구</h2>
        <p class="text-xl text-slate-600 font-medium">복잡한 업무를 <strong class="text-indigo-700 font-bold">클릭 몇 번</strong>으로 해결하는 프리미엄 툴킷</p>
      </div>
      <%= link_to tools_path, class: "group flex items-center gap-2 px-5 py-3 text-base font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl shadow-lg hover:shadow-xl transition-all" do %>
        전체 도구 보기
        <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
      <% end %>
    </div>

    <!-- Main 3 Tools -->
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-3 mb-16">
      <%= link_to contract_method_path, class: "group relative overflow-hidden rounded-3xl bg-white p-10 shadow-xl hover:shadow-2xl hover:-translate-y-3 transition-all duration-500 border-2 border-slate-100 hover:border-indigo-200" do %>
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-50/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 mb-7 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600 shadow-md group-hover:bg-indigo-600 group-hover:text-white transition-colors duration-300">
          <span class="material-symbols-outlined text-4xl">account_tree</span>
        </div>
        <h3 class="relative z-10 text-2xl font-bold text-slate-900 mb-4 tracking-tight">계약방식 결정</h3>
        <p class="relative z-10 text-base text-slate-600 leading-relaxed mb-10">예산과 품목만 입력하면 법령에 맞는 최적의 계약 방식을 <strong class="text-indigo-700 font-bold">인공지능이 추천</strong>해 드립니다.</p>
        <div class="relative z-10 flex items-center text-indigo-600 font-bold text-base group-hover:translate-x-2 transition-transform duration-300">
          <span>지금 확인하기</span>
          <span class="material-symbols-outlined ml-2 text-xl">arrow_forward</span>
        </div>
      <% end %>

      <%= link_to contract_guarantee_path, class: "group relative overflow-hidden rounded-3xl bg-white p-10 shadow-xl hover:shadow-2xl hover:-translate-y-3 transition-all duration-500 border-2 border-slate-100 hover:border-amber-200" do %>
        <div class="absolute inset-0 bg-gradient-to-br from-amber-50/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 mb-7 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-amber-50 text-amber-600 shadow-md group-hover:bg-amber-600 group-hover:text-white transition-colors duration-300">
          <span class="material-symbols-outlined text-4xl">percent</span>
        </div>
        <h3 class="relative z-10 text-2xl font-bold text-slate-900 mb-4 tracking-tight">계약보증금 계산</h3>
        <p class="relative z-10 text-base text-slate-600 leading-relaxed mb-10">계약금액만 입력하면 <strong class="text-amber-700 font-bold">계약·이행·하자·선금 보증금</strong>을 법령 기준에 맞게 자동 계산합니다.</p>
        <div class="relative z-10 flex items-center text-amber-600 font-bold text-base group-hover:translate-x-2 transition-transform duration-300">
          <span>지금 확인하기</span>
          <span class="material-symbols-outlined ml-2 text-xl">arrow_forward</span>
        </div>
      <% end %>

      <%= link_to estimated_price_path, class: "group relative overflow-hidden rounded-3xl bg-white p-10 shadow-xl hover:shadow-2xl hover:-translate-y-3 transition-all duration-500 border-2 border-slate-100 hover:border-emerald-200" do %>
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-50/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 mb-7 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600 shadow-md group-hover:bg-emerald-600 group-hover:text-white transition-colors duration-300">
          <span class="material-symbols-outlined text-4xl">payments</span>
        </div>
        <h3 class="relative z-10 text-2xl font-bold text-slate-900 mb-4 tracking-tight">예정가격 산정</h3>
        <p class="relative z-10 text-base text-slate-600 leading-relaxed mb-10">시장조사 가격을 입력하면 <strong class="text-emerald-700 font-bold">복수예비가격 85~100%</strong> 범위의 적정 예정가격을 즉시 산출합니다.</p>
        <div class="relative z-10 flex items-center text-emerald-600 font-bold text-base group-hover:translate-x-2 transition-transform duration-300">
          <span>지금 확인하기</span>
          <span class="material-symbols-outlined ml-2 text-xl">arrow_forward</span>
        </div>
      <% end %>
    </div>

    <!-- Minor Tools -->
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
      <!-- 업무 할일 달력 (emphasized) -->
      <%= link_to task_calendar_path, class: "flex flex-col items-center justify-center gap-3 rounded-2xl bg-gradient-to-br from-indigo-50 to-white p-6 shadow-md border-2 border-indigo-200 hover:border-indigo-300 hover:shadow-lg hover:-translate-y-1 transition-all duration-300" do %>
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
          <span class="material-symbols-outlined text-[20px]">calendar_today</span>
        </div>
        <span class="text-sm font-bold text-indigo-900">업무 할일 달력</span>
      <% end %>

      <!-- 나머지 도구들 -->
      <% [
        [legal_period_path, "calendar_month", "계약기간 산정"],
        [pre_contract_checklist_path, "checklist_rtl", "사전 체크리스트"],
        [contract_flow_path, "account_tree", "계약 흐름도"]
      ].each do |path, icon, label| %>
        <%= link_to path, class: "flex flex-col items-center justify-center gap-3 rounded-2xl bg-white p-6 shadow-sm border border-slate-100 hover:border-indigo-100 hover:shadow-md hover:-translate-y-1 transition-all duration-300" do %>
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-50 text-slate-600">
            <span class="material-symbols-outlined text-[20px]"><%= icon %></span>
          </div>
          <span class="text-sm font-semibold text-slate-900"><%= label %></span>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<% end %><%# cache home/core_tools %>

<!-- Topic Guides & Templates -->
<% if @sector != "common"
     banner_bg    = @sector == "local_gov" ? "bg-blue-50 border-blue-200"   : "bg-orange-50 border-orange-200"
     banner_text  = @sector == "local_gov" ? "text-blue-800"                : "text-orange-800"
     banner_icon  = @sector == "local_gov" ? "account_balance"              : "school"
     banner_icon_color = @sector == "local_gov" ? "text-blue-600"           : "text-orange-500"
     banner_name  = @sector == "local_gov" ? "지방자치단체"                 : "교육행정기관"
   end %>
<% if @sector != "common" %>
<div class="border-b <%= banner_bg %> border-t">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3 flex items-center gap-3">
    <span class="material-symbols-outlined <%= banner_icon_color %> text-xl"><%= banner_icon %></span>
    <p class="text-sm font-semibold <%= banner_text %>">
      <strong><%= banner_name %> 맞춤</strong> 콘텐츠를 표시하고 있습니다 — 법령 가이드·감사사례가 소속 기관에 맞게 조정되었습니다.
    </p>
    <%= link_to "전체 보기", root_path(sector: "common", anchor: "sector-tabs"),
          class: "ml-auto shrink-0 text-xs font-semibold #{@sector == "local_gov" ? "text-blue-600 hover:text-blue-800" : "text-orange-600 hover:text-orange-800"} underline underline-offset-2 transition-colors" %>
  </div>
</div>
<% end %>
<section class="py-24 bg-background-light">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <!-- Topic Guides (sector × month 큐레이션) -->
      <div class="lg:col-span-7">
        <% sector_label = { "common" => "공통", "local_gov" => "지자체", "edu" => "교육행정" }[@sector]
           sector_icon  = { "common" => "library_books", "local_gov" => "account_balance", "edu" => "school" }[@sector]
           sector_color = { "common" => "text-indigo-600", "local_gov" => "text-blue-600", "edu" => "text-orange-500" }[@sector]
           sector_badge_bg = { "common" => "bg-slate-100 text-slate-500", "local_gov" => "bg-blue-50 text-blue-700 ring-1 ring-blue-200", "edu" => "bg-orange-50 text-orange-700 ring-1 ring-orange-200" }[@sector] %>
        <div class="mb-8 flex items-center justify-between">
          <h2 class="text-2xl font-bold text-slate-900 flex items-center gap-2">
            <span class="material-symbols-outlined <%= sector_color %>"><%= sector_icon %></span>
            <% if @sector == "common" %>
              주요 법령 가이드
            <% else %>
              <span class="<%= sector_color %>"><%= sector_label %></span> 맞춤 가이드
            <% end %>
          </h2>
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full <%= sector_badge_bg %>">
            <%= @sector == "common" ? "#{Time.zone.now.month}월 추천" : "#{Time.zone.now.month}월 #{sector_label} 특화" %>
          </span>
        </div>

        <% topic_visual = {
          "private-contract"             => ["handshake",      "indigo"],
          "bidding"                      => ["gavel",          "violet"],
          "contract-execution"           => ["description",    "amber"],
          "inspection"                   => ["fact_check",     "emerald"],
          "payment"                      => ["payments",       "blue"],
          "travel-expense"               => ["flight_takeoff", "rose"],
          "estimated-price"              => ["calculate",      "emerald"],
          "contract-guarantee-deposit"   => ["security",       "amber"],
          "advance-payment"              => ["wallet",         "blue"],
          "late-penalty"                 => ["timer_off",      "rose"],
          "design-change"                => ["edit_note",      "violet"],
          "budget-compilation"           => ["account_balance","indigo"],
          "budget-carryover"             => ["undo",           "slate"],
          "year-end-settlement"          => ["receipt_long",   "slate"],
          "completion-payment-checklist" => ["checklist_rtl",  "emerald"],
          "goods-selection-committee"    => ["group_work",     "amber"]
        } %>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% if @curated_topics.present? %>
            <% @curated_topics.each_with_index do |topic, idx| %>
              <% icon, color = topic_visual[topic.slug] || ["library_books", "indigo"] %>
              <% if idx == 0 %>
                <%# Featured: 첫 번째 토픽 (가로 전폭, 강조 스타일) %>
                <%= link_to topic_path(topic.slug), class: "group relative sm:col-span-2 flex items-start gap-5 rounded-2xl bg-gradient-to-br from-indigo-50 via-white to-violet-50 p-6 shadow-sm border-2 border-indigo-200 transition-all hover:shadow-lg hover:-translate-y-1 hover:border-indigo-400 cursor-pointer overflow-hidden" do %>
                  <div class="absolute top-3 right-3">
                    <% badge_bg = { "common" => "bg-indigo-600", "local_gov" => "bg-blue-600", "edu" => "bg-orange-500" }[@sector]
                       badge_label = { "common" => "이달의 필수", "local_gov" => "🏢 지자체 필수", "edu" => "🏫 교육행정 필수" }[@sector] %>
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-bold <%= badge_bg %> text-white rounded-full">
                      <span class="material-symbols-outlined text-sm">star</span> <%= badge_label %>
                    </span>
                  </div>
                  <div class="shrink-0 flex h-14 w-14 items-center justify-center rounded-xl <%= tc(color, :icon_lg) %> transition-colors">
                    <span class="material-symbols-outlined text-3xl"><%= icon %></span>
                  </div>
                  <div class="pr-24 sm:pr-28">
                    <h3 class="font-bold text-xl text-slate-900 <%= tc(color, :title) %> transition-colors"><%= topic.name %></h3>
                    <p class="mt-1.5 text-sm text-slate-600 leading-relaxed"><%= topic.summary.to_s.truncate(80) %></p>
                    <% keywords = topic.keyword_list.first(3) %>
                    <% if keywords.any? %>
                      <div class="mt-3 flex flex-wrap gap-2">
                        <% keywords.each do |kw| %>
                          <span class="inline-flex items-center gap-1 text-xs <%= tc(color, :badge) %> border rounded-md px-2 py-0.5 font-medium"><%= kw %></span>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% else %>
                <%# 일반 카드 %>
                <%= link_to topic_path(topic.slug), class: "group flex items-start gap-4 rounded-2xl bg-white p-6 shadow-sm border border-slate-100 transition-all hover:shadow-lg hover:-translate-y-1 hover:border-indigo-100 cursor-pointer" do %>
                  <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-xl <%= tc(color, :icon_sm) %> transition-colors">
                    <span class="material-symbols-outlined"><%= icon %></span>
                  </div>
                  <div>
                    <h3 class="font-bold text-lg text-slate-900 <%= tc(color, :title) %> transition-colors"><%= topic.name %></h3>
                    <p class="mt-1 text-sm text-slate-500 leading-snug"><%= topic.summary.to_s.truncate(70) %></p>
                  </div>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        </div>
        <div class="mt-6">
          <%= link_to topics_path, class: "inline-flex items-center gap-1 text-sm font-bold text-indigo-600 hover:text-indigo-700 transition-colors" do %>
            전체 법령가이드 보기 <span class="material-symbols-outlined text-lg">arrow_forward</span>
          <% end %>
        </div>
      </div>

      <!-- Templates -->
      <div class="lg:col-span-5">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-slate-900 flex items-center gap-2">
            <span class="material-symbols-outlined text-indigo-600">folder_open</span> 인기 서식
          </h2>
          <%= link_to templates_path, class: "text-sm font-semibold text-slate-500 hover:text-indigo-600 transition-colors" do %>
            더보기 →
          <% end %>
        </div>
        <div class="space-y-4">
          <% [
            { title: "물품 표준 구매계약서", format: "HWP", color: "indigo" },
            { title: "수의계약 배제사유 각서", format: "HWP", color: "indigo" },
            { title: "착수계 및 완료계 세트", format: "XLSX", color: "emerald" }
          ].each do |tmpl| %>
            <%= link_to templates_path, class: "flex items-center p-4 rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-md hover:border-indigo-100 transition-all group" do %>
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg <%= tc(tmpl[:color], :icon_base) %> font-bold text-xs"><%= tmpl[:format] %></div>
              <div class="ml-4 flex-1">
                <h4 class="font-bold text-lg text-slate-900 <%= tc(tmpl[:color], :title) %> transition-colors"><%= tmpl[:title] %></h4>
                <span class="text-xs text-slate-500">최신 개정판</span>
              </div>
              <span class="material-symbols-outlined text-slate-300 <%= tc(tmpl[:color], :title) %> transition-colors">download</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 주요 감사사례 -->
<% if @recent_audit_cases.present? %>
<section class="bg-white py-16 border-t border-slate-100">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-slate-900 flex items-center gap-2 flex-wrap">
        <span class="material-symbols-outlined text-red-500">policy</span>
        주요 감사 지적 사례
        <% if @sector != "common" %>
          <% ac_badge_bg = @sector == "local_gov" ? "bg-blue-100 text-blue-700 ring-1 ring-blue-300" : "bg-orange-100 text-orange-700 ring-1 ring-orange-300"
             ac_badge_icon = @sector == "local_gov" ? "🏢" : "🏫"
             ac_badge_label = @sector == "local_gov" ? "지자체 맞춤" : "교육행정 맞춤" %>
          <span class="text-sm font-bold px-2.5 py-1 rounded-full <%= ac_badge_bg %>"><%= ac_badge_icon %> <%= ac_badge_label %></span>
        <% end %>
      </h2>
      <%= link_to audit_cases_path, class: "text-sm font-semibold text-slate-500 hover:text-red-600 transition-colors flex items-center gap-1" do %>
        전체 <%= @audit_case_count %>건 보기 <span class="material-symbols-outlined text-base">arrow_forward</span>
      <% end %>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <% @recent_audit_cases.each do |ac| %>
        <% is_critical = ac.severity == "중대" %>
        <% severity_bg = is_critical ? "bg-red-50 border-red-200" : "bg-orange-50 border-orange-200" %>
        <% severity_text = is_critical ? "text-red-700" : "text-orange-700" %>
        <% severity_badge = is_critical ? "bg-red-100 text-red-700" : "bg-orange-100 text-orange-700" %>
        <% severity_hover = is_critical ? "group-hover:text-red-700" : "group-hover:text-orange-700" %>
        <%= link_to audit_case_path(ac.slug), class: "group flex flex-col gap-3 p-5 rounded-2xl border #{severity_bg} hover:shadow-md transition-all" do %>
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold px-2 py-0.5 rounded-full <%= severity_badge %>"><%= ac.severity %></span>
            <span class="text-xs text-slate-500"><%= ac.category %></span>
          </div>
          <h3 class="font-bold text-lg text-slate-900 <%= severity_hover %> transition-colors leading-snug line-clamp-2"><%= ac.title %></h3>
          <p class="text-xs text-slate-500 line-clamp-2 flex-1"><%= ac.issue.truncate(80) %></p>
          <div class="flex items-center gap-1 <%= severity_text %> text-xs font-semibold group-hover:gap-2 transition-all">
            사례 보기 <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </div>
        <% end %>
      <% end %>
    </div>
    <p class="mt-6 text-xs text-slate-400 flex items-center gap-1">
      <span class="material-symbols-outlined text-sm">info</span>
      실제 감사 지적 사례를 분석하여 같은 실수를 반복하지 않도록 안내합니다.
    </p>
  </div>
</section>
<% end %>

<!-- Quick Price Finder -->
<div class="bg-white py-20 border-y border-slate-100">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="relative rounded-3xl overflow-hidden bg-slate-900 shadow-2xl">
      <%# blur-3xl 제거 → 단순 그라디언트로 대체 (모바일 GPU 부하 경감) %>
      <div class="absolute top-0 right-0 -mt-20 -mr-20 h-64 w-64 rounded-full bg-indigo-500 opacity-10"></div>
      <div class="absolute bottom-0 left-0 -mb-20 -ml-20 h-64 w-64 rounded-full bg-emerald-500 opacity-10"></div>
      <div class="relative z-10 p-8 md:p-12 flex flex-col lg:flex-row items-center justify-between gap-10"
           data-controller="home-price"
           data-home-price-contract-method-path="<%= contract_method_path %>">
        <div class="flex-1 text-center lg:text-left">
          <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full bg-white/10 border border-white/10 backdrop-blur-sm">
            <span class="material-symbols-outlined text-emerald-400 text-sm">payments</span>
            <span class="text-xs font-bold uppercase tracking-wider text-emerald-400">Smart Price Guide</span>
          </div>
          <h3 class="text-3xl font-bold text-white mb-3">금액을 입력해보세요</h3>
          <p class="text-slate-300 text-lg">금액에 따라 법령상 가능한 모든 계약 방법(1인 견적, 2인 이상 견적, 입찰 등)을<br class="hidden lg:block"/> 즉시 분석하여 가이드해드립니다.</p>
        </div>
        <div class="w-full lg:w-auto flex-1 max-w-lg">
          <div class="flex gap-3 mb-3">
            <select data-home-price-target="category" data-action="change->home-price#calculate"
                    class="flex-shrink-0 w-24 rounded-xl border-0 bg-slate-900 backdrop-blur-md text-white px-3 py-4 text-sm font-bold focus:ring-2 focus:ring-indigo-400 focus:border-indigo-400 shadow-lg">
              <option value="goods" class="text-slate-900 font-bold">물품</option>
              <option value="service" class="text-slate-900 font-bold">용역</option>
              <option value="construction" class="text-slate-900 font-bold">공사</option>
            </select>
            <div class="flex-1 bg-white/10 backdrop-blur-md border border-white/10 rounded-2xl p-2 flex items-center shadow-lg">
              <input data-home-price-target="input" data-action="input->home-price#format"
                     class="w-full bg-transparent border-0 px-4 py-2 text-2xl font-bold text-white drop-shadow-lg placeholder:text-slate-500 focus:ring-0" placeholder="예: 20,000,000" type="text"/>
              <span class="text-slate-400 text-lg font-medium mr-4">원</span>
              <button type="button" data-action="click->home-price#calculate" class="shrink-0 rounded-xl bg-indigo-600 px-8 py-4 text-base font-bold text-white shadow-lg shadow-indigo-600/30 hover:bg-indigo-500 transition-all">
                조회하기
              </button>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 mb-4 justify-center lg:justify-start">
            <% [["1십만원", 100_000], ["1백만원", 1_000_000], ["1천만원", 10_000_000], ["5천만원", 50_000_000], ["1억원", 100_000_000]].each do |label, val| %>
              <button type="button" data-action="click->home-price#addAmount" data-value="<%= val %>" class="px-3 py-1.5 text-xs font-medium bg-white/5 text-slate-400 rounded-lg border border-white/10 hover:bg-indigo-600/20 hover:text-white hover:border-indigo-500/50 transition-all"><%= label %></button>
            <% end %>
          </div>
          <p class="text-center lg:text-right text-xs text-slate-500">* 부가세 포함 금액 기준</p>
          <div data-home-price-target="result" class="hidden mt-4">
            <div data-home-price-target="resultContent" class="p-4 rounded-xl border-2"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Daily Quiz Section -->
<section class="relative overflow-hidden py-24 bg-[#0B1120]">
  <div class="absolute inset-0 bg-gradient-to-r from-slate-900 to-indigo-950/40"></div>
  <%# blur-[100px] 제거 → 단순 그라디언트 (모바일 GPU 부하 경감) %>
  <div class="absolute right-0 top-0 h-[500px] w-[500px] bg-indigo-600/5 rounded-full pointer-events-none"></div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-16">
      <div class="max-w-xl text-white">
        <div class="mb-6 inline-flex items-center rounded-full bg-indigo-500/20 px-4 py-1.5 text-sm font-semibold text-indigo-300 ring-1 ring-inset ring-indigo-500/30">
          <span class="mr-2 h-1.5 w-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
          오늘의 실무 퀴즈
        </div>
        <h2 class="text-4xl font-bold tracking-tight sm:text-5xl leading-tight">매일 하나씩,<br/><span class="text-indigo-400">계약 전문가</span>로 성장하세요.</h2>
        <p class="mt-6 text-xl text-slate-400 font-light leading-relaxed">하루 1분 투자로 헷갈리는 법령과 지침을 마스터할 수 있습니다.<br/>틀려도 괜찮아요, 명쾌한 해설이 있으니까요.</p>
      </div>
      <div class="w-full max-w-md">
        <div class="glass-dark rounded-3xl p-8 shadow-2xl relative border-t border-white/10"
             data-controller="home-quiz">
          <div class="absolute -top-3 -right-3 h-20 w-20 bg-emerald-500/20 blur-2xl rounded-full"></div>
          <div class="mb-8 flex items-center justify-between">
            <span data-home-quiz-target="progress" class="text-xs font-bold tracking-widest text-slate-400 uppercase">문제 1/5</span>
            <span data-home-quiz-target="category" class="inline-flex items-center rounded-md bg-emerald-400/10 px-2 py-1 text-xs font-bold text-emerald-400 ring-1 ring-inset ring-emerald-400/20">예산회계</span>
          </div>
          <h3 data-home-quiz-target="question" class="mb-10 text-xl font-bold text-white leading-relaxed"></h3>
          <div class="space-y-3" data-home-quiz-target="options"></div>
          <div data-home-quiz-target="result" class="hidden mt-4 p-4 rounded-xl">
            <p class="font-semibold text-lg" data-home-quiz-target="resultMessage"></p>
            <p class="text-sm mt-2 text-gray-300" data-home-quiz-target="resultExplanation"></p>
          </div>
          <div data-home-quiz-target="final" class="hidden text-center py-6">
            <div class="text-5xl mb-3">&#127881;</div>
            <h3 class="text-xl font-bold text-white mb-2">퀴즈 완료!</h3>
            <p class="text-gray-300 mb-2">총 5문제 중 <span data-home-quiz-target="finalScore" class="text-emerald-400 font-bold">0</span>문제 정답</p>
            <button data-action="click->home-quiz#restart" class="mt-3 px-6 py-2.5 rounded-lg bg-indigo-600 text-white font-bold hover:bg-indigo-500 transition-colors">다시 도전하기</button>
          </div>
          <div data-home-quiz-target="footer" class="mt-6 flex justify-end">
            <button data-action="click->home-quiz#submit" data-home-quiz-target="submit" class="px-6 py-2.5 rounded-xl bg-indigo-600 text-white font-bold hover:bg-indigo-500 shadow-lg shadow-indigo-600/30 transition-all disabled:opacity-40 disabled:cursor-not-allowed" disabled>정답 확인</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- External Links / Partner Networks -->
<% cache "home/partners/v1/#{@sector}", expires_in: 24.hours do %>
<section class="bg-slate-50 py-20 border-t border-slate-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="mb-10 text-center text-lg font-bold text-slate-400 uppercase tracking-widest">Partner Networks</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
      <% [
        { url: "https://www.g2b.go.kr", abbr: "G2B",    name: "나라장터",     color: "text-blue-900",   highlight: @sector == "local_gov" },
        { url: "https://www.s2b.kr",    abbr: "S2B",    name: "학교장터",     color: "text-orange-500", highlight: @sector == "edu" },
        { url: "https://www.onbid.co.kr", abbr: "On-Bid", name: "온비드",     color: "text-green-600",  highlight: false },
        { url: "https://www.lofin365.go.kr", abbr: "e-Hozo", name: "지방재정", color: "text-slate-800",  highlight: false },
        { url: "https://eduinfo.go.kr", abbr: "EDUI",   name: "지방교육재정", color: "text-indigo-600", highlight: false },
        { url: "https://www.law.go.kr", abbr: "Law",    name: "국가법령센터", color: "text-violet-600", highlight: false }
      ].each do |p| %>
        <% card_class = p[:highlight] ? "bg-indigo-50 border-indigo-200 shadow-md" : "bg-white border-slate-100 shadow-sm" %>
        <a href="<%= p[:url] %>" target="_blank" rel="noopener" class="group relative flex flex-col items-center justify-center rounded-2xl <%= card_class %> p-6 border transition-all hover:-translate-y-1 hover:shadow-md hover:border-indigo-100">
          <% if p[:highlight] %>
            <span class="absolute -top-2 -right-2 text-xs font-bold bg-indigo-600 text-white px-2 py-0.5 rounded-full">주요</span>
          <% end %>
          <span class="mb-2 text-xl font-black <%= p[:color] %> group-hover:scale-105 transition-transform"><%= p[:abbr] %></span>
          <span class="text-xs font-medium text-slate-500"><%= p[:name] %></span>
        </a>
      <% end %>
    </div>
  </div>
</section>

<% end %><%# cache home/partners %>

<!-- Final CTA -->
<% cache "home/final_cta/v1", expires_in: 24.hours do %>
<section class="bg-white py-24">
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
      실무, 이제 더 쉽고 완벽하게.
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-xl text-slate-500 font-light">
      공무원이 선택한 프리미엄 실무 플랫폼, 지금 바로 시작해보세요.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
      <%= link_to new_user_registration_path, class: "rounded-xl bg-slate-900 px-8 py-4 text-base font-bold text-white shadow-xl shadow-slate-900/10 hover:bg-slate-800 hover:scale-105 transition-all" do %>
        지금 바로 시작하기
      <% end %>
      <%= link_to tools_path, class: "rounded-xl bg-slate-100 px-8 py-4 text-base font-bold text-slate-700 hover:bg-slate-200 transition-all" do %>
        실무 도구 둘러보기
      <% end %>
    </div>
  </div>
</section>

<% end %><%# cache home/final_cta %>

</div>
