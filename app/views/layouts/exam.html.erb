    <script>
    // #6 로그인 상태 확인 및 localStorage ↔ 서버 동기화
    (async function() {
      try {
        const res = await fetch('/sync', { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
        if (!res.ok) return
        const server = await res.json()
        if (!server.signed_in) return

        // 서버 데이터를 localStorage에 병합 (서버 우선)
        const localRaw = JSON.parse(localStorage.getItem('exam_progress') || '{}')
        const merged = {
          chapters: Object.assign({}, localRaw.chapters || {}, server.chapters || {}),
          quizzes: mergeQuizzes(localRaw.quizzes || {}, server.quizzes || {}),
          chapterQuizzes: mergeQuizzes(localRaw.chapterQuizzes || {}, server.chapter_quizzes || {})
        }
        localStorage.setItem('exam_progress', JSON.stringify(merged))

        // 오답 병합
        const localWrong = JSON.parse(localStorage.getItem('exam_wrong_answers') || '[]')
        const mergedWrong = [...new Set([...localWrong, ...(server.wrong_answers || [])])]
        localStorage.setItem('exam_wrong_answers', JSON.stringify(mergedWrong))

        // 북마크 병합
        const localBookmarks = JSON.parse(localStorage.getItem('exam_bookmarks') || '[]')
        const mergedBookmarks = [...new Set([...localBookmarks, ...(server.bookmarks || [])])]
        localStorage.setItem('exam_bookmarks', JSON.stringify(mergedBookmarks))

        // 스트릭 병합 (더 높은 count 유지)
        const localStreak = JSON.parse(localStorage.getItem('exam_streak') || '{"count":0}')
        if ((server.streak && server.streak.count || 0) > (localStreak.count || 0)) {
          localStorage.setItem('exam_streak', JSON.stringify({
            count: server.streak.count,
            lastDate: server.streak.lastDate,
            history: server.streak.history || []
          }))
        }

        window._examSynced = true
      } catch(e) {}

      function mergeQuizzes(local, serverData) {
        const result = Object.assign({}, local)
        Object.entries(serverData || {}).forEach(([k, v]) => {
          if (!result[k] || (v.pct || 0) >= (result[k].pct || 0)) result[k] = v
        })
        return result
      }
    })()
    </script>

    <script>
    // 수동 동기화 (드롭다운/모바일 버튼에서 호출)
    async function manualSync(btn) {
      const icon = btn && btn.querySelector('.sync-icon')
      const label = btn && btn.querySelector('.sync-label')
      if (icon) icon.classList.add('animate-spin')
      if (label) label.textContent = '동기화 중...'

      try {
        const progress = JSON.parse(localStorage.getItem('exam_progress') || '{}')
        const wrongAnswers = JSON.parse(localStorage.getItem('exam_wrong_answers') || '[]')
        const bookmarks = JSON.parse(localStorage.getItem('exam_bookmarks') || '[]')
        const streak = JSON.parse(localStorage.getItem('exam_streak') || '{}')
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content
        if (!csrfToken) throw new Error('CSRF 토큰 없음')

        const res = await fetch('/sync', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({
            chapters: progress.chapters || {},
            quizzes: progress.quizzes || {},
            chapter_quizzes: progress.chapterQuizzes || {},
            wrong_answers: wrongAnswers,
            bookmarks: bookmarks,
            streak_count: streak.count || 0,
            streak_last_date: streak.lastDate || null,
            streak_history: streak.history || []
          })
        })
        const data = await res.json()
        if (data.success) {
          showSyncToast('✅ 학습 데이터가 저장되었습니다.', 'success')
        } else {
          throw new Error(data.error || '서버 오류')
        }
      } catch(e) {
        showSyncToast('❌ 동기화 실패: ' + e.message, 'error')
      } finally {
        if (icon) icon.classList.remove('animate-spin')
        if (label) label.textContent = '학습 동기화'
        // 드롭다운 닫기
        document.getElementById('user-menu-dropdown')?.classList.add('hidden')
      }
    }

    function showSyncToast(message, type) {
      const existing = document.getElementById('sync-toast')
      if (existing) existing.remove()

      const toast = document.createElement('div')
      toast.id = 'sync-toast'
      toast.className = `fixed bottom-24 left-1/2 -translate-x-1/2 z-[9999] px-5 py-3 rounded-full text-sm font-semibold shadow-lg transition-all duration-300 opacity-0 ${
        type === 'success' ? 'bg-emerald-600 text-white' : 'bg-red-600 text-white'
      }`
      toast.textContent = message
      document.body.appendChild(toast)

      requestAnimationFrame(() => { toast.style.opacity = '1' })
      setTimeout(() => {
        toast.style.opacity = '0'
        setTimeout(() => toast.remove(), 300)
      }, 3000)
    }
    </script>

    <script>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        var closeBtn = document.getElementById('mobile-menu-close');
        function openMenu() { menu && menu.classList.remove('hidden'); }
        function closeMenu() { menu && menu.classList.add('hidden'); }
        btn && btn.addEventListener('click', openMenu);
        closeBtn && closeBtn.addEventListener('click', closeMenu);
        menu && menu.addEventListener('click', function(e) {
          if (e.target === menu) closeMenu();
        });
        document.addEventListener('turbo:load', function() { closeMenu(); });

      // 유저 드롭다운
      var userBtn = document.getElementById('user-menu-btn');
      var userDropdown = document.getElementById('user-menu-dropdown');
      if (userBtn && userDropdown) {
        userBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          userDropdown.classList.toggle('hidden');
        });
        document.addEventListener('click', function() { userDropdown.classList.add('hidden'); });
      }
      })();
    </script>

    <script>
    // Nav 연속 학습일(streak) 표시 — localStorage에서 읽어 뱃지에 반영
    (function() {
      function updateNavStreak() {
        var badge = document.getElementById('nav-streak-badge');
        var countEl = document.getElementById('nav-streak-count');
        if (!badge || !countEl) return;
        try {
          var streak = JSON.parse(localStorage.getItem('exam_streak') || '{"count":0}');
          var count = streak.count || 0;
          if (count >= 1) {
            countEl.textContent = count;
            badge.classList.remove('hidden');
            badge.classList.add('flex');
          }
        } catch(e) {}
      }
      // DOM 준비 후 + Turbo 페이지 전환 후 실행
      updateNavStreak();
      document.addEventListener('turbo:load', updateNavStreak);
    })();

    // Q&A 댓글 좋아요
    async function examQuizLikeComment(commentId, btn) {
      const key = 'qa_liked_' + commentId
      if (localStorage.getItem(key) === '1') return
      try {
        const csrf = document.querySelector('meta[name="csrf-token"]')?.content
        const pathParts = window.location.pathname.split('/')
        const questionId = btn.closest('[data-comment-id]')?.closest('.qa-area')?.previousElementSibling?.dataset?.questionId
        const res = await fetch('/questions/' + questionId + '/comments/' + commentId + '/like', {
          method: 'POST', headers: { 'X-CSRF-Token': csrf || '', 'Content-Type': 'application/json' }
        })
        const data = await res.json()
        if (data.likes_count !== undefined) {
          btn.querySelector('.like-count').textContent = data.likes_count
          btn.classList.remove('text-slate-400')
          btn.classList.add('text-blue-500', 'font-semibold')
          localStorage.setItem(key, '1')
        }
      } catch(e) {}
    }

    // Q&A 댓글 신고
    async function examQuizReportComment(commentId, btn) {
      const key = 'qa_reported_' + commentId
      if (localStorage.getItem(key) === '1') return
      if (!confirm('이 댓글을 신고하시겠습니까?')) return
      try {
        const csrf = document.querySelector('meta[name="csrf-token"]')?.content
        const qaBtn = btn.closest('.qa-area')?.previousElementSibling
        const questionId = qaBtn?.dataset?.questionId
        await fetch('/questions/' + questionId + '/comments/' + commentId + '/report', {
          method: 'POST', headers: { 'X-CSRF-Token': csrf || '', 'Content-Type': 'application/json' }
        })
        localStorage.setItem(key, '1')
        btn.textContent = '신고됨'
        btn.disabled = true
        btn.className = 'text-xs text-slate-300 ml-1'
      } catch(e) {}
    }

    // Q&A 댓글 삭제
    async function examQuizDeleteComment(commentId, btn) {
      if (!confirm('댓글을 삭제하시겠습니까?')) return
      try {
        const csrf = document.querySelector('meta[name="csrf-token"]')?.content
        const qaBtn = btn.closest('.qa-area')?.previousElementSibling
        const questionId = qaBtn?.dataset?.questionId
        const res = await fetch('/questions/' + questionId + '/comments/' + commentId, {
          method: 'DELETE', headers: { 'X-CSRF-Token': csrf || '', 'Content-Type': 'application/json' }
        })
        const data = await res.json()
        if (data.success) {
          btn.closest('[data-comment-id]')?.remove()
        }
      } catch(e) { alert('삭제에 실패했습니다.') }
    }
    </script>
