<!DOCTYPE html>
<html lang="ko" class="scroll-smooth" style="background-color:#f0f7ff;color:#0f172a;">
  <head>
    <%= display_meta_tags %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="color-scheme" content="light only">
    <meta name="application-name" content="실무.kr - 공공조달관리사">
    <meta name="theme-color" content="#1d4ed8">
    <meta name="google-site-verification" content="4f2zo86zRxW5JBhdwgpDx16xvZKaC_QBDsBXvcb8xRc" />
    <meta name="naver-site-verification" content="35e0ac97eb0b5463fb23f269f08bbcc729e81d77" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Fonts - 비동기 로딩 %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preload" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" fetchpriority="high">
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"></noscript>

    <%# Icons %>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Material Symbols — Google Fonts (아이콘 서브셋, API 호출 없음) %>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=analytics,apps,arrow_back,arrow_forward,arrow_forward_ios,article,assignment,assignment_turned_in,bolt,calendar_month,cancel,chat_bubble_outline,check_circle,checklist,chevron_right,circle,close,computer,description,dictionary,donut_large,edit_note,emoji_events,error,error_outline,expand_less,expand_more,fact_check,flag,format_list_numbered,gavel,groups,handshake,info,key,language,leaderboard,lightbulb,list,local_fire_department,logout,mail,manage_accounts,menu,menu_book,open_in_new,paid,percent,person,person_check,pin,play_arrow,psychology,public,quiz,schedule,school,search,search_off,star,summarize,sync,target,thumb_up,timer,tips_and_updates,touch_app,trending_down,trending_flat,trending_up,verified,warning,work" rel="stylesheet">

    <style>
      .material-symbols-outlined {
        font-family: 'Material Symbols Outlined';
        font-weight: normal;
        font-style: normal;
        font-size: inherit;
        line-height: 1;
        letter-spacing: normal;
        text-transform: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        vertical-align: middle;
        width: 1em;
        height: 1em;
        white-space: nowrap;
        word-wrap: normal;
        direction: ltr;
        font-feature-settings: 'liga';
        -webkit-font-feature-settings: 'liga';
        -webkit-font-smoothing: antialiased;
        overflow: hidden;
      }
    </style>

    <% exam_ga_id = ENV['EXAM_GA_MEASUREMENT_ID'].presence || ENV['GA_MEASUREMENT_ID'] %>
    <% if Rails.env.production? && exam_ga_id.present? && !current_user&.admin? %>
      <script>
        function loadGoogleAnalytics() {
          const script = document.createElement('script');
          script.src = 'https://www.googletagmanager.com/gtag/js?id=<%= exam_ga_id %>';
          script.async = true; document.head.appendChild(script);
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date()); gtag('config', '<%= exam_ga_id %>');
        }
        if ('requestIdleCallback' in window) { requestIdleCallback(loadGoogleAnalytics, { timeout: 3000 }); }
        else { setTimeout(loadGoogleAnalytics, 3000); }
      </script>
    <% end %>


    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application.tailwind", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <%# 모의고사 컨트롤러 (exam-quiz, exam-simulation, exam-analysis) 별도 번들 %>
    <%= javascript_include_tag "exam_controllers", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- 상단 공지 바: 실무.kr 돌아가기 링크 (dismiss 가능, 학습 페이지 숨김) -->
    <%
      notice_bar_hidden = %w[exam/quizzes exam/keywords exam/practical exam/subjects exam/chapters].any? { |c| params[:controller] == c }
    %>
    <% unless notice_bar_hidden %>
    <div id="exam-notice-bar" class="text-white text-sm py-2" style="background:#002b57">
      <div class="max-w-5xl mx-auto px-4 flex items-center justify-between gap-3">
        <span class="flex items-center gap-2 min-w-0">
          <span class="material-symbols-outlined text-base flex-shrink-0">school</span>
          <span class="truncate"><strong>공공조달관리사 시험 대비</strong> — 2026년 첫 시험 준비 중</span>
        </span>
        <div class="flex items-center gap-2 flex-shrink-0">
          <a href="https://silmu.kr" class="flex items-center gap-1 text-blue-200 hover:text-white transition-colors text-xs whitespace-nowrap">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            <span class="hidden sm:inline">실무.kr로 돌아가기</span>
          </a>
          <button type="button" onclick="dismissExamNotice()" aria-label="닫기"
                  class="text-blue-300 hover:text-white transition-colors p-1 rounded">
            <span class="material-symbols-outlined text-base">close</span>
          </button>
        </div>
      </div>
    </div>
    <script>
      (function() {
        if (localStorage.getItem('exam_notice_v1') === 'dismissed') {
          var bar = document.getElementById('exam-notice-bar');
          if (bar) bar.style.display = 'none';
        }
        window.dismissExamNotice = function() {
          localStorage.setItem('exam_notice_v1', 'dismissed');
          var bar = document.getElementById('exam-notice-bar');
          if (bar) {
            bar.style.height = bar.offsetHeight + 'px';
            bar.style.overflow = 'hidden';
            bar.style.transition = 'height 0.2s';
            requestAnimationFrame(function() {
              bar.style.height = '0';
              setTimeout(function() { bar.style.display = 'none'; }, 200);
            });
          }
        };

        // 스크롤 시 Notice Bar 자동 숨김
        (function() {
          var bar = document.getElementById('exam-notice-bar');
          if (!bar || bar.style.display === 'none') return;
          var lastY = 0;
          var hidden = false;
          window.addEventListener('scroll', function() {
            var y = window.scrollY;
            if (!hidden && y > 60 && y > lastY) {
              // 아래로 60px 이상 스크롤 — 숨김
              bar.style.height = bar.offsetHeight + 'px';
              bar.style.overflow = 'hidden';
              bar.style.transition = 'height 0.3s ease';
              requestAnimationFrame(function() {
                bar.style.height = '0';
              });
              hidden = true;
            } else if (hidden && y < 20) {
              // 최상단 복귀 시 다시 표시
              bar.style.transition = 'height 0.3s ease';
              bar.style.height = '40px';
              hidden = false;
            }
            lastY = y;
          }, { passive: true });
        })();
      })();
    </script>
    <% end %>

    <!-- Navigation -->
    <nav class="bg-white/85 backdrop-blur-xl sticky top-0 z-50" style="box-shadow:0px 4px 24px rgba(0,43,87,0.07)">
      <div class="max-w-5xl mx-auto px-4">
        <div class="flex justify-between h-16">
          <!-- Logo -->
          <div class="flex items-center">
            <a href="https://exam.silmu.kr" class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background:#002b57">
                <span class="material-symbols-outlined text-white text-xl">school</span>
              </div>
              <div>
                <span class="text-lg font-bold text-slate-900" style="font-family:'Manrope',sans-serif">공공조달관리사</span>
                <span class="text-xs font-medium block leading-none" style="color:#002b57">by 실무.kr</span>
              </div>
            </a>
          </div>

          <!-- Nav Links -->
          <%
            _ctrl = params[:controller].to_s
            _on_info      = _ctrl == 'exam/exam_info'
            _on_strategy  = _ctrl == 'exam/strategy'
            _on_curriculum = %w[exam/subjects exam/keywords].include?(_ctrl)
            _on_quiz      = _ctrl.start_with?('exam/quiz')
            _on_practical = _ctrl == 'exam/practical'
            _on_rankings  = _ctrl == 'exam/rankings'
          %>
          <div class="hidden md:flex items-center gap-1">
            <a href="<%= exam_exam_info_path %>" class="px-3 py-2 font-medium transition-colors text-sm rounded-lg <%= _on_info ? 'text-blue-700 bg-slate-50' : 'text-slate-600 hover:text-blue-700 hover:bg-slate-50' %>">시험 정보</a>
            <a href="<%= exam_exam_strategy_path %>" class="flex items-center gap-1 px-3 py-2 font-medium transition-colors text-sm rounded-lg <%= _on_strategy ? 'text-amber-600 bg-amber-50' : 'text-slate-600 hover:text-amber-600 hover:bg-amber-50' %>">
              <span class="material-symbols-outlined text-base">emoji_events</span>
              합격 전략
            </a>

            <!-- 커리큘럼 드롭다운 -->
            <div class="relative group">
              <button class="flex items-center gap-1 px-3 py-2 font-medium transition-colors text-sm rounded-lg <%= _on_curriculum ? 'text-blue-700 bg-slate-50' : 'text-slate-600 hover:text-blue-700 hover:bg-slate-50' %>">
                <span class="material-symbols-outlined text-base">school</span>
                커리큘럼
                <span class="material-symbols-outlined text-sm">expand_more</span>
              </button>
              <!-- 드롭다운 메뉴 -->
              <div class="absolute top-full left-0 mt-1 w-64 bg-white rounded-xl shadow-lg border border-slate-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
                <div class="p-2">
                  <a href="<%= exam_subjects_path %>" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-50 transition-colors">
                    <div class="w-7 h-7 bg-slate-700 rounded-md flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-white text-sm">format_list_numbered</span>
                    </div>
                    <div>
                      <div class="text-sm font-semibold text-slate-800">전체 커리큘럼</div>
                      <div class="text-xs text-slate-400">4권 27장 전체 보기</div>
                    </div>
                  </a>
                  <hr class="my-1.5 border-slate-100">
                  <% [
                    [1, "공공조달의 이해", "7장", "emerald", "account_balance"],
                    [2, "공공조달 계획분석", "6장", "blue", "analytics"],
                    [3, "공공계약관리", "6장", "violet", "handshake"],
                    [4, "공공조달 관리실무", "8장", "rose", "manage_accounts"]
                  ].each do |id, title, chapters, color, icon| %>
                    <a href="<%= exam_subject_path(id) %>" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-50 transition-colors">
                      <div class="w-7 h-7 bg-<%= color %>-600 rounded-md flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-white text-sm"><%= icon %></span>
                      </div>
                      <div class="min-w-0">
                        <div class="text-sm font-medium text-slate-800 truncate"><%= id %>권 <%= title %></div>
                        <div class="text-xs text-slate-400"><%= chapters %></div>
                      </div>
                    </a>
                  <% end %>
                  <hr class="my-1.5 border-slate-100">
                  <a href="<%= exam_keywords_path %>" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-yellow-50 transition-colors">
                    <div class="w-7 h-7 bg-yellow-400 rounded-md flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-yellow-900 text-sm">dictionary</span>
                    </div>
                    <div>
                      <div class="text-sm font-semibold text-slate-800">핵심 용어집</div>
                      <div class="text-xs text-slate-400">전체 키워드 한눈에</div>
                    </div>
                  </a>
                </div>
              </div>
            </div>

            <a href="<%= exam_quiz_index_path %>" class="flex items-center gap-1 px-3 py-2 font-medium transition-colors text-sm rounded-lg <%= _on_quiz ? 'text-blue-700 bg-slate-50' : 'text-slate-600 hover:text-blue-700 hover:bg-slate-50' %>">
              <span class="material-symbols-outlined text-base">quiz</span>
              모의고사
            </a>
            <a href="<%= exam_practical_path %>" class="flex items-center gap-1 px-3 py-2 font-medium transition-colors text-sm rounded-lg <%= _on_practical ? 'text-violet-700 bg-violet-50' : 'text-slate-600 hover:text-violet-700 hover:bg-violet-50' %>">
              <span class="material-symbols-outlined text-base">edit_note</span>
              실기 대비
            </a>
            <a href="<%= exam_rankings_path %>" class="flex items-center gap-1 px-3 py-2 font-medium transition-colors text-sm rounded-lg <%= _on_rankings ? 'text-amber-600 bg-amber-50' : 'text-slate-600 hover:text-amber-600 hover:bg-amber-50' %>">
              <span class="material-symbols-outlined text-base">leaderboard</span>
              랭킹
            </a>
          </div>

          <!-- CTA + 로그인 -->
          <div class="flex items-center gap-2">
            <%# 홈 페이지에서는 히어로 CTA와 중복되므로 숨김. 커리큘럼 페이지에서는 active(dark filled), 나머지는 outline %>
            <% unless _ctrl == 'exam/home' %>
              <% if _on_curriculum %>
                <a href="<%= exam_subjects_path %>" class="hidden md:flex items-center gap-1 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-all duration-200 hover:opacity-90 hover:shadow-md" style="background:linear-gradient(135deg,#002b57,#174174)">
                  <span class="material-symbols-outlined text-base">school</span>
                  학습 시작
                </a>
              <% else %>
                <a href="<%= exam_subjects_path %>" class="hidden md:flex items-center gap-1 text-slate-600 text-sm font-semibold px-4 py-2 rounded-lg border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all duration-200">
                  <span class="material-symbols-outlined text-base">school</span>
                  학습 시작
                </a>
              <% end %>
            <% end %>

            <% if user_signed_in? %>
              <!-- 로그인 상태: 학습 진행 상태 + 유저 드롭다운 -->
              <!-- 연속 학습일 (streak) — JS가 localStorage에서 읽어 채움 -->
              <div id="nav-streak-badge" class="hidden md:flex items-center gap-1 text-xs font-semibold text-orange-600 bg-orange-50 px-2.5 py-1.5 rounded-lg border border-orange-200">
                <span class="material-symbols-outlined text-sm">local_fire_department</span>
                <span id="nav-streak-count">-</span>
                <span class="text-orange-400 font-normal">일</span>
              </div>
              <div class="relative hidden md:block" id="user-menu-wrapper">
                <button id="user-menu-btn" class="flex items-center gap-1.5 px-3 py-2 rounded-lg hover:bg-slate-50 text-slate-600 text-sm font-medium transition-colors">
                  <span class="material-symbols-outlined text-base">person_check</span>
                  <span class="max-w-[80px] truncate"><%= current_user.email.split('@').first %></span>
                  <span class="material-symbols-outlined text-sm text-slate-400">expand_more</span>
                </button>
                <div id="user-menu-dropdown" class="hidden absolute right-0 top-full pt-1 w-44 z-50">
                  <div class="bg-white border border-slate-200 rounded-xl shadow-lg py-1">
                    <a href="<%= exam_rankings_path %>" class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50">
                      <span class="material-symbols-outlined text-amber-500 text-base">leaderboard</span>내 랭킹
                    </a>
                    <button onclick="manualSync(this)" class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 w-full text-left">
                      <span class="material-symbols-outlined text-blue-500 text-base sync-icon">sync</span>
                      <span class="sync-label">학습 동기화</span>
                    </button>
                    <hr class="border-slate-100 my-1">
                    <%= button_to destroy_user_session_path, method: :delete, form: { data: { turbo: false } }, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 w-full text-left" do %>
                      <span class="material-symbols-outlined text-base">logout</span>로그아웃
                    <% end %>
                  </div>
                </div>
              </div>
            <% else %>
              <!-- 미로그인 상태: 회원가입 + 로그인 버튼 -->
              <a href="<%= new_user_registration_path %>" class="hidden md:flex items-center gap-1 bg-blue-50 hover:bg-blue-100 text-blue-700 font-semibold text-sm px-3 py-2 rounded-lg transition-colors border border-blue-200">
                무료 가입
              </a>
              <a href="<%= new_user_session_path %>" class="hidden md:flex items-center gap-1 text-slate-600 hover:text-blue-700 font-medium text-sm px-3 py-2 rounded-lg hover:bg-slate-50 transition-colors border border-slate-200">
                <span class="material-symbols-outlined text-base">person</span>
                로그인
              </a>
            <% end %>

            <!-- 모바일 메뉴 버튼 -->
            <button id="mobile-menu-btn" class="md:hidden p-3 min-w-[44px] min-h-[44px] flex items-center justify-center text-slate-600 hover:text-blue-700 rounded-lg hover:bg-slate-50" aria-label="메뉴 열기">
              <span class="material-symbols-outlined">menu</span>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-emerald-50 border-l-4 border-emerald-500 px-4 py-4">
        <div class="max-w-5xl mx-auto flex items-center gap-3">
          <span class="material-symbols-outlined text-emerald-600">check_circle</span>
          <p class="text-emerald-800 font-medium"><%= notice %></p>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-50 border-l-4 border-red-500 px-4 py-4">
        <div class="max-w-5xl mx-auto flex items-center gap-3">
          <span class="material-symbols-outlined text-red-600">error</span>
          <p class="text-red-800 font-medium"><%= alert %></p>
        </div>
      </div>
    <% end %>

    <!-- 미로그인 유도 배너: 학습 페이지에서는 숨김 -->
    <%
      learning_controllers = %w[exam/quizzes exam/keywords exam/practical exam/subjects exam/chapters]
      hide_login_banner = learning_controllers.any? { |c| params[:controller] == c }
    %>
    <% unless user_signed_in? || hide_login_banner %>
      <div id="exam-login-banner" class="bg-gradient-to-r from-blue-50 to-indigo-50 border-b border-blue-200 px-4 py-3">
        <div class="max-w-5xl mx-auto flex items-center justify-between gap-3">
          <div class="flex items-center gap-2.5 min-w-0">
            <span class="material-symbols-outlined text-blue-600 text-xl flex-shrink-0">sync</span>
            <span class="text-sm text-slate-700 min-w-0">
              <strong class="text-blue-700">로그인</strong>하면 학습 진도·오답노트·북마크가 서버에 저장되어 어디서든 이어 공부할 수 있어요.
            </span>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <a href="<%= new_user_session_path %>" class="text-xs font-bold bg-blue-600 text-white px-3 py-1.5 rounded-lg hover:bg-blue-700 transition-colors whitespace-nowrap">
              로그인
            </a>
            <a href="<%= new_user_registration_path %>" class="text-xs font-semibold text-blue-700 border border-blue-300 bg-white px-3 py-1.5 rounded-lg hover:bg-blue-50 transition-colors whitespace-nowrap hidden sm:block">
              무료 가입
            </a>
            <button type="button" onclick="dismissExamLoginBanner()" aria-label="닫기"
                    class="text-slate-400 hover:text-slate-600 transition-colors p-1 rounded flex-shrink-0">
              <span class="material-symbols-outlined text-base">close</span>
            </button>
          </div>
        </div>
      </div>
      <script>
        (function() {
          if (localStorage.getItem('exam_login_banner_v1') === 'dismissed') {
            var el = document.getElementById('exam-login-banner');
            if (el) el.style.display = 'none';
          }
          window.dismissExamLoginBanner = function() {
            localStorage.setItem('exam_login_banner_v1', 'dismissed');
            var el = document.getElementById('exam-login-banner');
            if (el) {
              el.style.height = el.offsetHeight + 'px';
              el.style.overflow = 'hidden';
              el.style.transition = 'height 0.2s';
              requestAnimationFrame(function() {
                el.style.height = '0';
                setTimeout(function() { el.style.display = 'none'; }, 200);
              });
            }
          };
        })();
      </script>
    <% end %>

    <!-- Main Content: 모바일에서 Bottom Tab 높이만큼 하단 여백 -->
    <main class="flex-1 pb-16 md:pb-0">
      <%= yield %>
    </main>

    <!-- 모바일 Bottom Tab Bar (md 이상 숨김) -->
    <%
      current_ctrl = params[:controller].to_s
      current_action = params[:action].to_s
      tab_home   = current_ctrl == 'exam/home'
      tab_study  = %w[exam/subjects exam/chapters exam/keywords exam/practical exam/strategy exam/exam_info].include?(current_ctrl)
