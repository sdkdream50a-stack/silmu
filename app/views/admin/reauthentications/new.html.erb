<% content_for :title, "관리자 재인증" %>

<section class="section py-12">
  <div class="container mx-auto max-w-md px-4">
    <div class="bg-white border border-gray-200 rounded-2xl p-6 lg:p-8 shadow-sm">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-editorial-navy-bg rounded-lg flex items-center justify-center">
          <span class="material-symbols-outlined text-editorial-navy">lock</span>
        </div>
        <div>
          <h1 class="text-lg font-bold text-slate-900">관리자 재인증</h1>
          <p class="text-sm text-slate-500">민감한 작업 전 본인 확인이 필요합니다.</p>
        </div>
      </div>

      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_reauthentication_path, method: :post, local: true, class: "space-y-4" do |f| %>
        <div>
          <label for="password" class="block text-sm font-medium text-slate-700 mb-1.5">비밀번호</label>
          <%= f.password_field :password,
                id: "password",
                required: true,
                autofocus: true,
                autocomplete: "current-password",
                class: "w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-editorial-navy focus:ring-1 focus:ring-editorial-navy" %>
        </div>

        <button type="submit" class="w-full py-2.5 bg-slate-900 hover:bg-slate-700 text-white text-sm font-semibold rounded-lg transition-colors">
          재인증
        </button>
      <% end %>

      <div class="mt-6 pt-4 border-t border-gray-100 text-xs text-slate-500 space-y-1.5">
        <p>• 30분간 관리자 작업이 허용됩니다.</p>
        <p>• 소셜 로그인(카카오·네이버) 계정은 <%= link_to "다시 로그인", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-editorial-navy underline" %>해 갱신하세요.</p>
      </div>
    </div>
  </div>
</section>
