<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center gap-3 mb-8">
    <h1 class="text-2xl font-bold text-slate-900">Exam 관리자 대시보드</h1>
  </div>

  <!-- 요약 통계 -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
      <div class="text-3xl font-bold text-slate-800"><%= @stats[:total_comments] %></div>
      <div class="text-sm text-slate-500 mt-1">전체 댓글</div>
    </div>
    <div class="bg-white rounded-xl border border-orange-200 p-4 text-center">
      <div class="text-3xl font-bold text-orange-600"><%= @stats[:reported_comments] %></div>
      <div class="text-sm text-slate-500 mt-1">신고된 댓글</div>
    </div>
    <div class="bg-white rounded-xl border border-red-200 p-4 text-center">
      <div class="text-3xl font-bold text-red-600"><%= @stats[:hidden_comments] %></div>
      <div class="text-sm text-slate-500 mt-1">숨겨진 댓글</div>
    </div>
    <div class="bg-white rounded-xl border border-blue-200 p-4 text-center">
      <div class="text-3xl font-bold text-blue-600"><%= @stats[:total_reports] %></div>
      <div class="text-sm text-slate-500 mt-1">오류 제보</div>
    </div>
  </div>

  <!-- 신고된 댓글 -->
  <div class="bg-white rounded-2xl border border-slate-200 mb-8">
    <div class="px-6 py-4 border-b border-slate-200">
      <h2 class="font-bold text-slate-800 flex items-center gap-2">
        <span class="text-orange-500">&#9873;</span> 신고된 댓글 (<%= @reported_comments.size %>)
      </h2>
    </div>
    <% if @reported_comments.empty? %>
      <p class="text-center text-slate-400 py-8">신고된 댓글이 없습니다.</p>
    <% else %>
      <div class="divide-y divide-slate-100">
        <% @reported_comments.each do |c| %>
          <div class="px-6 py-4 flex items-start gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class="text-sm font-semibold text-slate-700"><%= c.author_display_name %></span>
                <span class="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">신고 <%= c.reported_count %>회</span>
                <% if c.hidden? %>
                  <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full">숨겨짐</span>
                <% end %>
                <span class="text-xs text-slate-400">문제 #<%= c.question_id %></span>
              </div>
              <p class="text-sm text-slate-600 break-words"><%= c.body %></p>
              <p class="text-xs text-slate-400 mt-1"><%= c.created_at.strftime("%Y.%m.%d %H:%M") %></p>
            </div>
            <div class="flex flex-col gap-2 flex-shrink-0">
              <% if c.hidden? %>
                <%= button_to "복구", restore_comment_analyics_exam_dashboard_index_path(id: c.id),
                    method: :patch, class: "text-xs bg-green-500 text-white px-3 py-1.5 rounded-lg hover:bg-green-600" %>
              <% end %>
              <%= button_to "삭제", delete_comment_analyics_exam_dashboard_index_path(id: c.id),
                  method: :delete, data: { turbo_confirm: "댓글을 삭제하시겠습니까?" },
                  class: "text-xs bg-red-500 text-white px-3 py-1.5 rounded-lg hover:bg-red-600" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- 오류 제보 -->
  <div class="bg-white rounded-2xl border border-slate-200">
    <div class="px-6 py-4 border-b border-slate-200">
      <h2 class="font-bold text-slate-800 flex items-center gap-2">
        <span class="text-blue-500">&#9873;</span> 문제 오류 제보 (<%= @question_reports.size %>)
      </h2>
    </div>
    <% if @question_reports.empty? %>
      <p class="text-center text-slate-400 py-8">오류 제보가 없습니다.</p>
    <% else %>
      <div class="divide-y divide-slate-100">
        <% @question_reports.each do |r| %>
          <div class="px-6 py-4 flex items-start gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">문제 #<%= r.question_id %></span>
                <% if r.user_id %>
                  <span class="text-xs text-slate-400">유저 #<%= r.user_id %></span>
                <% else %>
                  <span class="text-xs text-slate-400">비로그인</span>
                <% end %>
              </div>
              <p class="text-sm text-slate-600 break-words"><%= r.body %></p>
              <p class="text-xs text-slate-400 mt-1"><%= r.created_at.strftime("%Y.%m.%d %H:%M") %></p>
            </div>
            <div class="flex-shrink-0">
              <%= button_to "삭제", delete_report_analyics_exam_dashboard_index_path(id: r.id),
                  method: :delete, data: { turbo_confirm: "제보를 삭제하시겠습니까?" },
                  class: "text-xs bg-slate-500 text-white px-3 py-1.5 rounded-lg hover:bg-slate-600" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
