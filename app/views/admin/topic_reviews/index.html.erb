<% content_for :title, "법령 개정 검토 — Admin" %>

<div class="container-wide py-8">
  <h1 class="text-2xl font-bold text-slate-900 mb-2">법령 개정 영향 토픽 검토</h1>
  <p class="text-sm text-slate-600 mb-6">Sprint #4-B — Westlaw + Editorial Ops — LawSyncJob이 시행일 변경 감지 시 자동 flag</p>

  <%# 통계 %>
  <div class="grid grid-cols-3 gap-3 mb-6">
    <div class="bg-white border border-slate-200 rounded-lg p-3 text-center">
      <p class="text-xs text-slate-500 m-0">검토 대기</p>
      <p class="text-2xl font-bold text-rose-600 m-0"><%= @stats[:pending] %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-lg p-3 text-center">
      <p class="text-xs text-slate-500 m-0">동기화 법령</p>
      <p class="text-2xl font-bold text-slate-700 m-0"><%= @stats[:total_law_synced] %></p>
    </div>
    <div class="bg-white border border-slate-200 rounded-lg p-3 text-center">
      <p class="text-xs text-slate-500 m-0">최근 동기화</p>
      <p class="text-sm font-medium text-slate-700 m-0"><%= @stats[:last_sync]&.strftime("%Y-%m-%d %H:%M") || "—" %></p>
    </div>
  </div>

  <div class="bg-white border border-slate-200 rounded-lg overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-50">
        <tr>
          <th class="text-left px-3 py-2 font-medium">flag 시간</th>
          <th class="text-left px-3 py-2 font-medium">토픽</th>
          <th class="text-left px-3 py-2 font-medium">개정 사유</th>
          <th class="text-center px-3 py-2 font-medium">작업</th>
        </tr>
      </thead>
      <tbody>
        <% if @topics.empty? %>
          <tr><td colspan="4" class="text-center py-8 text-slate-400">검토 대기 토픽 없음 (모든 법령 신선도 OK)</td></tr>
        <% else %>
          <% @topics.each do |t| %>
            <tr class="border-t border-slate-100">
              <td class="px-3 py-2 text-xs text-slate-500"><%= t.review_flagged_at&.strftime("%m/%d %H:%M") %></td>
              <td class="px-3 py-2"><%= link_to t.name, topic_path(t.slug), class: "text-blue-600 hover:underline" %><br><span class="text-xs text-slate-400"><%= t.slug %></span></td>
              <td class="px-3 py-2 text-slate-700"><%= t.review_reason %></td>
              <td class="px-3 py-2 text-center">
                <%= button_to "검토 완료", resolve_admin_topic_review_path(t),
                      method: :patch,
                      class: "inline-flex items-center gap-1 px-3 py-1 rounded bg-emerald-100 text-emerald-700 hover:bg-emerald-200 text-xs font-medium",
                      form: { class: "inline-block" } %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
